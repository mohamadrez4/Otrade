@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "System Settings";
}

<div class="admin-page">

    <div class="panel-card">
        <div class="admin-section-header">
            <h3>System Settings</h3>
            <p>Manage platform wallet, withdrawal, email and SMTP settings.</p>
        </div>

        <div id="settingsMessage" class="admin-message">
            Loading settings...
        </div>

        <form id="settingsForm" autocomplete="off" class="admin-settings-form" style="display:none;">

            <div class="admin-settings-grid">

                <div class="admin-setting-group">
                    <label>Site Wallet Address</label>
                    <input id="SiteWalletAddress" class="panel-input" type="text" />
                </div>
                <div class="admin-setting-group">
                    <label>Site Wallet Network</label>
                    <input id="Network" class="panel-input" type="text" />
                </div>
                <div class="admin-setting-group">
                    <label>Admin Email</label>
                    <input id="ADMIN_EMAIL" class="panel-input" type="email" />
                </div>

                <div class="admin-setting-group">
                    <label>Withdrawal Limit</label>
                    <input id="WithdrawalLimit" class="panel-input" type="number" min="0" step="1" />
                </div>

                <div class="admin-setting-group">
                    <label>SMTP Host</label>
                    <input id="SmtpHost" class="panel-input" type="text" />
                </div>

                <div class="admin-setting-group">
                    <label>SMTP Port</label>
                    <input id="SmtpPort" class="panel-input" type="number" min="1" />
                </div>

                <div class="admin-setting-group">
                    <label>SMTP Username</label>
                    <input id="Username" class="panel-input" type="text" />
                </div>

                <div class="admin-setting-group">
                    <label>SMTP Password</label>
                    <input id="Password" class="panel-input" type="password" />
                </div>

                <div class="admin-setting-group">
                    <label>From Name</label>
                    <input id="FromName" class="panel-input" type="text" />
                </div>
                <div class="admin-setting-group">
                    <label>Telegram Bot Enabled</label>
                    <select id="TelegramBotEnabled" class="panel-input">
                        <option value="false">Disabled</option>
                        <option value="true">Enabled</option>
                    </select>
                </div>

                <div class="admin-setting-group">
                    <label>Telegram Bot Token</label>
                    <input id="TelegramBotToken" class="panel-input" type="password" placeholder="Enter bot token" />
                </div>

                <div class="admin-setting-group">
                    <label>Telegram Chat ID</label>
                    <input id="TelegramChatId" class="panel-input" type="text" />
                </div>

                <div class="admin-setting-group">
                    <label>Email Notifications</label>
                    <select id="NotificationEmailEnabled" class="panel-input">
                        <option value="true">Enabled</option>
                        <option value="false">Disabled</option>
                    </select>
                </div>

                <div class="admin-setting-group">
                    <label>Telegram Notifications</label>
                    <select id="NotificationTelegramEnabled" class="panel-input">
                        <option value="false">Disabled</option>
                        <option value="true">Enabled</option>
                    </select>
                </div>

                <div class="admin-setting-group">
                    <label>KYC Max File Size (MB)</label>
                    <input id="KycMaxFileSizeMB" class="panel-input" type="number" min="1" step="1" />
                </div>

                <div class="admin-setting-group">
                    <label>KYC Allowed Extensions</label>
                    <input id="KycAllowedExtensions" class="panel-input" type="text" placeholder="jpg,jpeg,png,pdf" />
                </div>

                <div class="admin-setting-group">
                    <label>Initial Registration Expire Hours</label>
                    <input id="InitialRegistrationExpireHours"
                           class="panel-input"
                           type="number"
                           min="1"
                           max="720"
                           step="1"
                           placeholder="72" />
                    <small class="setting-help-text">
                        Pre-registration request remains valid for this many hours.
                    </small>
                </div>
                <div class="admin-setting-group">
                    <label>Pre-Registration Wait Minutes</label>
                    <input id="PreRegistrationWaitMinutes"
                           class="panel-input"
                           type="number"
                           min="1"
                           max="120"
                           step="1"
                           placeholder="15" />
                    <small class="setting-help-text">
                        User waits on the approval page for this many minutes before the page stops polling automatically.
                    </small>
                </div>
            </div>

            <button id="saveSettingsBtn" type="submit" class="panel-primary-btn mt-3">
                Save Settings
            </button>

        </form>
    </div>

</div>

@section Scripts {
    <script>
        const settingsMessage = document.getElementById("settingsMessage");
        const settingsForm = document.getElementById("settingsForm");
        const saveSettingsBtn = document.getElementById("saveSettingsBtn");

        const settingKeys = [
            "SiteWalletAddress",
            "Network",
            "ADMIN_EMAIL",
            "WithdrawalLimit",
            "SmtpHost",
            "SmtpPort",
            "Username",
            "Password",
            "FromName",

            "TelegramBotEnabled",
            "TelegramBotToken",
            "TelegramChatId",
            "NotificationEmailEnabled",
            "NotificationTelegramEnabled",
            "KycMaxFileSizeMB",
            "KycAllowedExtensions",
            "InitialRegistrationExpireHours",
            "PreRegistrationWaitMinutes"
        ];

        async function loadSettings() {
            try {
                const result = await api("/api/admin/settings");

                if (!result.success) {
                    settingsMessage.innerText = result.message || "Could not load settings.";
                    return;
                }

                const settings = result.data || [];

                settingKeys.forEach(key => {
                    const input = document.getElementById(key);
                    const item = settings.find(x => x.key === key || x.Key === key);

                    if (input && item) {
                                if (key === "Password") {
                                    input.value = "";
                                    input.placeholder = "Leave empty to keep current password";
                                    return;
                                }
                                if (key === "TelegramBotToken") {
                                    input.value = "";
                                    input.placeholder = "Leave empty to keep current token";
                                    return;
                                }
                        input.value = item.value || item.Value || "";
                    }
                });

                settingsMessage.style.display = "none";
                settingsForm.style.display = "block";

            } catch (error) {
                settingsMessage.innerText = error.message || "Could not load settings.";
            }
        }
                function validateSettingsBeforeSave(settings) {
            const getValue = (key) => {
                return settings.find(x => x.key === key)?.value?.trim() || "";
            };

            const siteWalletAddress = getValue("SiteWalletAddress");
            const network = getValue("Network");
            const initialRegistrationExpireHours = Number(getValue("InitialRegistrationExpireHours"));
            const preRegistrationWaitMinutes = Number(getValue("PreRegistrationWaitMinutes"));

            if (!siteWalletAddress) {
                showNotification("Site wallet address is required.", "error");
                return false;
            }

            if (!network) {
                showNotification("Network is required.", "error");
                return false;
            }

            if (!initialRegistrationExpireHours ||
                initialRegistrationExpireHours < 1 ||
                initialRegistrationExpireHours > 720) {
                showNotification("Initial registration expire hours must be between 1 and 720.", "error");
                return false;
            }

            if (!preRegistrationWaitMinutes ||
                preRegistrationWaitMinutes < 1 ||
                preRegistrationWaitMinutes > 120) {
                showNotification("Pre-registration wait minutes must be between 1 and 120.", "error");
                return false;
            }

            return true;
        }
        settingsForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            const settings = settingKeys.map(key => {
                return {
                    key: key,
                    value: document.getElementById(key).value
                };
            });
                if (!validateSettingsBeforeSave(settings)) {
                    return;
                }

            saveSettingsBtn.disabled = true;
            saveSettingsBtn.innerText = "Saving...";

            try {
                const result = await api("/api/admin/settings/save", {
                    method: "POST",
                    body: JSON.stringify({
                        settings: settings
                    })
                });
                        if (!result || result.success !== true) {
            showNotification(result?.message || "Could not save settings.", "error");
            return;
        }

        showNotification(result?.message || "Settings saved successfully.", "success");

        setTimeout(async () => {
            await loadSettings();
        }, 500);

            } catch (error) {
                showNotification(error.message || "Could not save settings.","error");
               
            } finally {
                saveSettingsBtn.disabled = false;
                saveSettingsBtn.innerText = "Save Settings";
            }
        });

        loadSettings();
    </script>
}