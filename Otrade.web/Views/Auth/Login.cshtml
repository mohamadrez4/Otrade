@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login | Otrade</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png?v=1" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png?v=1" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/auth.css" rel="stylesheet" />
    <link href="~/css/common.css" rel="stylesheet" />
    <script src="~/js/common.js"></script>
</head>
<body class="auth-body">

    <div class="auth-wrapper">

        <div class="auth-left">
            <div class="brand-glow"></div>
            <img class="hero-logo" src="~/images/Logo4.png" alt="Otrade Logo" />
            <div class="hero-content">
                <h1>Trade Smarter.<br />Grow Faster.</h1>
                <p>Access your investment dashboard, monitor profits, and manage your referral network.</p>

                <div class="stat-card">
                    <span>Total Investment</span>
                    <strong>$2.5M+</strong>
                </div>

                <div class="stat-card">
                    <span>Active Members</span>
                    <strong>12,583</strong>
                </div>

                <div class="stat-card">
                    <span>Daily Profit</span>
                    <strong>Up to 0.54%</strong>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <div class="login-card">

                <div class="logo-box">
                    <img src="~/images/logo.png" alt="Otrade Logo" />
                    <span>Online Trading Room</span>
                </div>

                <h2>Welcome Back</h2>
                <p class="subtitle">Login to your Otrade account</p>

                <form id="loginForm">
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" class="form-control auth-input" id="email" placeholder="Enter your email" />
                    </div>
                    <div class="mb-3">
                        <label>Password</label>
                        <div class="pre-password-wrap">
                            <input type="password"
                                   class="form-control auth-input"
                                   id="password"
                                   placeholder="Enter password" />

                            <button type="button"
                                    class="pre-eye-btn"
                                    onclick="togglePassword('password', this)"
                                    aria-label="Show password">
                                <span class="eye-open">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 5C7 5 2.7 8.1 1 12c1.7 3.9 6 7 11 7s9.3-3.1 11-7c-1.7-3.9-6-7-11-7Zm0 11.5A4.5 4.5 0 1 1 12 7.5a4.5 4.5 0 0 1 0 9Zm0-2A2.5 2.5 0 1 0 12 9.5a2.5 2.5 0 0 0 0 5Z" />
                                    </svg>
                                </span>

                                <span class="eye-closed">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3.3 2 2 3.3l3 3C3.2 7.6 1.8 9.6 1 12c1.7 3.9 6 7 11 7 2 0 3.9-.5 5.5-1.3l3.2 3.2 1.3-1.3L3.3 2Zm8.7 15c-3.8 0-7.1-2.1-8.8-5 .7-1.3 1.8-2.5 3.1-3.4l2.2 2.2A4.4 4.4 0 0 0 7.5 12 4.5 4.5 0 0 0 12 16.5c.4 0 .8-.1 1.2-.2l2 2A10.2 10.2 0 0 1 12 17Zm2.4-3.8c.1-.4.1-.8.1-1.2A4.5 4.5 0 0 0 10 7.5c-.4 0-.8.1-1.2.2L7.2 6.1C8.7 5.4 10.3 5 12 5c5 0 9.3 3.1 11 7a12.5 12.5 0 0 1-3.2 4.1l-2.1-2.1c.5-.6.8-1.3.8-2.1a2.5 2.5 0 0 0-2.5-2.5c-.8 0-1.5.3-2.1.8l-1.9-1.9c.1 0 .2-.1.3-.1A2.5 2.5 0 0 1 14.5 12c0 .1 0 .2-.1.3Z" />
                                    </svg>
                                </span>
                            </button>
                        </div>
                    </div>


                    <div class="d-flex justify-content-end mb-4">
                        <a href="/auth/forgotpassword" class="auth-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn login-btn w-100">
                        Login
                    </button>
                </form>

                <div class="auth-footer">
                    Don’t have an account?
                    <a href="/auth/register">Create account</a>
                </div>

            </div>
        </div>

    </div>

    <script>
        function getTokenPayload(token) {
            try {
                return JSON.parse(atob(token.split('.')[1]));
            } catch {
                return null;
            }
        }

        function getIsAdmin(payload) {
            if (!payload) return false;
                  

            return     payload.isAdmin
               
        }

        const token = localStorage.getItem("token");
        if (token) {
            const payload = getTokenPayload(token);

            if (payload && payload.exp * 1000 > Date.now()) {
                const isAdmin = getIsAdmin(payload);

                if (isAdmin.toString().toLowerCase()=="true") {
                    window.location.href = "/admin/dashboard";
                } else {
                    window.location.href = "/dashboard";
                }
            } else {
                localStorage.removeItem("token");
            }
        }

        document.getElementById("loginForm")
            .addEventListener("submit", async function (e) {
                e.preventDefault();

                const email = document.getElementById("email").value;
                const password = document.getElementById("password").value;
                if (!isValidEmail(email)) {
                    showNotification("Please enter a valid email address.", "error");
                     return;
                }
                if (!email || !password) {
                    showNotification("Please enter email and password","error");
                    
                    return;
                }

                try {
                    const response = await fetch("/api/auth/login", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify({
                            email: email,
                            password: password
                        })
                    });

                    const result = await response.json();

                    if (!result.success) {
                        showNotification(result.message,"error");
                      
                        return;
                    }

                    localStorage.setItem("token", result.data.token);
                    localStorage.setItem("userId", result.data.userId);

                    const isAdmin = result.data.isAdmin;
                      debugger;
                    if (isAdmin.toString().toLowerCase()=="true") {
                        window.location.href = "/admin/dashboard";
                    } else {
                        window.location.href = "/dashboard";
                    }
                }
                catch (error) {
                    console.error(error);
                    showNotification("Unable to connect to server","error");
                   
                }
            });
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);

            const isHidden = input.type === "password";

            input.type = isHidden ? "text" : "password";

            btn.classList.toggle("is-visible", isHidden);

            btn.setAttribute(
                "aria-label",
                isHidden ? "Hide password" : "Show password"
            );
        }
    </script>
    <div id="notificationContainer"
         class="notification-container">
    </div>
</body>

</html>