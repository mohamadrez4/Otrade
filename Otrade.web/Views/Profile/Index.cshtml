        // ---------------------
        function normalizeValue(value) {
            return String(value || "")
                .trim()
                .toLowerCase()
                .replaceAll("_", "")
                .replaceAll("-", "")
                .replaceAll(" ", "");
        }

        function isApproved(status) {
            const value = normalizeValue(status);
            return value === "approved" || value === "2";
        }

        function isPending(status) {
            const value = normalizeValue(status);
            return value === "pending" || value === "0" || value === "1";
        }

        function isRejected(status) {
            const value = normalizeValue(status);
            return value === "rejected" || value === "3";
        }

        function isNationalId(documentType) {
            const value = normalizeValue(documentType);

            return value === "nationalid" ||
                value === "nationalidimage" ||
                value === "nationalcard" ||
                value === "nationalidcard";
        }

        function isSelfie(documentType) {
            const value = normalizeValue(documentType);

            return value === "selfie" ||
                value === "selfieimage" ||
                value === "selfiewithid";
        }

        function getBestKycDocument(docs, type) {
            const filtered = (docs || []).filter(doc => {
                if (type === "NationalId") {
                    return isNationalId(doc.documentType);
                }

                if (type === "Selfie") {
                    return isSelfie(doc.documentType);
                }

                return false;
            });

            if (!filtered.length) {
                return null;
            }

            const approved = filtered.find(doc => isApproved(doc.status));
            if (approved) return approved;

            const pending = filtered.find(doc => isPending(doc.status));
            if (pending) return pending;

            const rejected = filtered.find(doc => isRejected(doc.status));
            if (rejected) return rejected;

            return filtered[0];
        }

        function canUploadDocument(doc) {
            if (!doc) {
                return true;
            }

            return isRejected(doc.status);
        }

        function setSubmitKycVisible(isVisible) {
            if (isVisible) {
                submitKycBtn.hidden = false;
                submitKycBtn.classList.remove("kyc-submit-hidden");
                submitKycBtn.style.setProperty("display", "inline-flex", "important");
                return;
            }

            submitKycBtn.hidden = true;
            submitKycBtn.classList.add("kyc-submit-hidden");
            submitKycBtn.style.setProperty("display", "none", "important");
        }

        function setFilePickerVisible(input, isVisible) {
            const filePicker = input.closest(".kyc-file-picker");

            if (!filePicker) {
                return;
            }

            filePicker.style.display = isVisible ? "flex" : "none";
        }

        function clearFileInput(input, fileNameElement) {
            input.value = "";

            if (fileNameElement) {
                fileNameElement.innerText = "No file chosen";
                fileNameElement.classList.remove("has-file");
            }
        }

        function showRejectReason(reason, box, textElement) {
            const value = String(reason || "").trim();

            if (!box || !textElement || !value) {
                hideRejectReason(box, textElement);
                return;
            }

            box.style.display = "block";
            textElement.innerText = value;
        }

        function hideRejectReason(box, textElement) {
            if (!box || !textElement) {
                return;
            }

            box.style.display = "none";
            textElement.innerText = "";
        }

        function setupFileNamePreview(input, fileNameElement) {
            input.addEventListener("change", function () {
                const file = input.files && input.files[0];

                if (!file) {
                    fileNameElement.innerText = "No file chosen";
                    fileNameElement.classList.remove("has-file");
                    return;
                }

                fileNameElement.innerText = file.name;
                fileNameElement.classList.add("has-file");
            });
        }

        function renderKycDocument(doc, options) {
            const {
                group,
                input,
                fileNameElement,
                statusElement,
                label,
                rejectReasonBox,
                rejectReasonText
            } = options;

            group.style.display = "grid";
            hideRejectReason(rejectReasonBox, rejectReasonText);
            clearFileInput(input, fileNameElement);

            if (!doc) {
                setFilePickerVisible(input, true);

                input.disabled = false;
                input.required = true;

                statusElement.innerText = `${label} Missing`;
                statusElement.className = "profile-status rejected";
                return;
            }

            if (isApproved(doc.status)) {
                setFilePickerVisible(input, false);

                input.disabled = true;
                input.required = false;

                statusElement.innerText = `${label} Approved`;
                statusElement.className = "profile-status approved";
                return;
            }

            if (isPending(doc.status)) {
                setFilePickerVisible(input, false);

                input.disabled = true;
                input.required = false;

                statusElement.innerText = `${label} Pending Review`;
                statusElement.className = "profile-status pending";
                return;
            }

            if (isRejected(doc.status)) {
                setFilePickerVisible(input, true);

                input.disabled = false;
                input.required = true;

                statusElement.innerText = `${label} Rejected`;
                statusElement.className = "profile-status rejected";

                showRejectReason(
                    doc.rejectReason,
                    rejectReasonBox,
                    rejectReasonText
                );

                return;
            }

            setFilePickerVisible(input, true);

            input.disabled = false;
            input.required = true;

            statusElement.innerText = `${label} Missing`;
            statusElement.className = "profile-status rejected";
        }

        function updateKycSubmitButton(data, nationalDoc, selfieDoc) {
            if (isApproved(data.kycStatus)) {
                setSubmitKycVisible(false);
                return;
            }

            const nationalApproved = nationalDoc && isApproved(nationalDoc.status);
            const selfieApproved = selfieDoc && isApproved(selfieDoc.status);

            if (nationalApproved && selfieApproved) {
                setSubmitKycVisible(false);
                return;
            }

            const nationalCanUpload = canUploadDocument(nationalDoc);
            const selfieCanUpload = canUploadDocument(selfieDoc);

            setSubmitKycVisible(nationalCanUpload || selfieCanUpload);
        }

