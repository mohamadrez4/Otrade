@{
    ViewData["Title"] = "Profile";
}

<div class="profile-page">

    <!-- Profile Info -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>Profile Information</h3>
                <p>View your account information and verification status.</p>
            </div>
        </div>

        <div id="profileMessage" class="profile-message">
            Loading profile...
        </div>

        <div id="profileContent" class="profile-grid" style="display:none;">
            <div class="profile-info-item">
                <span>First Name</span>
                <strong id="firstName">-</strong>
            </div>

            <div class="profile-info-item">
                <span>Last Name</span>
                <strong id="lastName">-</strong>
            </div>

            <div class="profile-info-item">
                <span>Email</span>
                <strong id="email">-</strong>
            </div>

            <div class="profile-info-item">
                <span>Referral Code</span>
                <strong id="referralCode">-</strong>
            </div>

            <div class="profile-info-item">
                <span>KYC Status</span>
                <strong id="kycStatus" class="profile-status">-</strong>
            </div>
        </div>
    </div>

    <!-- Wallet Address -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>Withdrawal Wallet Address</h3>
                <p>This address will be used for your withdrawal requests.</p>
            </div>
        </div>

        <div id="walletAddressMessage" class="profile-alert" style="display:none;"></div>

        <form id="walletAddressForm" class="profile-form" autocomplete="off">
            <div class="profile-form-group">
                <label for="network">Network</label>

                <select id="network" class="panel-input" required>
                    <option value="">Select network</option>
                    <option value="TRC20">TRC20</option>
                    <option value="BEP20">BEP20</option>
                </select>
            </div>

            <div class="profile-form-group">
                <label for="walletAddress">Wallet Address</label>

                <input id="walletAddress"
                       class="panel-input"
                       type="text"
                       autocomplete="new-password"
                       placeholder="Enter your wallet address"
                       required />
            </div>

            <button id="saveWalletBtn" type="submit" class="panel-primary-btn">
                Save Wallet Address
            </button>
        </form>
    </div>

    <!-- KYC -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>KYC Verification</h3>
                <p>Upload only the documents that are missing or rejected.</p>
            </div>
        </div>

        <div id="kycMessage" class="profile-alert" style="display:none;"></div>

        <form id="kycForm" class="profile-form" autocomplete="off">

            <!-- National ID -->
            <div id="nationalIdGroup" class="profile-form-group">
                <label for="nationalIdImage">National ID Image</label>

                <div class="kyc-file-picker">
                    <input id="nationalIdImage"
                           class="kyc-file-input"
                           type="file"
                           accept="image/*" />

                    <label for="nationalIdImage" class="kyc-file-btn">
                        Choose File
                    </label>

                    <span id="nationalIdFileName" class="kyc-file-name">
                        No file chosen
                    </span>
                </div>

                <span id="nationalIdStatus" class="profile-status"></span>

                <div id="nationalIdRejectReasonBox"
                     class="kyc-reject-reason-box"
                     style="display:none;">
                    <strong>National ID Reject Reason</strong>
                    <p id="nationalIdRejectReasonText"></p>
                </div>
            </div>

            <!-- Selfie -->
            <div id="selfieGroup" class="profile-form-group">
                <label for="selfieImage">Selfie Image</label>

                <div class="kyc-file-picker">
                    <input id="selfieImage"
                           class="kyc-file-input"
                           type="file"
                           accept="image/*" />

                    <label for="selfieImage" class="kyc-file-btn">
                        Choose File
                    </label>

                    <span id="selfieFileName" class="kyc-file-name">
                        No file chosen
                    </span>
                </div>

                <span id="selfieStatus" class="profile-status"></span>

                <div id="selfieRejectReasonBox"
                     class="kyc-reject-reason-box"
                     style="display:none;">
                    <strong>Selfie Reject Reason</strong>
                    <p id="selfieRejectReasonText"></p>
                </div>
            </div>

            <button id="submitKycBtn"
                    type="submit"
                    class="panel-primary-btn kyc-submit-hidden"
                    hidden>
                Submit KYC
            </button>
        </form>
    </div>

    <!-- Change Password -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>Change Password</h3>
                <p>Update your account password.</p>
            </div>
        </div>

        <div id="passwordMessage" class="profile-alert" style="display:none;"></div>

        <form id="passwordForm" class="profile-form" autocomplete="off">
            <div class="profile-form-group">
                <label for="currentPassword">Current Password</label>

                <input id="currentPassword"
                       class="panel-input"
                       type="password"
                       autocomplete="new-password"
                       placeholder="Enter current password"
                       required />
            </div>

            <div class="profile-form-group">
                <label for="newPassword">New Password</label>

                <input id="newPassword"
                       class="panel-input"
                       type="password"
                       autocomplete="new-password"
                       placeholder="Enter new password"
                       required />
            </div>

            <button id="changePasswordBtn" type="submit" class="panel-primary-btn">
                Change Password
            </button>
        </form>
    </div>

</div>

@section Scripts {
    <script>
        // ---------------------
        // Elements
        // ---------------------
        const profileMessage = document.getElementById("profileMessage");
        const profileContent = document.getElementById("profileContent");

        const firstName = document.getElementById("firstName");
        const lastName = document.getElementById("lastName");
        const email = document.getElementById("email");
        const referralCode = document.getElementById("referralCode");
        const kycStatus = document.getElementById("kycStatus");

        const walletAddressForm = document.getElementById("walletAddressForm");
        const networkInput = document.getElementById("network");
        const walletAddressInput = document.getElementById("walletAddress");
        const saveWalletBtn = document.getElementById("saveWalletBtn");
        const walletAddressMessage = document.getElementById("walletAddressMessage");

        const kycForm = document.getElementById("kycForm");
        const nationalIdImage = document.getElementById("nationalIdImage");
        const selfieImage = document.getElementById("selfieImage");
        const submitKycBtn = document.getElementById("submitKycBtn");
        const kycMessage = document.getElementById("kycMessage");

        const nationalIdGroup = document.getElementById("nationalIdGroup");
        const selfieGroup = document.getElementById("selfieGroup");
        const nationalIdStatus = document.getElementById("nationalIdStatus");
        const selfieStatus = document.getElementById("selfieStatus");

        const nationalIdFileName = document.getElementById("nationalIdFileName");
        const selfieFileName = document.getElementById("selfieFileName");

        const nationalIdRejectReasonBox = document.getElementById("nationalIdRejectReasonBox");
        const nationalIdRejectReasonText = document.getElementById("nationalIdRejectReasonText");
        const selfieRejectReasonBox = document.getElementById("selfieRejectReasonBox");
        const selfieRejectReasonText = document.getElementById("selfieRejectReasonText");

        const passwordForm = document.getElementById("passwordForm");
        const currentPassword = document.getElementById("currentPassword");
        const newPassword = document.getElementById("newPassword");
        const changePasswordBtn = document.getElementById("changePasswordBtn");
        const passwordMessage = document.getElementById("passwordMessage");

        // ---------------------
        // Helpers
        // ---------------------
        function normalizeValue(value) {
            return String(value || "")
                .trim()
                .toLowerCase()
                .replaceAll("_", "")
                .replaceAll("-", "")
                .replaceAll(" ", "");
        }

        function isApproved(status) {
            const value = normalizeValue(status);
            return value === "approved" || value === "2";
        }

        function isPending(status) {
            const value = normalizeValue(status);
            return value === "pending" || value === "0" || value === "1";
        }

        function isRejected(status) {
            const value = normalizeValue(status);
            return value === "rejected" || value === "3";
        }

        function isNationalId(documentType) {
            const value = normalizeValue(documentType);

            return value === "nationalid" ||
                value === "nationalidimage" ||
                value === "nationalcard" ||
                value === "nationalidcard";
        }

        function isSelfie(documentType) {
            const value = normalizeValue(documentType);

            return value === "selfie" ||
                value === "selfieimage" ||
                value === "selfiewithid";
        }

        function getBestKycDocument(docs, type) {
            const filtered = (docs || []).filter(doc => {
                if (type === "NationalId") {
                    return isNationalId(doc.documentType);
                }

                if (type === "Selfie") {
                    return isSelfie(doc.documentType);
                }

                return false;
            });

            if (!filtered.length) {
                return null;
            }

            const approved = filtered.find(doc => isApproved(doc.status));
            if (approved) return approved;

            const pending = filtered.find(doc => isPending(doc.status));
            if (pending) return pending;

            const rejected = filtered.find(doc => isRejected(doc.status));
            if (rejected) return rejected;

            return filtered[0];
        }

        function canUploadDocument(doc) {
            if (!doc) {
                return true;
            }

            return isRejected(doc.status);
        }

        function setSubmitKycVisible(isVisible) {
            if (isVisible) {
                submitKycBtn.hidden = false;
                submitKycBtn.classList.remove("kyc-submit-hidden");
                submitKycBtn.style.setProperty("display", "inline-flex", "important");
                return;
            }

            submitKycBtn.hidden = true;
            submitKycBtn.classList.add("kyc-submit-hidden");
            submitKycBtn.style.setProperty("display", "none", "important");
        }

        function setFilePickerVisible(input, isVisible) {
            const filePicker = input.closest(".kyc-file-picker");

            if (!filePicker) {
                return;
            }

            filePicker.style.display = isVisible ? "flex" : "none";
        }

        function clearFileInput(input, fileNameElement) {
            input.value = "";

            if (fileNameElement) {
                fileNameElement.innerText = "No file chosen";
                fileNameElement.classList.remove("has-file");
            }
        }

        function showRejectReason(reason, box, textElement) {
            const value = String(reason || "").trim();

            if (!box || !textElement || !value) {
                hideRejectReason(box, textElement);
                return;
            }

            box.style.display = "block";
            textElement.innerText = value;
        }

        function hideRejectReason(box, textElement) {
            if (!box || !textElement) {
                return;
            }

            box.style.display = "none";
            textElement.innerText = "";
        }

        function setupFileNamePreview(input, fileNameElement) {
            input.addEventListener("change", function () {
                const file = input.files && input.files[0];

                if (!file) {
                    fileNameElement.innerText = "No file chosen";
                    fileNameElement.classList.remove("has-file");
                    return;
                }

                fileNameElement.innerText = file.name;
                fileNameElement.classList.add("has-file");
            });
        }

        function renderKycDocument(doc, options) {
            const {
                group,
                input,
                fileNameElement,
                statusElement,
                label,
                rejectReasonBox,
                rejectReasonText
            } = options;

            group.style.display = "grid";
            hideRejectReason(rejectReasonBox, rejectReasonText);
            clearFileInput(input, fileNameElement);

            if (!doc) {
                setFilePickerVisible(input, true);

                input.disabled = false;
                input.required = true;

                statusElement.innerText = `${label} Missing`;
                statusElement.className = "profile-status rejected";
                return;
            }

            if (isApproved(doc.status)) {
                setFilePickerVisible(input, false);

                input.disabled = true;
                input.required = false;

                statusElement.innerText = `${label} Approved`;
                statusElement.className = "profile-status approved";
                return;
            }

            if (isPending(doc.status)) {
                setFilePickerVisible(input, false);

                input.disabled = true;
                input.required = false;

                statusElement.innerText = `${label} Pending Review`;
                statusElement.className = "profile-status pending";
                return;
            }

            if (isRejected(doc.status)) {
                setFilePickerVisible(input, true);

                input.disabled = false;
                input.required = true;

                statusElement.innerText = `${label} Rejected`;
                statusElement.className = "profile-status rejected";

                showRejectReason(
                    doc.rejectReason,
                    rejectReasonBox,
                    rejectReasonText
                );

                return;
            }

            setFilePickerVisible(input, true);

            input.disabled = false;
            input.required = true;

            statusElement.innerText = `${label} Missing`;
            statusElement.className = "profile-status rejected";
        }

        function updateKycSubmitButton(data, nationalDoc, selfieDoc) {
            if (isApproved(data.kycStatus)) {
                setSubmitKycVisible(false);
                return;
            }

            const nationalApproved = nationalDoc && isApproved(nationalDoc.status);
            const selfieApproved = selfieDoc && isApproved(selfieDoc.status);

            if (nationalApproved && selfieApproved) {
                setSubmitKycVisible(false);
                return;
            }

            const nationalCanUpload = canUploadDocument(nationalDoc);
            const selfieCanUpload = canUploadDocument(selfieDoc);

            setSubmitKycVisible(nationalCanUpload || selfieCanUpload);
        }

        function showAlert(element, message, isSuccess) {
            element.innerText = message;
            element.className = isSuccess ? "profile-alert success" : "profile-alert error";
            element.style.display = "block";
        }

        function hideAlert(element) {
            element.innerText = "";
            element.style.display = "none";
        }

        // ---------------------
        // Load Profile
        // ---------------------
        async function loadProfile() {
            try {
                const result = await api("/api/profile");

                if (!result.success) {
                    profileMessage.innerText = result.message || "Could not load profile.";
                    profileMessage.style.display = "block";
                    return;
                }

                const data = result.data || {};

                firstName.innerText = data.firstName || "-";
                lastName.innerText = data.lastName || "-";
                email.innerText = data.email || "-";
                referralCode.innerText = data.referralCode || "-";

                kycStatus.innerText = data.kycStatus || "-";
                kycStatus.className = `profile-status ${String(data.kycStatus || "").toLowerCase()}`;

                if (data.walletAddress) {
                    networkInput.value = data.walletAddress.network || "";
                    walletAddressInput.value = data.walletAddress.address || "";
                }

                const kycDocs = data.kycDocuments || [];
                const nationalDoc = getBestKycDocument(kycDocs, "NationalId");
                const selfieDoc = getBestKycDocument(kycDocs, "Selfie");

                renderKycDocument(nationalDoc, {
                    group: nationalIdGroup,
                    input: nationalIdImage,
                    fileNameElement: nationalIdFileName,
                    statusElement: nationalIdStatus,
                    label: "National ID",
                    rejectReasonBox: nationalIdRejectReasonBox,
                    rejectReasonText: nationalIdRejectReasonText
                });

                renderKycDocument(selfieDoc, {
                    group: selfieGroup,
                    input: selfieImage,
                    fileNameElement: selfieFileName,
                    statusElement: selfieStatus,
                    label: "Selfie",
                    rejectReasonBox: selfieRejectReasonBox,
                    rejectReasonText: selfieRejectReasonText
                });

                updateKycSubmitButton(data, nationalDoc, selfieDoc);

                profileMessage.style.display = "none";
                profileContent.style.display = "grid";

            } catch (error) {
                profileMessage.innerText = error.message || "Could not load profile.";
                profileMessage.style.display = "block";
            }
        }

        // ---------------------
        // Wallet Address
        // ---------------------
        walletAddressForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            const network = networkInput.value.trim();
            const address = walletAddressInput.value.trim();

            if (!network || !address) {
                showAlert(walletAddressMessage, "Please enter network and wallet address.", false);
                return;
            }

            saveWalletBtn.disabled = true;
            saveWalletBtn.innerText = "Saving...";

            try {
                const result = await api("/api/wallet/address/save", {
                    method: "POST",
                    body: JSON.stringify({
                        network,
                        address
                    })
                });

                if (!result.success) {
                    showAlert(walletAddressMessage, result.message || "Could not save wallet address.", false);
                    return;
                }

                showAlert(walletAddressMessage, result.message || "Wallet address saved successfully.", true);

            } catch (error) {
                showAlert(walletAddressMessage, error.message || "Could not save wallet address.", false);
            } finally {
                saveWalletBtn.disabled = false;
                saveWalletBtn.innerText = "Save Wallet Address";
            }
        });

        // ---------------------
        // KYC Upload
        // ---------------------
        kycForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            hideAlert(kycMessage);

            const formData = new FormData();

            if (!nationalIdImage.disabled && nationalIdImage.files[0]) {
                formData.append("NationalIdImage", nationalIdImage.files[0]);
            }

            if (!selfieImage.disabled && selfieImage.files[0]) {
                formData.append("SelfieImage", selfieImage.files[0]);
            }

            if (formData.keys().next().done) {
                showAlert(kycMessage, "Please upload at least one document.", false);
                return;
            }

            submitKycBtn.disabled = true;
            submitKycBtn.innerText = "Submitting...";

            try {
                const result = await api("/api/kyc/upload", {
                    method: "POST",
                    body: formData
                });

                if (!result.success) {
                    showAlert(kycMessage, result.message || "Could not submit KYC.", false);
                    return;
                }

                showAlert(kycMessage, result.message || "KYC submitted successfully.", true);

                clearFileInput(nationalIdImage, nationalIdFileName);
                clearFileInput(selfieImage, selfieFileName);

                await loadProfile();

            } catch (error) {
                showAlert(kycMessage, error.message || "Could not submit KYC.", false);
            } finally {
                submitKycBtn.disabled = false;
                submitKycBtn.innerText = "Submit KYC";
            }
        });

        // ---------------------
        // Change Password
        // ---------------------
        passwordForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            const current = currentPassword.value.trim();
            const next = newPassword.value.trim();

            if (!current || !next) {
                showAlert(passwordMessage, "Please enter current and new password.", false);
                return;
            }

            if (next.length < 6) {
                showAlert(passwordMessage, "New password must be at least 6 characters.", false);
                return;
            }

            changePasswordBtn.disabled = true;
            changePasswordBtn.innerText = "Changing...";

            try {
                const result = await api("/api/profile/change-password", {
                    method: "POST",
                    body: JSON.stringify({
                        currentPassword: current,
                        newPassword: next
                    })
                });

                if (!result.success) {
                    showAlert(passwordMessage, result.message || "Could not change password.", false);
                    return;
                }

                showAlert(passwordMessage, result.message || "Password changed successfully.", true);

                currentPassword.value = "";
                newPassword.value = "";

            } catch (error) {
                showAlert(passwordMessage, error.message || "Could not change password.", false);
            } finally {
                changePasswordBtn.disabled = false;
                changePasswordBtn.innerText = "Change Password";
            }
        });

        // ---------------------
        // Init
        // ---------------------
        setupFileNamePreview(nationalIdImage, nationalIdFileName);
        setupFileNamePreview(selfieImage, selfieFileName);

        setSubmitKycVisible(false);
        loadProfile();
    </script>
}