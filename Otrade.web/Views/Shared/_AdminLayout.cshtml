<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] | Otrade Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/flatpickr.min.css" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="~/css/panel.css"
      rel="stylesheet"
      asp-append-version="true" />

<link href="~/css/admin.css"
      rel="stylesheet"
      asp-append-version="true" />

<link href="~/css/common.css"
      rel="stylesheet"
      asp-append-version="true" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png?v=1" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png?v=1" />
    <script src="~/js/common.js"></script>
    <script src="~/js/auth.js"></script>
    <script src="~/js/flatpickr.js"></script>
    <script>
        checkAuth();
    </script>
</head>
<body class="panel-body">
    <div id="notificationContainer" class="notification-container"></div>
    <div class="panel-layout">

        <aside class="sidebar">
            <div class="sidebar-logo">
                <img src="~/images/logo.png" />
            </div>
            <div class="admin-role-layout-badge" id="adminRoleBadge">
                Admin
            </div>
            <nav class="sidebar-nav">

                <a href="/admin/dashboard" class="nav-item" data-permission="viewReports">
                    <span>Admin Dashboard</span>
                </a>
                <a href="/admin/wallet-overview" class="nav-item" data-permission="viewReports">
                    <span>Wallet Overview</span>
                </a>
                <a href="/admin/deposits" class="nav-item" data-permission="manageDeposits">
                    <span>Deposits</span>
                </a>
                <a href="/admin/pre-registrations" class="nav-item" data-permission="manageDeposits">
                    <span>Pre-Registrations</span>
                </a>
                <a href="/admin/bonus-codes" class="nav-item" data-permission="manageBonus">
                    <span>Bonus Codes</span>
                </a>
                <a href="/admin/investment-capacity" class="nav-item" data-permission="manageDeposits">
                    <span>Investment Capacity</span>
                </a>
                <a href="/admin/investment-wait-list" class="nav-item" data-permission="manageDeposits">
                    <span>Investment Wait List</span>
                </a>
                <a href="/admin/withdrawals" class="nav-item" data-permission="manageWithdrawals">
                    <span>Withdrawals</span>
                </a>

                <a href="/admin/kyc" class="nav-item" data-permission="manageKyc">
                    <span>KYC</span>
                </a>
                <a href="/admin/two-factor-recovery" class="nav-item" data-permission="manageKyc">
                    <span>Two-Factor Recovery</span>
                </a>
                <a href="/admin/tickets" class="nav-item" data-permission="manageTickets">
                    <span>Tickets</span>
                </a>

                <a href="/admin/users" class="nav-item" data-permission="manageUsers">
                    <span>Users</span>
                </a>

                <a href="/admin/reports" class="nav-item" data-permission="viewReports">
                    <span>Reports</span>
                </a>

                <a href="/admin/settings" class="nav-item" data-permission="manageSettings">
                    <span>Settings</span>
                </a>

                <a href="/dashboard" class="nav-item" data-permission="viewReports">
                    <span>User Panel</span>
                </a>

                <a href="javascript:void(0)" data-permission="manageHangfire" onclick="openHangfireDashboard()">
                    Hangfire
                </a>
            </nav>

            <button class="logout-btn" onclick="logout()">Logout</button>
        </aside>
        <div class="sidebar-mobile-overlay" id="sidebarMobileOverlay"></div>

        <main class="panel-main">
            <header class="topbar">
                <button type="button"
                        class="mobile-menu-btn"
                        id="mobileMenuBtn"
                        aria-label="Open menu">
                    ☰
                </button>

                <div>
                    <h4>@ViewData["Title"]</h4>
                </div>
            </header>

            <section class="content">
                @RenderBody()
            </section>
        </main>

    </div>

    <script src="~/js/api.js"></script>
    <script>
        const currentPath = window.location.pathname.toLowerCase();

        document.querySelectorAll(".sidebar-nav a").forEach(link => {
            const href = link.getAttribute("href").toLowerCase();

            if (currentPath === href || currentPath.startsWith(href + "/")) {
                link.classList.add("active");
            }
        });
                document.addEventListener("DOMContentLoaded", async function () {
            await refreshAdminSession();
            await loadAdminAccess();
        });

        async function loadAdminAccess() {
            try {
                const result = await api("/api/admin/me/access", {
                    method: "GET"
                });

                const access = result.data || result;

                applyAdminAccess(access);
                renderAdminRoleBadge(access);

            } catch (error) {
                showNotification(
                    error.message || "Could not load admin permissions.",
                    "error"
                );

                setTimeout(() => {
                    window.location.href = "/auth/login";
                }, 800);
            }
        }

        function applyAdminAccess(access) {
            document.querySelectorAll("[data-permission]").forEach(element => {
                const permission = element.getAttribute("data-permission");

                if (access && access[permission] === true) {
                    element.classList.add("permission-visible");
                } else {
                    element.classList.remove("permission-visible");
                }
            });
        }

        function renderAdminRoleBadge(access) {
            const roleBadge = document.getElementById("adminRoleBadge");

            if (!roleBadge || !access) {
                return;
            }

            roleBadge.textContent = access.adminRole || "Admin";
        }
                async function refreshAdminSession() {
            try {
                await api("/admin/session", {
                    method: "POST"
                });
            } catch {
            }
        }
                async function openHangfireDashboard() {
            try {
                const result = await api("/admin/hangfire/session", {
                    method: "POST"
                });

                window.location.href = result?.redirectUrl || "/hangfire";

            } catch (error) {
                showNotification(
                    error.message || "You do not have permission to access Hangfire.",
                    "error"
                );
            }
        }

        </script>
    <script>
    (function () {
        if (window.__otradeAdminSidebarInitialized) {
            return;
        }

        window.__otradeAdminSidebarInitialized =
            true;

        const body =
            document.body;

        const sidebar =
            document.querySelector(
                ".sidebar"
            );

        const menuButton =
            document.getElementById(
                "mobileMenuBtn"
            );

        const overlay =
            document.getElementById(
                "sidebarMobileOverlay"
            );

        const mobileMedia =
            window.matchMedia(
                "(max-width: 992px)"
            );

        function isMobileOrTablet() {
            return mobileMedia.matches;
        }

        function updateMenuState(isOpen) {
            if (menuButton) {
                menuButton.setAttribute(
                    "aria-expanded",
                    String(isOpen)
                );

                menuButton.setAttribute(
                    "aria-label",
                    isOpen
                        ? "Close menu"
                        : "Open menu"
                );
            }

            if (overlay) {
                overlay.setAttribute(
                    "aria-hidden",
                    String(!isOpen)
                );
            }

            if (sidebar) {
                sidebar.setAttribute(
                    "aria-hidden",
                    String(
                        isMobileOrTablet() &&
                        !isOpen
                    )
                );
            }
        }

        function openSidebar() {
            if (!isMobileOrTablet()) {
                return;
            }

            body.classList.add(
                "sidebar-open"
            );

            updateMenuState(true);
        }

        function closeSidebar() {
            body.classList.remove(
                "sidebar-open"
            );

            updateMenuState(false);
        }

        function toggleSidebar() {
            if (!isMobileOrTablet()) {
                return;
            }

            const isOpen =
                body.classList.contains(
                    "sidebar-open"
                );

            if (isOpen) {
                closeSidebar();
            } else {
                openSidebar();
            }
        }

        function synchronizeSidebar() {
            /*
             * کلاس قدیمی دیگر نباید در Desktop
             * منو را مخفی کند.
             */
            body.classList.remove(
                "sidebar-collapsed"
            );

            if (isMobileOrTablet()) {
                closeSidebar();
                return;
            }

            /*
             * در Desktop منو همیشه ثابت و باز است.
             */
            body.classList.remove(
                "sidebar-open"
            );

            updateMenuState(true);
        }

        if (menuButton) {
            menuButton.addEventListener(
                "click",
                function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    toggleSidebar();
                }
            );
        }

        if (overlay) {
            overlay.addEventListener(
                "click",
                function (event) {
                    event.preventDefault();

                    closeSidebar();
                }
            );
        }

        if (sidebar) {
            sidebar
                .querySelectorAll("a")
                .forEach(
                    function (link) {
                        link.addEventListener(
                            "click",
                            function () {
                                if (
                                    isMobileOrTablet()
                                ) {
                                    closeSidebar();
                                }
                            }
                        );
                    }
                );
        }

        document.addEventListener(
            "keydown",
            function (event) {
                if (
                    event.key === "Escape" &&
                    isMobileOrTablet()
                ) {
                    closeSidebar();
                }
            }
        );

        if (
            typeof mobileMedia.addEventListener ===
            "function"
        ) {
            mobileMedia.addEventListener(
                "change",
                synchronizeSidebar
            );
        } else {
            mobileMedia.addListener(
                synchronizeSidebar
            );
        }

        synchronizeSidebar();
    })();
</script>
    @RenderSection("Scripts", required: false)

</body>
</html>