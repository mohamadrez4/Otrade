            syncTwoFactorModalBodyState();

            window.setTimeout(
                () => {
                    if (mode === "disable") {
                        twoFactorActionPassword.focus();
                    } else {
                        twoFactorActionCode.focus();
                    }
                },
                50
            );
        }

        function renderRecoveryCodes(codes) {
            currentRecoveryCodes =
                Array.isArray(codes)
                    ? codes
                        .map(code =>
                            String(code || "").trim()
                        )
                        .filter(Boolean)
                    : [];

            recoveryCodesList.innerHTML =
                "";

            currentRecoveryCodes.forEach(
                (code, index) => {
                    const item =
                        document.createElement(
                            "div"
                        );

                    item.className =
                        "profile-2fa-recovery-code";

                    const number =
                        document.createElement(
                            "span"
                        );

                    number.innerText =
                        String(index + 1)
                            .padStart(2, "0");

                    const codeElement =
                        document.createElement(
                            "code"
                        );

                    codeElement.innerText =
                        code;

                    item.append(
                        number,
                        codeElement
                    );

                    recoveryCodesList.appendChild(
                        item
                    );
                }
            );

            recoveryCodesSavedCheck.checked =
                false;

            closeRecoveryCodesBtn.disabled =
                true;

            recoveryCodesModal.hidden =
                false;

            syncTwoFactorModalBodyState();
        }

        function closeRecoveryCodesModal() {
            if (
                !recoveryCodesSavedCheck.checked
            ) {
                showNotification(
                    "Confirm that you saved the recovery codes first.",
                    "warning"
                );

                return;
            }

            recoveryCodesModal.hidden =
                true;

            currentRecoveryCodes =
                [];

            recoveryCodesList.innerHTML =
                "";

            recoveryCodesSavedCheck.checked =
                false;

            closeRecoveryCodesBtn.disabled =
                true;

            syncTwoFactorModalBodyState();

            if (logoutAfterRecoveryCodes) {
                logoutAfterRecoveryCodes =
                    false;

                localStorage.removeItem(
                    "token"
                );

                localStorage.removeItem(
                    "userId"
                );

                window.location.href =
                    "/auth/login";
            }
        }

        function downloadRecoveryCodes() {
            if (!currentRecoveryCodes.length) {
                showNotification(
                    "No recovery codes are available.",
                    "warning"
                );

                return;
            }

            const content = [
                "Otrade Google Authenticator Recovery Codes",
                "Generated: " +
                    new Date().toLocaleString("en-US"),
                "",
                ...currentRecoveryCodes,
                "",
                "Each code can be used only once.",
                "Store this file in a secure location."
            ].join("\r\n");

            const blob =
                new Blob(
                    [content],
                    {
                        type:
                            "text/plain;charset=utf-8"
                    }
                );

            const url =
                URL.createObjectURL(blob);

            const link =
                document.createElement("a");

            link.href =
                url;

            link.download =
                "otrade-recovery-codes.txt";

            document.body.appendChild(link);
            link.click();
            link.remove();

            URL.revokeObjectURL(url);

            showNotification(
                "Recovery codes downloaded.",
                "success"
            );
        }

        // ---------------------
        // Google Authenticator API
        // ---------------------
        async function loadTwoFactorStatus() {
            hideTwoFactorStates();

            twoFactorLoading.hidden =
                false;

            setTwoFactorHeaderStatus(
                "loading",
                "Checking..."
            );

            try {
                const result = await api(
                    "/api/security/two-factor/status",
                    {
                        method: "GET"
                    }
                );

                if (!result || !result.success) {
                    throw new Error(
                        result?.message ||
                        "Could not load Google Authenticator status."
                    );
                }

                const data =
                    result.data || {};

                twoFactorLoading.hidden =
                    true;

                if (data.isEnabled) {
                    setTwoFactorHeaderStatus(
                        "enabled",
                        "Enabled"
                    );

                    twoFactorEnabledState.hidden =
                        false;

                    twoFactorEnabledAt.innerText =
                        formatTwoFactorDate(
                            data.enabledAt
                        );

                    const recoveryCount =
                        Number(
                            data.recoveryCodesRemaining ||
                            0
                        );

                    twoFactorRecoveryCount.innerText =
                        recoveryCount.toLocaleString(
                            "en-US"
                        );

                    twoFactorRecoveryCount.classList.toggle(
                        "low",
                        recoveryCount <= 2
                    );

                    twoFactorRecoveryWarning.hidden =
                        recoveryCount > 2;

                    return;
                }

                setTwoFactorHeaderStatus(
                    data.hasPendingSetup
                        ? "pending"
                        : "disabled",
                    data.hasPendingSetup
                        ? "Setup Pending"
                        : "Disabled"
                );

                twoFactorDisabledState.hidden =
                    false;

                if (data.hasPendingSetup) {
                    twoFactorDisabledDescription.innerText =
                        "A previous setup is still pending. For security, generate a new QR code to continue activation.";

                    startTwoFactorSetupBtn.innerText =
                        "Generate New Setup";
                } else {
                    twoFactorDisabledDescription.innerText =
                        "Add an extra security layer to your account. After activation, a code from your phone will be required for login and withdrawal.";

                    startTwoFactorSetupBtn.innerText =
                        "Enable Google Authenticator";
                }

            } catch (error) {
                twoFactorLoading.hidden =
                    false;

                twoFactorLoading.innerText =
                    error.message ||
                    "Could not load Google Authenticator status.";

                setTwoFactorHeaderStatus(
                    "error",
                    "Unavailable"
                );
            }
        }

        async function createTwoFactorSetup(
            triggerButton
        ) {
            const button =
                triggerButton ||
                startTwoFactorSetupBtn;

            const originalText =
                button.innerText;

            button.disabled =
                true;

            button.innerText =
                "Creating Setup...";

            try {
                const result = await api(
                    "/api/security/two-factor/setup",
                    {
                        method: "POST"
                    }
                );

                if (!result || !result.success) {
                    showNotification(
                        result?.message ||
                        "Could not create the Google Authenticator setup.",
                        "error"
                    );

                    return;
                }

                const data =
                    result.data || {};

                if (
                    !isSafeQrCodeDataUrl(
                        data.qrCodeDataUrl
                    )
                ) {
                    showNotification(
                        "The QR code returned by the server is invalid.",
                        "error"
                    );

                    return;
                }

                renderTwoFactorSetup(
                    data,
                    "enable"
                );

                showNotification(
                    result.message ||
                    "Google Authenticator setup created.",
                    "success"
                );

            } catch (error) {
                showNotification(
                    error.message ||
                    "Could not create the Google Authenticator setup.",
                    "error"
                );

            } finally {
                button.disabled =
                    false;

                button.innerText =
                    originalText;
            }
        }

        async function enableTwoFactor() {
            sanitizeTwoFactorSetupCode();

            const code =
                twoFactorSetupCode.value;

            if (!isValidSixDigitCode(code)) {
                showNotification(
                    "Enter the current 6-digit Google Authenticator code.",
                    "warning"
                );

                twoFactorSetupCode.focus();
                return;
            }

            confirmTwoFactorBtn.disabled =
                true;

            confirmTwoFactorBtn.innerText =
                "Verifying...";

            try {
                const endpoint =
                    twoFactorSetupMode === "replace"
                        ? "/api/security/two-factor/replace/confirm"
                        : "/api/security/two-factor/enable";

                const result = await api(
                    endpoint,
                    {
                        method: "POST",
                        body: JSON.stringify({
                            code: code
                        })
                    }
                );

                if (!result || !result.success) {
                    showNotification(
                        result?.message ||
                        "Could not enable Google Authenticator.",
                        "error"
                    );

                    return;
                }

                clearTwoFactorSetupTimer();

                const replacementCompleted =
                    twoFactorSetupMode ===
                    "replace";

                showNotification(
                    result.message ||
                    (
                        replacementCompleted
                            ? "Google Authenticator replaced successfully."
                            : "Google Authenticator enabled successfully."
                    ),
                    "success"
                );

                const codes =
                    result.data?.recoveryCodes ||
                    [];

                if (replacementCompleted) {
                    logoutAfterRecoveryCodes =
                        true;

                    if (codes.length) {
                        renderRecoveryCodes(
                            codes
                        );
                    } else {
                        localStorage.removeItem(
                            "token"
                        );

                        localStorage.removeItem(
                            "userId"
                        );

                        window.location.href =
                            "/auth/login";
                    }

                    return;
                }

                await loadTwoFactorStatus();

                if (codes.length) {
                    renderRecoveryCodes(codes);
                }

            } catch (error) {
                showNotification(
                    error.message ||
                    "Could not enable Google Authenticator.",
                    "error"
                );

            } finally {
                confirmTwoFactorBtn.disabled =
                    false;

                confirmTwoFactorBtn.innerText =
                    "Verify and Enable";
            }
        }

        async function submitTwoFactorAction(
            event
        ) {
            event.preventDefault();

            const code =
                String(
                    twoFactorActionCode.value ||
                    ""
                ).trim();

            if (!code) {
                showNotification(
                    "Authentication code is required.",
                    "warning"
                );

                twoFactorActionCode.focus();
                return;
            }

            if (
                twoFactorActionMode ===
                "regenerate" &&
                !isValidSixDigitCode(code)
            ) {
                showNotification(
                    "Enter a valid 6-digit Google Authenticator code.",
                    "warning"
                );

                twoFactorActionCode.focus();
                return;
            }

            const originalText =
                twoFactorActionSubmitBtn.innerText;

            twoFactorActionSubmitBtn.disabled =
                true;

            twoFactorActionSubmitBtn.innerText =
                "Processing...";

            try {
                if (
                    twoFactorActionMode ===
                    "replace"
                ) {
                    const password =
                        twoFactorActionPassword.value;

                    if (!password) {
                        showNotification(
                            "Current password is required.",
                            "warning"
                        );

                        twoFactorActionPassword.focus();
                        return;
                    }

                    const result = await api(
                        "/api/security/two-factor/replace/start",
                        {
                            method: "POST",
                            body: JSON.stringify({
                                password: password,
                                code: code
                            })
                        }
                    );

                    if (
                        !result ||
                        !result.success
                    ) {
                        showNotification(
                            result?.message ||
                            "Could not start Google Authenticator replacement.",
                            "error"
                        );

                        return;
                    }

                    const data =
                        result.data || {};

                    if (
                        !isSafeQrCodeDataUrl(
                            data.qrCodeDataUrl
                        )
                    ) {
                        showNotification(
                            "The QR code returned by the server is invalid.",
                            "error"
                        );

                        return;
                    }

                    closeTwoFactorActionModal();

                    renderTwoFactorSetup(
                        data,
                        "replace"
                    );

                    showNotification(
                        result.message ||
                        "New Google Authenticator setup created.",
                        "success"
                    );

                    return;
                }

                if (
                    twoFactorActionMode ===
                    "disable"
                ) {
                    const password =
                        twoFactorActionPassword.value;

                    if (!password) {
                        showNotification(
                            "Current password is required.",
                            "warning"
                        );

                        twoFactorActionPassword.focus();
                        return;
                    }

                    const result = await api(
                        "/api/security/two-factor/disable",
                        {
                            method: "POST",
                            body: JSON.stringify({
                                password: password,
                                code: code
                            })
                        }
                    );

                    if (
                        !result ||
                        !result.success
                    ) {
                        showNotification(
                            result?.message ||
                            "Could not disable Google Authenticator.",
                            "error"
                        );

                        return;
                    }

                    closeTwoFactorActionModal();

                    showNotification(
                        result.message ||
                        "Google Authenticator disabled successfully.",
                        "success"
                    );

                    await loadTwoFactorStatus();

                    return;
                }

                const result = await api(
                    "/api/security/two-factor/recovery-codes/regenerate",
                    {
                        method: "POST",
                        body: JSON.stringify({
                            code: code
                        })
                    }
                );

                if (
                    !result ||
                    !result.success
                ) {
                    showNotification(
                        result?.message ||
                        "Could not generate new recovery codes.",
                        "error"
                    );

                    return;
                }

                closeTwoFactorActionModal();

                showNotification(
                    result.message ||
                    "New recovery codes generated successfully.",
                    "success"
                );

                await loadTwoFactorStatus();

                const codes =
                    result.data?.recoveryCodes ||
                    [];

                if (codes.length) {
                    renderRecoveryCodes(codes);
                }

            } catch (error) {
                showNotification(
                    error.message ||
                    "Could not complete the security operation.",
                    "error"
                );

            } finally {
                twoFactorActionSubmitBtn.disabled =
                    false;

                twoFactorActionSubmitBtn.innerText =
                    originalText;
            }
        }

        function isValidUsdtBep20Address(value) {
            const address = String(value || "").trim();

            return /^0x[a-fA-F0-9]{40}$/.test(address);
        }

        function updateWalletAddressState() {
            const address = walletAddressInput.value.trim();

            walletAddressCounter.innerText =
                `${address.length} / 42`;

            walletAddressInput.classList.remove(
                "profile-wallet-valid",
                "profile-wallet-invalid"
            );

            if (!address) {
                walletAddressValidationText.innerText =
                    "Enter a 42-character USDT BEP20 address.";

                return;
            }

            if (isValidUsdtBep20Address(address)) {
                walletAddressInput.classList.add(
                    "profile-wallet-valid"
                );

                walletAddressValidationText.innerText =
                    "Valid USDT BEP20 address format.";

                return;
            }

            walletAddressInput.classList.add(
                "profile-wallet-invalid"
            );

            walletAddressValidationText.innerText =
                "The address must start with 0x and contain 40 hexadecimal characters.";
        }

        // ---------------------
        // Load Profile
        // ---------------------
        async function loadProfile() {
            try {
                const result = await api("/api/profile");

                if (!result.success) {
                    profileMessage.innerText = result.message || "Could not load profile.";
                    profileMessage.style.display = "block";
                    return;
                }

                const data = result.data || {};

                const forcePasswordFromQuery =
                    new URLSearchParams(
                        window.location.search
                    ).get("forcePassword") === "1";

                const mustChangePassword =
                    data.mustChangePassword === true ||
                    forcePasswordFromQuery;

                forcedPasswordBanner.hidden =
                    !mustChangePassword;

                if (mustChangePassword) {
                    window.setTimeout(
                        function () {
                            changePasswordCard
                                .scrollIntoView({
                                    behavior:
                                        "smooth",
                                    block:
                                        "center"
                                });

                            currentPassword.focus();
                        },
                        250
                    );
                }

                if (
                    data.totpRecoveryLockedUntil
                ) {
                    const lockedUntil =
                        new Date(
                            data.totpRecoveryLockedUntil
                        );

                    if (
                        !Number.isNaN(
                            lockedUntil.getTime()
                        ) &&
                        lockedUntil.getTime() >
                        Date.now()
                    ) {
                        showNotification(
                            "Withdrawals are temporarily locked until " +
                            lockedUntil.toLocaleString("en-US") +
                            " after the approved security recovery.",
                            "warning",
                            "Security Lock",
                            8000
                        );
                    }
                }

                firstName.innerText = data.firstName || "-";
                lastName.innerText = data.lastName || "-";
                email.innerText = data.email || "-";
                referralCode.innerText = data.referralCode || "-";

                kycStatus.innerText = data.kycStatus || "-";
                kycStatus.className = `profile-status ${String(data.kycStatus || "").toLowerCase()}`;

                networkInput.value = "BEP20";

                if (data.walletAddress) {
                    walletAddressInput.value =
                        data.walletAddress.address || "";

                    const previousNetwork =
                        String(
                            data.walletAddress.network || ""
                        )
                        .trim()
                        .toUpperCase();

                    if (
                        previousNetwork &&
                        previousNetwork !== "BEP20" &&
                        previousNetwork !== "BSC"
                    ) {
                        showNotification(
                            "Your previous withdrawal network is no longer supported. Please enter a USDT address on the BNB Smart Chain (BEP20) network.",
                            "warning"
                        );
                    }
                }

                updateWalletAddressState();

                const kycDocs = data.kycDocuments || [];
                const nationalDoc = getBestKycDocument(kycDocs, "NationalId");
                const selfieDoc = getBestKycDocument(kycDocs, "Selfie");

                renderKycDocument(nationalDoc, {
                    group: nationalIdGroup,
                    input: nationalIdImage,
                    fileNameElement: nationalIdFileName,
                    statusElement: nationalIdStatus,
                    label: "National ID",
                    rejectReasonBox: nationalIdRejectReasonBox,
                    rejectReasonText: nationalIdRejectReasonText
                });

                renderKycDocument(selfieDoc, {
                    group: selfieGroup,
                    input: selfieImage,
                    fileNameElement: selfieFileName,
                    statusElement: selfieStatus,
                    label: "Selfie",
                    rejectReasonBox: selfieRejectReasonBox,
                    rejectReasonText: selfieRejectReasonText
                });

                updateKycSubmitButton(data, nationalDoc, selfieDoc);

                profileMessage.style.display = "none";
                profileContent.style.display = "grid";

            } catch (error) {
                profileMessage.innerText = error.message || "Could not load profile.";
                profileMessage.style.display = "block";
            }
        }

        // ---------------------
        // Google Authenticator Events
        // ---------------------
        startTwoFactorSetupBtn.addEventListener(
            "click",
            function () {
                createTwoFactorSetup(
                    startTwoFactorSetupBtn
                );
            }
        );

        restartTwoFactorSetupBtn.addEventListener(
            "click",
            function () {
                createTwoFactorSetup(
                    restartTwoFactorSetupBtn
                );
            }
        );

        cancelTwoFactorSetupBtn.addEventListener(
            "click",
            async function () {
                clearTwoFactorSetupTimer();

                twoFactorQrImage.removeAttribute(
                    "src"
                );

                twoFactorSetupCode.value =
                    "";

                twoFactorSetupMode =
                    "enable";

                await loadTwoFactorStatus();
            }
        );

        copyTwoFactorKeyBtn.addEventListener(
            "click",
            function () {
                copyTextToClipboard(
                    twoFactorManualKey.innerText,
                    "Manual setup key copied."
                );
            }
        );

        twoFactorSetupCode.addEventListener(
            "input",
            sanitizeTwoFactorSetupCode
        );

        twoFactorSetupCode.addEventListener(
            "keydown",
            function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    enableTwoFactor();
                }
            }
        );

        confirmTwoFactorBtn.addEventListener(
            "click",
            enableTwoFactor
        );

        regenerateRecoveryCodesBtn.addEventListener(
            "click",
            async function () {
                const confirmed =
                    await showConfirm(
                        "Generating new recovery codes will permanently invalidate every existing recovery code.",
                        "Generate New Recovery Codes"
                    );

                if (!confirmed) {
                    return;
                }

                openTwoFactorActionModal(
                    "regenerate"
                );
            }
        );

        replaceTwoFactorBtn.addEventListener(
            "click",
            async function () {
                const confirmed =
                    await showConfirm(
                        "A new authenticator will be prepared. The current authenticator stays active until you confirm the new QR code.",
                        "Replace Google Authenticator"
                    );

                if (!confirmed) {
                    return;
                }

                openTwoFactorActionModal(
                    "replace"
                );
            }
        );

        disableTwoFactorBtn.addEventListener(
            "click",
            async function () {
                const confirmed =
                    await showConfirm(
                        "Disabling Google Authenticator will remove the extra protection from login and withdrawal.",
                        "Disable Google Authenticator"
                    );

                if (!confirmed) {
                    return;
                }

                openTwoFactorActionModal(
                    "disable"
                );
            }
        );

        document
            .querySelectorAll(
                "[data-close-two-factor-action]"
            )
            .forEach(element => {
                element.addEventListener(
                    "click",
                    closeTwoFactorActionModal
                );
            });

        twoFactorActionForm.addEventListener(
            "submit",
            submitTwoFactorAction
        );

        twoFactorActionCode.addEventListener(
            "input",
            function () {
                if (
                    twoFactorActionMode !==
                    "regenerate"
                ) {
                    twoFactorActionCode.value =
                        String(
                            twoFactorActionCode.value ||
                            ""
                        )
                        .replace(/\s+/g, "")
                        .slice(0, 14);

                    return;
                }

                twoFactorActionCode.value =
                    normalizeSixDigitCode(
                        twoFactorActionCode.value
                    );
            }
        );

        recoveryCodesSavedCheck.addEventListener(
            "change",
            function () {
                closeRecoveryCodesBtn.disabled =
                    !recoveryCodesSavedCheck.checked;
            }
        );

        copyRecoveryCodesBtn.addEventListener(
            "click",
            function () {
                copyTextToClipboard(
                    currentRecoveryCodes.join(
                        "\n"
                    ),
                    "Recovery codes copied."
                );
            }
        );

        downloadRecoveryCodesBtn.addEventListener(
            "click",
            downloadRecoveryCodes
        );

        closeRecoveryCodesBtn.addEventListener(
            "click",
            closeRecoveryCodesModal
        );

        document.addEventListener(
            "keydown",
            function (event) {
                if (
                    event.key === "Escape" &&
                    !twoFactorActionModal.hidden
                ) {
                    closeTwoFactorActionModal();
                }
            }
        );

        // ---------------------
        // USDT BEP20 Wallet Address
        // ---------------------
        walletAddressForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            const network = "BEP20";
            const address = walletAddressInput.value.trim();

            if (!address) {
                showNotification(
                    "Please enter your USDT BEP20 withdrawal address.",
                    "warning"
                );

                walletAddressInput.focus();
                return;
            }

            if (!isValidUsdtBep20Address(address)) {
                showNotification(
                    "Please enter a valid USDT BEP20 address starting with 0x.",
                    "warning"
                );

                walletAddressInput.focus();
                return;
            }

            saveWalletBtn.disabled = true;
            saveWalletBtn.innerText = "Saving...";

            try {
                const result = await api(
                    "/api/wallet/address/save",
                    {
                        method: "POST",
                        body: JSON.stringify({
                            network: network,
                            address: address
                        })
                    }
                );

                if (!result.success) {
                    showNotification(
                        result.message ||
                        "Could not save the USDT BEP20 address.",
                        "error"
                    );

                    return;
                }

                showNotification(
                    result.message ||
                    "USDT BEP20 withdrawal address saved successfully.",
                    "success"
                );

                networkInput.value = "BEP20";
                updateWalletAddressState();

            } catch (error) {
                showNotification(
                    error.message ||
                    "Could not save the USDT BEP20 address.",
                    "error"
                );

            } finally {
                saveWalletBtn.disabled = false;
                saveWalletBtn.innerText =
                    "Save USDT BEP20 Address";
            }
        });

        walletAddressInput.addEventListener(
            "input",
            function () {
                const cleaned =
                    walletAddressInput.value
                        .replace(/\s+/g, "");

                if (walletAddressInput.value !== cleaned) {
                    walletAddressInput.value = cleaned;
                }

                updateWalletAddressState();
            }
        );

        clearWalletAddressBtn.addEventListener(
            "click",
            function () {
                walletAddressInput.value = "";

                updateWalletAddressState();
                walletAddressInput.focus();
            }
        );

        // ---------------------
        // KYC Upload
        // ---------------------
        kycForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            hideAlert(kycMessage);

            const formData = new FormData();

            if (!nationalIdImage.disabled && nationalIdImage.files[0]) {
                formData.append("NationalIdImage", nationalIdImage.files[0]);
            }

            if (!selfieImage.disabled && selfieImage.files[0]) {
                formData.append("SelfieImage", selfieImage.files[0]);
            }

            if (formData.keys().next().done) {
                showAlert(kycMessage, "Please upload at least one document.", false);
                return;
            }

            submitKycBtn.disabled = true;
            submitKycBtn.innerText = "Submitting...";

            try {
                const result = await api("/api/kyc/upload", {
                    method: "POST",
                    body: formData
                });

                if (!result.success) {
                    showAlert(kycMessage, result.message || "Could not submit KYC.", false);
                    return;
                }

                showAlert(kycMessage, result.message || "KYC submitted successfully.", true);

                clearFileInput(nationalIdImage, nationalIdFileName);
                clearFileInput(selfieImage, selfieFileName);

                await loadProfile();

            } catch (error) {
                showAlert(kycMessage, error.message || "Could not submit KYC.", false);
            } finally {
                submitKycBtn.disabled = false;
                submitKycBtn.innerText = "Submit KYC";
            }
        });

        // ---------------------
        // Change Password
        // ---------------------
        passwordForm.addEventListener("submit", async function (e) {
            e.preventDefault();

            const current = currentPassword.value.trim();
            const next = newPassword.value.trim();

            if (!current || !next) {
                showAlert(passwordMessage, "Please enter current and new password.", false);
                return;
            }

            if (next.length < 6) {
                showAlert(passwordMessage, "New password must be at least 6 characters.", false);
                return;
            }

            changePasswordBtn.disabled = true;
            changePasswordBtn.innerText = "Changing...";

            try {
                const result = await api("/api/profile/change-password", {
                    method: "POST",
                    body: JSON.stringify({
                        currentPassword: current,
                        newPassword: next
                    })
                });

                if (!result.success) {
                    showAlert(passwordMessage, result.message || "Could not change password.", false);
                    return;
                }

                showAlert(passwordMessage, result.message || "Password changed successfully.", true);

                currentPassword.value = "";
                newPassword.value = "";

                forcedPasswordBanner.hidden =
                    true;

                if (
                    new URLSearchParams(
                        window.location.search
                    ).get("forcePassword") === "1"
                ) {
                    window.history.replaceState(
                        {},
                        "",
                        "/profile"
                    );
                }

                showNotification(
                    "Your password was changed. Normal account access has been restored.",
                    "success"
                );

            } catch (error) {
                showAlert(passwordMessage, error.message || "Could not change password.", false);
            } finally {
                changePasswordBtn.disabled = false;
                changePasswordBtn.innerText = "Change Password";
            }
        });
                function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);

            const isHidden = input.type === "password";

            input.type = isHidden ? "text" : "password";

            btn.classList.toggle("is-visible", isHidden);

            btn.setAttribute(
                "aria-label",
                isHidden ? "Hide password" : "Show password"
            );
        }
        // ---------------------
        // Init
        // ---------------------
        setupFileNamePreview(nationalIdImage, nationalIdFileName);
        setupFileNamePreview(selfieImage, selfieFileName);

        networkInput.value = "BEP20";
        updateWalletAddressState();

        setSubmitKycVisible(false);

        loadProfile();
        loadTwoFactorStatus();
    </script>
}   