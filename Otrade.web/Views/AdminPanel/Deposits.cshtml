@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pending Deposits";
}

<div class="admin-page">

    <div class="panel-card">
        <div class="admin-section-header">
            <h3>Pending Deposits</h3>
            <p>
                Review pending deposit requests. You can correct the final approved amount before crediting the user's Main Wallet.
            </p>
        </div>

        <div id="depositsMessage" class="admin-message">
            Loading pending deposits...
        </div>

        <div id="depositsTableWrapper" class="admin-table-wrapper" style="display:none;">
            <table class="admin-table admin-deposits-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Requested Amount</th>
                        <th>Tx Hash</th>
                        <th>Network</th>
                        <th>Created At</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody id="depositsTableBody"></tbody>
            </table>
        </div>
    </div>

</div>

<div class="admin-modal-backdrop" id="approveDepositModal" style="display:none;">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <div>
                <h4>Approve Deposit</h4>
                <p>
                    Enter the final approved amount. This amount will be credited to the user's Main Wallet.
                </p>
            </div>

            <button type="button"
                    class="admin-modal-close"
                    onclick="closeApproveDepositModal()">
                ×
            </button>
        </div>

        <div class="admin-modal-body">
            <input type="hidden" id="approveDepositId" />

            <div class="admin-deposit-summary">
                <div>
                    <span>User</span>
                    <strong id="approveDepositUser">-</strong>
                </div>

                <div>
                    <span>Requested Amount</span>
                    <strong id="approveRequestedAmount">0.00 USDT</strong>
                </div>
            </div>

            <div class="admin-modal-info admin-tx-modal-info">
                <span>Tx Hash</span>
                <strong id="approveDepositTx">-</strong>
            </div>
            <div class="admin-modal-info admin-tx-modal-info">
                <span>Network / Site Wallet</span>
                <strong id="approveDepositNetworkWallet">-</strong>
            </div>
            <label class="admin-modal-label" for="approvedAmountInput">
                Approved Amount
            </label>

            <input id="approvedAmountInput"
                   class="panel-input"
                   type="number"
                   min="0"
                   step="0.00000001"
                   placeholder="Enter final approved amount" />

            <small class="admin-modal-help">
                Important: approved deposit amount is credited to Main Wallet, not Invest Wallet.
            </small>
        </div>

        <div class="admin-modal-actions">
            <button type="button"
                    class="admin-secondary-btn"
                    onclick="closeApproveDepositModal()">
                Cancel
            </button>

            <button type="button"
                    class="admin-action-btn approve"
                    id="confirmApproveDepositBtn"
                    onclick="confirmApproveDeposit()">
                Approve & Credit Main Wallet
            </button>
        </div>
    </div>
</div>

<div class="admin-modal-backdrop" id="rejectDepositModal" style="display:none;">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <div>
                <h4>Reject Deposit</h4>
                <p>
                    Enter the rejection reason. The reason will be stored and sent to the user.
                </p>
            </div>

            <button type="button"
                    class="admin-modal-close"
                    onclick="closeRejectDepositModal()">
                ×
            </button>
        </div>

        <div class="admin-modal-body">
            <input type="hidden" id="rejectDepositId" />

            <div class="admin-deposit-summary">
                <div>
                    <span>User</span>
                    <strong id="rejectDepositUser">-</strong>
                </div>

                <div>
                    <span>Requested Amount</span>
                    <strong id="rejectRequestedAmount">0.00 USDT</strong>
                </div>
            </div>

            <label class="admin-modal-label" for="rejectDepositReason">
                Reject Reason
            </label>

            <textarea id="rejectDepositReason"
                      class="admin-modal-textarea"
                      maxlength="1000"
                      placeholder="Explain why this deposit is rejected..."></textarea>

            <small class="admin-modal-help">
                This note will be visible in admin records and sent by email to the user.
            </small>
        </div>

        <div class="admin-modal-actions">
            <button type="button"
                    class="admin-secondary-btn"
                    onclick="closeRejectDepositModal()">
                Cancel
            </button>

            <button type="button"
                    class="admin-action-btn reject"
                    id="confirmRejectDepositBtn"
                    onclick="confirmRejectDeposit()">
                Reject Deposit
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const depositsMessage = document.getElementById("depositsMessage");
        const depositsTableWrapper = document.getElementById("depositsTableWrapper");
        const depositsTableBody = document.getElementById("depositsTableBody");

        const approveDepositModal = document.getElementById("approveDepositModal");
        const rejectDepositModal = document.getElementById("rejectDepositModal");

        const approveDepositId = document.getElementById("approveDepositId");
        const approveDepositUser = document.getElementById("approveDepositUser");
        const approveRequestedAmount = document.getElementById("approveRequestedAmount");
        const approveDepositTx = document.getElementById("approveDepositTx");
        const approvedAmountInput = document.getElementById("approvedAmountInput");
        const confirmApproveDepositBtn = document.getElementById("confirmApproveDepositBtn");

        const rejectDepositId = document.getElementById("rejectDepositId");
        const rejectDepositUser = document.getElementById("rejectDepositUser");
        const rejectRequestedAmount = document.getElementById("rejectRequestedAmount");
        const rejectDepositReason = document.getElementById("rejectDepositReason");
        const confirmRejectDepositBtn = document.getElementById("confirmRejectDepositBtn");
        const approveDepositNetworkWallet = document.getElementById("approveDepositNetworkWallet");
        let depositsCache = [];

        async function loadPendingDeposits() {
            depositsMessage.style.display = "block";
            depositsMessage.innerText = "Loading pending deposits...";
            depositsTableWrapper.style.display = "none";
            depositsTableBody.innerHTML = "";

            try {
                const result = await api("/api/admin/deposits/pending");

                if (!result || !result.success) {
                    depositsMessage.innerText = result?.message || "Could not load pending deposits.";
                    return;
                }

                depositsCache = result.data || [];

                if (!depositsCache.length) {
                    depositsMessage.innerText = "No pending deposits found.";
                    return;
                }

                depositsCache.forEach(deposit => {
                    const row = document.createElement("tr");

                    row.innerHTML = `
                        <td>
                            <div class="admin-user-cell">
                                <strong>${escapeHtml(deposit.userUid || "-")}</strong>
                                <span>${escapeHtml(deposit.email || "-")}</span>
                                ${
                                    deposit.userFullName
                                        ? `<small>${escapeHtml(deposit.userFullName)}</small>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td>
                            <span class="admin-amount-cell">
                                ${formatMoney(deposit.amount)}
                            </span>
                        </td>

                        <td>
                            <div class="admin-tx-full-cell">
                                <span title="${escapeHtml(deposit.txId || "")}">
                                    ${escapeHtml(deposit.txId || "-")}
                                </span>

                                ${
                                    deposit.txId
                                        ? `<button type="button" onclick="copyAdminText('${escapeForJs(deposit.txId)}')">Copy</button>`
                                        : ""
                                }
                            </div>
                        </td>
                                <td>
                                    <span class="admin-status approved">
                                        ${escapeHtml(deposit.network || "-")}
                                    </span>
                                </td>
                        <td>${formatDate(deposit.createdAt)}</td>

                        <td class="text-end">
                            <div class="admin-row-actions">
                                <button class="admin-action-btn approve"
                                        onclick="openApproveDepositModal(${deposit.depositId})">
                                    Approve
                                </button>

                                <button class="admin-action-btn reject"
                                        onclick="openRejectDepositModal(${deposit.depositId})">
                                    Reject
                                </button>
                            </div>
                        </td>
                    `;

                    depositsTableBody.appendChild(row);
                });

                depositsMessage.style.display = "none";
                depositsTableWrapper.style.display = "block";

            } catch (error) {
                depositsMessage.innerText = error.message || "Could not load pending deposits.";
            }
        }

        function openApproveDepositModal(depositId) {
            const deposit = depositsCache.find(x => x.depositId === depositId);

            if (!deposit) {
                showNotification("Deposit not found.", "error");
                return;
            }

            approveDepositId.value = deposit.depositId;

            approveDepositUser.innerText =
                `${deposit.userUid || "-"} / ${deposit.email || "-"}`;

            approveRequestedAmount.innerText =
                formatMoney(deposit.amount);

            approveDepositTx.innerText =
                deposit.txId || "-";
            approveDepositNetworkWallet.innerText =
            `${deposit.network || "-"} / ${deposit.siteWalletAddress || "-"}`;
            approvedAmountInput.value =
                Number(deposit.amount || 0);

            approveDepositModal.style.display = "flex";

            setTimeout(() => {
                approvedAmountInput.focus();
                approvedAmountInput.select();
            }, 100);
        }

        function closeApproveDepositModal() {
            approveDepositModal.style.display = "none";

            approveDepositId.value = "";
            approveDepositUser.innerText = "-";
            approveRequestedAmount.innerText = "0.00 USDT";
            approveDepositTx.innerText = "-";
            approveDepositNetworkWallet.innerText = "-";
            approvedAmountInput.value = "";
        }

        async function confirmApproveDeposit() {
            const depositId = Number(approveDepositId.value);
            const approvedAmount = Number(approvedAmountInput.value || 0);

            if (!depositId) {
                showNotification("Deposit was not selected.", "error");
                return;
            }

            if (!approvedAmount || approvedAmount <= 0) {
                showNotification("Approved amount must be greater than zero.", "error");
                return;
            }

            const confirmed = await showConfirm(
                `Approve this deposit and credit ${formatMoney(approvedAmount)} to user's Main Wallet?`,
                "Approve Deposit"
            );

            if (!confirmed) {
                return;
            }

            confirmApproveDepositBtn.disabled = true;
            confirmApproveDepositBtn.innerText = "Approving...";

            try {
                const result = await api(`/api/admin/deposits/approve/${depositId}`, {
                    method: "POST",
                    body: JSON.stringify({
                        approvedAmount
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not approve deposit.", "error");
                    return;
                }

                showNotification(result.message || "Deposit approved successfully.", "success");

                closeApproveDepositModal();
                await loadPendingDeposits();

            } catch (error) {
                showNotification(error.message || "Could not approve deposit.", "error");
            } finally {
                confirmApproveDepositBtn.disabled = false;
                confirmApproveDepositBtn.innerText = "Approve & Credit Main Wallet";
            }
        }

        function openRejectDepositModal(depositId) {
            const deposit = depositsCache.find(x => x.depositId === depositId);

            if (!deposit) {
                showNotification("Deposit not found.", "error");
                return;
            }

            rejectDepositId.value = deposit.depositId;

            rejectDepositUser.innerText =
                `${deposit.userUid || "-"} / ${deposit.email || "-"}`;

            rejectRequestedAmount.innerText =
                formatMoney(deposit.amount);

            rejectDepositReason.value = "";

            rejectDepositModal.style.display = "flex";

            setTimeout(() => {
                rejectDepositReason.focus();
            }, 100);
        }

        function closeRejectDepositModal() {
            rejectDepositModal.style.display = "none";

            rejectDepositId.value = "";
            rejectDepositUser.innerText = "-";
            rejectRequestedAmount.innerText = "0.00 USDT";
            rejectDepositReason.value = "";
        }

        async function confirmRejectDeposit() {
            const depositId = Number(rejectDepositId.value);
            const reason = rejectDepositReason.value.trim();

            if (!depositId) {
                showNotification("Deposit was not selected.", "error");
                return;
            }

            if (!reason) {
                showNotification("Reject reason is required.", "error");
                return;
            }

            if (reason.length > 1000) {
                showNotification("Reject reason cannot be more than 1000 characters.", "error");
                return;
            }

            const confirmed = await showConfirm(
                "Reject this deposit request?",
                "Reject Deposit"
            );

            if (!confirmed) {
                return;
            }

            confirmRejectDepositBtn.disabled = true;
            confirmRejectDepositBtn.innerText = "Rejecting...";

            try {
                const result = await api(`/api/admin/deposits/reject/${depositId}`, {
                    method: "POST",
                    body: JSON.stringify({
                        reason
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not reject deposit.", "error");
                    return;
                }

                showNotification(result.message || "Deposit rejected successfully.", "success");

                closeRejectDepositModal();
                await loadPendingDeposits();

            } catch (error) {
                showNotification(error.message || "Could not reject deposit.", "error");
            } finally {
                confirmRejectDepositBtn.disabled = false;
                confirmRejectDepositBtn.innerText = "Reject Deposit";
            }
        }

        async function copyAdminText(text) {
            if (!text) {
                showNotification("Nothing to copy.", "warning");
                return;
            }

            try {
                await navigator.clipboard.writeText(text);
                showNotification("Copied to clipboard.", "success");
            } catch {
                const textarea = document.createElement("textarea");
                textarea.value = text;
                textarea.style.position = "fixed";
                textarea.style.opacity = "0";

                document.body.appendChild(textarea);
                textarea.focus();
                textarea.select();

                document.execCommand("copy");
                document.body.removeChild(textarea);

                showNotification("Copied to clipboard.", "success");
            }
        }

        function formatMoney(value) {
            const number = Number(value || 0);

            return number.toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }) + " USDT";
        }

        function formatDate(value) {
            if (!value) return "-";

            return new Date(value).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit"
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function escapeForJs(value) {
            return String(value || "")
                .replaceAll("\\", "\\\\")
                .replaceAll("'", "\\'")
                .replaceAll('"', '\\"')
                .replaceAll("\n", "")
                .replaceAll("\r", "");
        }

        approveDepositModal.addEventListener("click", function (e) {
            if (e.target === approveDepositModal) {
                closeApproveDepositModal();
            }
        });

        rejectDepositModal.addEventListener("click", function (e) {
            if (e.target === rejectDepositModal) {
                closeRejectDepositModal();
            }
        });

        loadPendingDeposits();
    </script>
}