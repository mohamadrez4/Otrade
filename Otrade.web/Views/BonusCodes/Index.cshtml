@{
    ViewData["Title"] = "Bonus Codes";
}

<div class="bonus-user-page">

    <div class="panel-card bonus-apply-card">
        <div class="bonus-user-header">
            <div>
                <h3>Apply Bonus Code</h3>
                <p>
                    Enter your bonus code to activate available capital bonus, rank bonus, or campaign rewards.
                </p>
            </div>
        </div>

        <form id="applyBonusCodeForm" class="bonus-apply-form">

            <div class="bonus-code-input-wrap">
                <label for="bonusCodeInput">Bonus Code</label>

                <input id="bonusCodeInput"
                       class="panel-input bonus-user-input"
                       type="text"
                       maxlength="50"
                       autocomplete="off"
                       placeholder="Example: WELCOME10"
                       required />
            </div>

            <button id="applyBonusCodeBtn"
                    type="submit"
                    class="panel-primary-btn bonus-apply-btn">
                Apply Code
            </button>

        </form>

        <div class="bonus-user-note">
            <strong>Note:</strong>
            Bonus capital is calculated based on your current Invest Wallet balance at the time you apply the code.
        </div>
    </div>

    <div class="panel-card mt-4">
        <div class="bonus-user-header">
            <div>
                <h3>My Bonus History</h3>
                <p>
                    Review your applied bonus codes, bonus capital, applied rank, and status.
                </p>
            </div>
        </div>

        <div id="myBonusMessage" class="bonus-user-message">
            Loading bonus history...
        </div>

        <div id="myBonusTableWrapper" class="bonus-user-table-wrapper" style="display:none;">
            <table class="bonus-user-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Campaign</th>
                        <th>Real Capital</th>
                        <th>Bonus Capital</th>
                        <th>Applied Rank</th>
                        <th>Status</th>
                        <th>Applied At</th>
                        <th>Expires At</th>
                        <th>Closed At</th>
                    </tr>
                </thead>

                <tbody id="myBonusTableBody"></tbody>
            </table>
        </div>

        <div id="myBonusPagination" class="bonus-user-pagination" style="display:none;">
            <button id="myBonusPrevBtn"
                    class="bonus-user-page-btn"
                    type="button">
                Previous
            </button>

            <span id="myBonusPageInfo"></span>

            <button id="myBonusNextBtn"
                    class="bonus-user-page-btn"
                    type="button">
                Next
            </button>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const applyBonusCodeForm = document.getElementById("applyBonusCodeForm");
        const bonusCodeInput = document.getElementById("bonusCodeInput");
        const applyBonusCodeBtn = document.getElementById("applyBonusCodeBtn");

        const myBonusMessage = document.getElementById("myBonusMessage");
        const myBonusTableWrapper = document.getElementById("myBonusTableWrapper");
        const myBonusTableBody = document.getElementById("myBonusTableBody");

        const myBonusPagination = document.getElementById("myBonusPagination");
        const myBonusPrevBtn = document.getElementById("myBonusPrevBtn");
        const myBonusNextBtn = document.getElementById("myBonusNextBtn");
        const myBonusPageInfo = document.getElementById("myBonusPageInfo");

        let myBonusCurrentPage = 1;
        const myBonusPageSize = 20;
        let myBonusTotalPages = 1;

        applyBonusCodeForm.addEventListener("submit", applyBonusCode);

        bonusCodeInput.addEventListener("input", function () {
            this.value = this.value.toUpperCase();
        });

        myBonusPrevBtn.addEventListener("click", async function () {
            if (myBonusCurrentPage <= 1) {
                return;
            }

            myBonusCurrentPage--;
            await loadMyBonusUsages();
        });

        myBonusNextBtn.addEventListener("click", async function () {
            if (myBonusCurrentPage >= myBonusTotalPages) {
                return;
            }

            myBonusCurrentPage++;
            await loadMyBonusUsages();
        });

        async function applyBonusCode(e) {
            e.preventDefault();

            const code = bonusCodeInput.value.trim().toUpperCase();

            if (!code) {
                showNotification("Please enter a bonus code.", "warning");
                return;
            }

            const confirmed = await showConfirm(
                `Apply bonus code ${code}?`,
                "Apply Bonus Code"
            );

            if (!confirmed) {
                return;
            }

            applyBonusCodeBtn.disabled = true;
            applyBonusCodeBtn.innerText = "Applying...";

            try {
                const result = await api("/api/bonus-codes/apply", {
                    method: "POST",
                    body: JSON.stringify({
                        code: code
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not apply bonus code.", "error");
                    return;
                }

                showNotification(
                    result.message || "Bonus code applied successfully.",
                    "success"
                );

                bonusCodeInput.value = "";

                myBonusCurrentPage = 1;
                await loadMyBonusUsages();

            } catch (error) {
                showNotification(
                    error.message || "Could not apply bonus code.",
                    "error"
                );
            } finally {
                applyBonusCodeBtn.disabled = false;
                applyBonusCodeBtn.innerText = "Apply Code";
            }
        }

        async function loadMyBonusUsages() {
            myBonusMessage.style.display = "block";
            myBonusMessage.innerText = "Loading bonus history...";

            myBonusTableWrapper.style.display = "none";
            myBonusPagination.style.display = "none";
            myBonusTableBody.innerHTML = "";

            try {
                const url =
                    `/api/bonus-codes/my-usages?page=${myBonusCurrentPage}&pageSize=${myBonusPageSize}`;

                const result = await api(url);

                if (!result || !result.success) {
                    myBonusMessage.innerText =
                        result?.message || "Could not load bonus history.";
                    return;
                }

                const data = result.data || {};
                const items = data.items || [];

                myBonusCurrentPage = data.page || 1;
                myBonusTotalPages = data.totalPages || 1;

                if (!items.length) {
                    myBonusMessage.innerText = "No bonus records found.";
                    myBonusPagination.style.display = "none";
                    return;
                }

                renderMyBonusUsages(items);
                renderMyBonusPagination(data);

                myBonusMessage.style.display = "none";
                myBonusTableWrapper.style.display = "block";

            } catch (error) {
                myBonusMessage.innerText =
                    error.message || "Could not load bonus history.";
                myBonusPagination.style.display = "none";
            }
        }

        function renderMyBonusUsages(items) {
            myBonusTableBody.innerHTML = "";

            items.forEach(item => {
                const row = document.createElement("tr");
                const statusClass = String(item.status || "").toLowerCase();

                row.innerHTML = `
                    <td>
                        <span class="bonus-user-code-pill">
                            ${escapeHtml(item.code || "-")}
                        </span>
                    </td>

                    <td>
                        ${escapeHtml(item.campaignName || "-")}
                    </td>

                    <td>
                        ${formatMoney(item.realCapitalAmount)} USDT
                    </td>

                    <td>
                        <strong class="bonus-user-capital">
                            ${formatMoney(item.bonusCapitalAmount)} USDT
                        </strong>
                    </td>

                    <td>
                        ${escapeHtml(item.appliedRankName || "-")}
                    </td>

                    <td>
                        <span class="bonus-user-status ${escapeHtml(statusClass)}">
                            ${escapeHtml(item.status || "-")}
                        </span>

                        ${renderBonusAdminNote(item)}
                    </td>

                    <td>${formatDateTime(item.createdAt)}</td>

                    <td>${formatDateTime(item.expiresAt)}</td>

                    <td>${formatDateTime(item.completedAt)}</td>
                `;

                myBonusTableBody.appendChild(row);
            });
        }
        function renderBonusAdminNote(item) {
            const note = String(item.adminNote || "").trim();

            if (!note || note === "Applied by user") {
                return "";
            }

            return `
                <small class="bonus-user-admin-note">
                    ${escapeHtml(note)}
                </small>
            `;
        }
        function renderMyBonusPagination(data) {
            const totalCount = data.totalCount || 0;

            if (totalCount <= 0) {
                myBonusPagination.style.display = "none";
                return;
            }

            myBonusCurrentPage = data.page || 1;
            myBonusTotalPages = data.totalPages || 1;

            myBonusPagination.style.display = "flex";

            myBonusPageInfo.innerText =
                `Page ${myBonusCurrentPage} of ${myBonusTotalPages} - Total: ${totalCount}`;

            myBonusPrevBtn.disabled = myBonusCurrentPage <= 1;
            myBonusNextBtn.disabled = myBonusCurrentPage >= myBonusTotalPages;
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 8
            });
        }

        function formatDateTime(value) {
            if (!value) return "-";

            return new Date(value).toLocaleString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit",
                hour: "2-digit",
                minute: "2-digit"
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        loadMyBonusUsages();
    </script>
}