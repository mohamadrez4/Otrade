@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Forgot Password | Otrade</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png?v=1" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png?v=1" />
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/auth.css" rel="stylesheet" />
    <link href="~/css/common.css" rel="stylesheet" />
    <script src="~/js/common.js"></script>
</head>
<body class="auth-body">

    <div class="register-wrapper">

        <div class="register-card">

            <div class="logo-box text-center">
                <img src="~/images/logo.png" alt="Otrade Logo" />
                <span>Online Trading Room</span>
            </div>

            <div id="forgotStep">
                <h2>Forgot Password</h2>

                <p class="subtitle">
                    Enter your email address and we will send you a reset code.
                </p>

                <form id="forgotForm">
                    <div class="mb-4">
                        <label>Email</label>
                        <input type="email"
                               class="form-control auth-input"
                               id="forgotEmail"
                               placeholder="Enter your email" />
                    </div>

                    <button type="submit" class="btn login-btn w-100">
                        Send Reset Code
                    </button>
                </form>

                <div class="auth-footer">
                    Back to
                    <a href="/auth/login">Login</a>
                </div>
            </div>

            <div id="resetStep" style="display:none;">
                <h2>Reset Password</h2>

                <p class="subtitle">
                    Enter the reset code sent to your email.
                </p>

                <form id="resetForm">
                    <input type="hidden" id="resetEmail" />

                    <div class="otp-box mb-4">
                        <input type="text" maxlength="1" class="otp-input reset-otp" />
                        <input type="text" maxlength="1" class="otp-input reset-otp" />
                        <input type="text" maxlength="1" class="otp-input reset-otp" />
                        <input type="text" maxlength="1" class="otp-input reset-otp" />
                        <input type="text" maxlength="1" class="otp-input reset-otp" />
                        <input type="text" maxlength="1" class="otp-input reset-otp" />
                    </div>

                    <div class="mb-3">
                        <label>New Password</label>
                        <input type="password"
                               class="form-control auth-input"
                               id="newPassword"
                               placeholder="Enter new password" />
                    </div>

                    <div class="mb-4">
                        <label>Confirm Password</label>
                        <input type="password"
                               class="form-control auth-input"
                               id="confirmNewPassword"
                               placeholder="Confirm new password" />
                    </div>

                    <button type="submit" class="btn login-btn w-100">
                        Change Password
                    </button>
                </form>

                <div class="auth-footer">
                    Back to
                    <a href="/auth/login">Login</a>
                </div>
            </div>

        </div>

    </div>
   
    <script>
                const token =
            localStorage.getItem("token");

        if (token)
        {
            try
            {
                const payload =
                    JSON.parse(atob(token.split('.')[1]));

                if (payload.exp * 1000 > Date.now())
                {
                    window.location.href = "/dashboard";
                }
            }
            catch
            {
                localStorage.removeItem("token");
            }
        }
        document.getElementById("forgotForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const email = document.getElementById("forgotEmail").value;
            debugger
            const response = await fetch("/api/auth/forgot-password", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ email: email })
            });

            const result = await response.json();

            if (!result.success) {
                    showNotification(result.message,"error");
               
                return;
            }

            document.getElementById("resetEmail").value = email;
            document.getElementById("forgotStep").style.display = "none";
            document.getElementById("resetStep").style.display = "block";
        });

        document.getElementById("resetForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const password = document.getElementById("newPassword").value;
            const confirmPassword = document.getElementById("confirmNewPassword").value;

            if (password !== confirmPassword) {
                showNotification("Passwords do not match","error");
              
                return;
            }

            let code = "";
            document.querySelectorAll(".reset-otp").forEach(x => code += x.value);

            const payload = {
                email: document.getElementById("resetEmail").value,
                code: code,
                newPassword: password
            };

            const response = await fetch("/api/auth/change-password", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (!result.success) {
                showNotification(result.message,"error");
                
                return;
            }

            window.location.href = "/auth/login";
        });

        document.querySelectorAll(".reset-otp").forEach((input, index, inputs) => {
            input.addEventListener("input", () => {
                if (input.value.length === 1 && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
            });
        });
    </script>
    <div id="notificationContainer"
         class="notification-container">
    </div>
     
</body>
</html>