@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Users Management";
}

<div class="admin-page">

    <div class="panel-card">
        <div class="admin-section-header">
            <h3>Users</h3>
            <p>View and manage platform users, ranks, wallets, sponsors, referral codes, and KYC status.</p>
        </div>

        <div class="admin-filter-row">
            <input id="searchInput"
                   class="panel-input"
                   type="text"
                   placeholder="Search by email, name, referral code, or sponsor" />

            <button id="searchBtn" class="panel-primary-btn">
                Search
            </button>
        </div>

        <div id="usersMessage" class="admin-message">
            Loading users...
        </div>

        <div id="usersTableWrapper" class="admin-table-wrapper" style="display:none;">
            <table class="admin-table admin-users-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Referral Code</th>
                        <th>Full Name</th>
                        <th>Rank</th>
                        <th>KYC Status</th>
                        <th>Main Wallet</th>
                        <th>Invest Wallet</th>
                        <th>Profit Wallet</th>
                        <th>Referral Wallet</th>
                        <th>Sponsor</th>
                        <th>Admin Role</th>
                    </tr>
                </thead>

                <tbody id="usersTableBody"></tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const usersMessage = document.getElementById("usersMessage");
        const usersTableWrapper = document.getElementById("usersTableWrapper");
        const usersTableBody = document.getElementById("usersTableBody");
        const searchInput = document.getElementById("searchInput");
        const searchBtn = document.getElementById("searchBtn");

        let currentPage = 1;
        const pageSize = 20;

        searchBtn.addEventListener("click", function () {
            currentPage = 1;
            loadUsers();
        });

        searchInput.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                currentPage = 1;
                loadUsers();
            }
        });

        async function loadUsers() {
            usersMessage.style.display = "block";
            usersMessage.innerText = "Loading users...";
            usersTableWrapper.style.display = "none";
            usersTableBody.innerHTML = "";

            const search = searchInput.value.trim();

            let url = `/api/admin/users?page=${currentPage}&pageSize=${pageSize}`;

            if (search) {
                url += `&search=${encodeURIComponent(search)}`;
            }

            try {
                const result = await api(url);

                if (!result.success) {
                    usersMessage.innerText = result.message || "Could not load users.";
                    return;
                }

                const data = result.data || {};
                const items = data.items || [];

                if (!items.length) {
                    usersMessage.innerText = "No users found.";
                    return;
                }

                items.forEach(user => {
                    const row = document.createElement("tr");

                    row.innerHTML = `
                        <td>
                            <span class="admin-user-email">
                                ${escapeHtml(user.email || "-")}
                            </span>
                        </td>

                        <td>
                            <span class="admin-ref-code">
                                ${escapeHtml(user.referralCode || "-")}
                            </span>
                        </td>

                        <td>
                            ${escapeHtml(buildFullName(user))}
                        </td>

                        <td>
                            ${escapeHtml(user.currentRank?.name || "-")}
                        </td>

                        <td>
                            <span class="admin-kyc-status ${String(user.kycStatus || "").toLowerCase()}">
                                ${escapeHtml(user.kycStatus || "-")}
                            </span>
                        </td>

                        <td>${formatMoney(user.wallets?.main || 0)}</td>
                        <td>${formatMoney(user.wallets?.invest || 0)}</td>
                        <td>${formatMoney(user.wallets?.profit || 0)}</td>
                        <td>${formatMoney(user.wallets?.referral || 0)}</td>

           <td>
            <div class="admin-sponsor-cell">
                <strong>${escapeHtml(user.sponsorEmail || "-")}</strong>

                ${
                    user.sponsorFullName
                        ? `<span class="admin-sponsor-name">${escapeHtml(user.sponsorFullName)}</span>`
                        : ""
                }

                ${
                    user.sponsorReferralCode
                        ? `<span>UID: ${escapeHtml(user.sponsorReferralCode)}</span>`
                        : ""
                }
            </div>
        </td>
        <td>
            ${renderAdminRoleSelect(user)}
        </td>
                    `;

                    usersTableBody.appendChild(row);
                });

                usersMessage.style.display = "none";
                usersTableWrapper.style.display = "block";

            } catch (error) {
                usersMessage.innerText = error.message || "Could not load users.";
            }
        }
                function renderAdminRoleSelect(user) {
            if (user.isOwner) {
                return `
                    <span class="admin-role-badge owner">
                        Owner
                    </span>
                `;
            }

            const currentRole = user.adminRole || "User";

            return `
                <select class="admin-role-select"
                        onchange="updateAdminRole(${user.userId}, this.value)">
                    <option value="" ${currentRole === "User" ? "selected" : ""}>
                        User
                    </option>
                    <option value="SuperAdmin" ${currentRole === "SuperAdmin" ? "selected" : ""}>
                        SuperAdmin
                    </option>
                    <option value="Finance" ${currentRole === "Finance" ? "selected" : ""}>
                        Finance
                    </option>
                    <option value="Support" ${currentRole === "Support" ? "selected" : ""}>
                        Support
                    </option>
                    <option value="Backend" ${currentRole === "Backend" ? "selected" : ""}>
                        Backend
                    </option>
                </select>
            `;
        }
                async function updateAdminRole(userId, adminRole) {
            const confirmed = await showConfirm(
                "Are you sure you want to change this user's admin role?",
                "Change Admin Role"
            );

            if (!confirmed) {
                await loadUsers();
                return;
            }

            try {
                const result = await api(`/api/admin/users/${userId}/admin-role`, {
                    method: "POST",
                    body: JSON.stringify({
                        adminRole: adminRole || null
                    })
                });

                showNotification(
                    result.message || "Admin role updated successfully.",
                    "success"
                );

                await loadUsers();

            } catch (error) {
                showNotification(
                    error.message || "Could not update admin role.",
                    "error"
                );

                await loadUsers();
            }
        }
        function buildFullName(user) {
            const firstName = user.firstName || "";
            const lastName = user.lastName || "";
            const fullName = `${firstName} ${lastName}`.trim();

            return fullName || "-";
        }

        function formatMoney(value) {
            const number = Number(value || 0);

            return number.toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 8
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        loadUsers();
    </script>
}