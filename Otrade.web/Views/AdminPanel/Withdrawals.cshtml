@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pending Withdrawals";
}

<div class="admin-page">

    <div class="panel-card">
        <div class="admin-section-header">
            <h3>Pending Withdrawals</h3>
            <p>
                Review withdrawal requests that were confirmed by user email verification.
                Approving does not deduct wallet balance again; rejecting refunds the reserved amount.
            </p>
        </div>

        <div id="withdrawalsMessage" class="admin-message">
            Loading pending withdrawals...
        </div>

        <div id="withdrawalsTableWrapper" class="admin-table-wrapper" style="display:none;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Amount</th>
                        <th>Network</th>
                        <th>Wallet Address</th>
                        <th>Created At</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody id="withdrawalsTableBody"></tbody>
            </table>
        </div>
    </div>

</div>

<div id="rejectWithdrawalModal" class="admin-modal-backdrop" style="display:none;">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <div>
                <h4>Reject Withdrawal</h4>
                <p>Enter the reason for rejecting this withdrawal. The amount will be refunded to the user's Main Wallet.</p>
            </div>

            <button type="button"
                    class="admin-modal-close"
                    onclick="closeRejectWithdrawalModal()">
                ×
            </button>
        </div>

        <div class="admin-modal-body">
            <div class="admin-reject-summary">
                <div>
                    <span>User</span>
                    <strong id="rejectModalUser">-</strong>
                </div>

                <div>
                    <span>Amount</span>
                    <strong id="rejectModalAmount">-</strong>
                </div>
            </div>

            <label class="admin-modal-label" for="rejectWithdrawalReason">
                Reject Reason
            </label>

            <textarea id="rejectWithdrawalReason"
                      class="admin-modal-textarea"
                      maxlength="1000"
                      placeholder="Write the reject reason..."></textarea>

            <small class="admin-modal-help">
                This note will be visible to the user in withdrawal history.
            </small>
        </div>

        <div class="admin-modal-actions">
            <button type="button"
                    class="admin-secondary-btn"
                    onclick="closeRejectWithdrawalModal()">
                Cancel
            </button>

            <button type="button"
                    id="confirmRejectWithdrawalBtn"
                    class="admin-action-btn reject"
                    onclick="submitRejectWithdrawal()">
                Reject & Refund
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const withdrawalsMessage = document.getElementById("withdrawalsMessage");
        const withdrawalsTableWrapper = document.getElementById("withdrawalsTableWrapper");
        const withdrawalsTableBody = document.getElementById("withdrawalsTableBody");

        const rejectWithdrawalModal = document.getElementById("rejectWithdrawalModal");
        const rejectWithdrawalReason = document.getElementById("rejectWithdrawalReason");
        const rejectModalUser = document.getElementById("rejectModalUser");
        const rejectModalAmount = document.getElementById("rejectModalAmount");
        const confirmRejectWithdrawalBtn = document.getElementById("confirmRejectWithdrawalBtn");

        let selectedRejectWithdrawalId = null;
        let selectedRejectWithdrawal = null;

        async function loadPendingWithdrawals() {
            withdrawalsMessage.style.display = "block";
            withdrawalsMessage.innerText = "Loading pending withdrawals...";
            withdrawalsTableWrapper.style.display = "none";
            withdrawalsTableBody.innerHTML = "";

            try {
                const result = await api("/api/admin/withdrawals/pending");

                if (!result || !result.success) {
                    withdrawalsMessage.innerText = result?.message || "Could not load pending withdrawals.";
                    return;
                }

                const items = result.data || [];

                if (!items.length) {
                    withdrawalsMessage.innerText = "No pending withdrawals found.";
                    return;
                }

                items.forEach(item => {
                    const row = document.createElement("tr");

                    row.innerHTML = `
                        <td>
                            <div class="admin-user-cell">
                                <strong>${escapeHtml(item.userUid || "-")}</strong>
                                <span>${escapeHtml(item.userEmail || "-")}</span>
                                ${
                                    item.userFullName
                                        ? `<small>${escapeHtml(item.userFullName)}</small>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td>
                            <span class="admin-amount-cell">
                                ${formatMoney(item.amount)}
                            </span>
                        </td>

                        <td>
                            <span class="admin-status neutral">
                                ${escapeHtml(item.network || "-")}
                            </span>
                        </td>

                        <td>
                            <div class="admin-withdraw-address">
                                <span>${escapeHtml(item.walletAddress || "-")}</span>

                                <button type="button"
                                        onclick="copyText('${escapeJs(item.walletAddress || "")}')">
                                    Copy
                                </button>
                            </div>
                        </td>

                        <td>${formatDate(item.createdAt)}</td>

                        <td class="text-end">
                            <button class="admin-action-btn approve"
                                    onclick="approveWithdrawal(${item.withdrawalId})">
                                Approve
                            </button>

                            <button class="admin-action-btn reject"
                                    onclick='openRejectWithdrawalModal(${JSON.stringify(item)})'>
                                Reject
                            </button>
                        </td>
                    `;

                    withdrawalsTableBody.appendChild(row);
                });

                withdrawalsMessage.style.display = "none";
                withdrawalsTableWrapper.style.display = "block";

            } catch (error) {
                withdrawalsMessage.innerText = error.message || "Could not load pending withdrawals.";
            }
        }

        async function approveWithdrawal(withdrawalId) {
            const confirmed = await showConfirm(
                "Approve this withdrawal? This will only mark the request as approved. The amount has already been reserved after user email verification.",
                "Approve Withdrawal"
            );

            if (!confirmed) {
                return;
            }

            try {
                const result = await api(`/api/admin/withdrawals/approve/${withdrawalId}`, {
                    method: "POST"
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not approve withdrawal.", "error");
                    return;
                }

                showNotification(result.message || "Withdrawal approved.", "success");

                await loadPendingWithdrawals();

            } catch (error) {
                showNotification(error.message || "Could not approve withdrawal.", "error");
            }
        }

        function openRejectWithdrawalModal(item) {
            selectedRejectWithdrawalId = item.withdrawalId;
            selectedRejectWithdrawal = item;

            rejectWithdrawalReason.value = "";

            rejectModalUser.innerText =
                `${item.userUid || "-"} / ${item.userEmail || "-"}`;

            rejectModalAmount.innerText =
                formatMoney(item.amount);

            rejectWithdrawalModal.style.display = "flex";

            setTimeout(() => {
                rejectWithdrawalReason.focus();
            }, 100);
        }

        function closeRejectWithdrawalModal() {
            selectedRejectWithdrawalId = null;
            selectedRejectWithdrawal = null;

            rejectWithdrawalReason.value = "";
            rejectModalUser.innerText = "-";
            rejectModalAmount.innerText = "-";

            rejectWithdrawalModal.style.display = "none";
        }

        async function submitRejectWithdrawal() {
            if (!selectedRejectWithdrawalId) {
                showNotification("Withdrawal was not selected.", "error");
                return;
            }

            const reason = rejectWithdrawalReason.value.trim();

            if (!reason) {
                showNotification("Reject reason is required.", "warning");
                return;
            }

            if (reason.length > 1000) {
                showNotification("Reject reason cannot be more than 1000 characters.", "warning");
                return;
            }

            const confirmed = await showConfirm(
                "Reject this withdrawal and refund the amount to user's Main Wallet?",
                "Reject Withdrawal"
            );

            if (!confirmed) {
                return;
            }

            confirmRejectWithdrawalBtn.disabled = true;
            confirmRejectWithdrawalBtn.innerText = "Rejecting...";

            try {
                const result = await api(`/api/admin/withdrawals/reject/${selectedRejectWithdrawalId}`, {
                    method: "POST",
                    body: JSON.stringify({
                        reason: reason
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not reject withdrawal.", "error");
                    return;
                }

                showNotification(result.message || "Withdrawal rejected and refunded.", "success");

                closeRejectWithdrawalModal();

                await loadPendingWithdrawals();

            } catch (error) {
                showNotification(error.message || "Could not reject withdrawal.", "error");
            } finally {
                confirmRejectWithdrawalBtn.disabled = false;
                confirmRejectWithdrawalBtn.innerText = "Reject & Refund";
            }
        }

        async function copyText(value) {
            if (!value) {
                showNotification("Nothing to copy.", "warning");
                return;
            }

            try {
                await navigator.clipboard.writeText(value);
                showNotification("Copied.", "success");
            } catch {
                showNotification("Could not copy.", "error");
            }
        }

        function formatMoney(value) {
            const number = Number(value || 0);

            return number.toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }) + " USDT";
        }

        function formatDate(value) {
            if (!value) return "-";

            return new Date(value).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit"
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function escapeJs(value) {
            return String(value || "")
                .replaceAll("\\", "\\\\")
                .replaceAll("'", "\\'")
                .replaceAll('"', "&quot;");
        }

        rejectWithdrawalModal.addEventListener("click", function (e) {
            if (e.target === rejectWithdrawalModal) {
                closeRejectWithdrawalModal();
            }
        });

        loadPendingWithdrawals();
    </script>
}