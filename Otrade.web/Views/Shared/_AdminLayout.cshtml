<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] | Otrade Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/panel.css" rel="stylesheet" />
    <link href="~/css/admin.css" rel="stylesheet" />
    <link href="~/css/common.css" rel="stylesheet" />
    <link rel="icon" type="image/x-icon" href="~/favicon.ico?v=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png?v=1" />
    <link rel="apple-touch-icon" href="~/apple-touch-icon.png?v=1" />
    <script src="~/js/common.js"></script>
    <script src="~/js/auth.js"></script>
    <script>
        checkAuth();
    </script>
</head>
<body class="panel-body">

    <div class="panel-layout">

        <aside class="sidebar">
            <div class="sidebar-logo">
                <img src="~/images/logo.png" />
            </div>

            <nav class="sidebar-nav">

                <a href="/admin/dashboard" class="nav-item">
                    <span>Admin Dashboard</span>
                </a>

                <a href="/admin/deposits" class="nav-item">
                    <span>Deposits</span>
                </a>

                <a href="/admin/withdrawals" class="nav-item">
                    <span>Withdrawals</span>
                </a>

                <a href="/admin/kyc" class="nav-item">
                    <span>KYC</span>
                </a>

                <a href="/admin/tickets" class="nav-item">
                    <span>Tickets</span>
                </a>

                <a href="/admin/users" class="nav-item">
                    <span>Users</span>
                </a>

                <a href="/admin/reports" class="nav-item">
                    <span>Reports</span>
                </a>

                <a href="/admin/settings" class="nav-item">
                    <span>Settings</span>
                </a>

                <a href="/dashboard" class="nav-item">
                    <span>User Panel</span>
                </a>

                <a href="#" onclick="openHangfire(event)">Hangfire</a>
            </nav>

            <button class="logout-btn" onclick="logout()">Logout</button>
        </aside>

        <main class="panel-main">
            <header class="topbar">
                <div>
                    <h4>@ViewData["Title"]</h4>
                </div>
            </header>

            <section class="content">
                @RenderBody()
            </section>
        </main>

    </div>

    <script src="~/js/api.js"></script>
    <script>
        const currentPath = window.location.pathname.toLowerCase();

        document.querySelectorAll(".sidebar-nav a").forEach(link => {
            const href = link.getAttribute("href").toLowerCase();

            if (currentPath === href || currentPath.startsWith(href + "/")) {
                link.classList.add("active");
            }
        });
        async function openHangfire(e) {
            e.preventDefault();

            const token = localStorage.getItem("token");

            if (!token) {
                showNotification("Please login again.","error");
               
                return;
            }

            const res = await fetch("/admin/hangfire/session", {
                method: "POST",
                headers: {
                    "Authorization": "Bearer " + token
                },
                credentials: "include"
            });

            if (!res.ok) {
                showNotification("Access denied.","error");
                 
                return;
            }

            window.open("/hangfire", "_blank");
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>