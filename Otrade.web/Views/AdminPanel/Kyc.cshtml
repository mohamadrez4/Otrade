@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Pending KYC";
}

<div class="admin-page">

    <div class="panel-card">
        <div class="admin-section-header">
            <h3>Pending KYC Documents</h3>
            <p>
                Review user identity documents. Each document is approved or rejected individually.
                User KYC becomes approved only when both National ID and Selfie are approved.
            </p>
        </div>

        <div id="kycMessage" class="admin-message">
            Loading pending KYC documents...
        </div>

        <div id="kycTableWrapper" class="admin-table-wrapper" style="display:none;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Document Type</th>
                        <th>Status</th>
                        <th>Created At</th>
                        <th>View</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody id="kycTableBody"></tbody>
            </table>
        </div>
    </div>

</div>

<div class="admin-modal-backdrop" id="rejectKycModal" style="display:none;">
    <div class="admin-modal">
        <div class="admin-modal-header">
            <div>
                <h4>Reject KYC Document</h4>
                <p>
                    Enter the rejection reason. This reason will be saved and sent to the user.
                </p>
            </div>

            <button type="button"
                    class="admin-modal-close"
                    onclick="closeRejectKycModal()">
                ×
            </button>
        </div>

        <div class="admin-modal-body">
            <input type="hidden" id="rejectKycDocumentId" />

            <div class="admin-kyc-reject-summary">
                <div>
                    <span>User</span>
                    <strong id="rejectKycUser">-</strong>
                </div>

                <div>
                    <span>Document</span>
                    <strong id="rejectKycDocumentType">-</strong>
                </div>
            </div>

            <label class="admin-modal-label" for="rejectKycReason">
                Reject Reason
            </label>

            <textarea id="rejectKycReason"
                      class="admin-modal-textarea"
                      maxlength="1000"
                      placeholder="Explain why this document is rejected..."></textarea>

            <small class="admin-modal-help">
                The user will see this note in Profile and can upload the rejected document again.
            </small>
        </div>

        <div class="admin-modal-actions">
            <button type="button"
                    class="admin-secondary-btn"
                    onclick="closeRejectKycModal()">
                Cancel
            </button>

            <button type="button"
                    class="admin-action-btn reject"
                    id="confirmRejectKycBtn"
                    onclick="confirmRejectKyc()">
                Reject KYC
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const kycMessage = document.getElementById("kycMessage");
        const kycTableWrapper = document.getElementById("kycTableWrapper");
        const kycTableBody = document.getElementById("kycTableBody");

        const rejectKycModal = document.getElementById("rejectKycModal");
        const rejectKycDocumentId = document.getElementById("rejectKycDocumentId");
        const rejectKycReason = document.getElementById("rejectKycReason");
        const rejectKycUser = document.getElementById("rejectKycUser");
        const rejectKycDocumentType = document.getElementById("rejectKycDocumentType");
        const confirmRejectKycBtn = document.getElementById("confirmRejectKycBtn");

        let pendingKycCache = [];

        async function loadPendingKycs() {
            kycMessage.style.display = "block";
            kycMessage.innerText = "Loading pending KYC documents...";
            kycTableWrapper.style.display = "none";
            kycTableBody.innerHTML = "";

            try {
                const result = await api("/api/admin/kyc/pending");

                if (!result || !result.success) {
                    kycMessage.innerText = result?.message || "Could not load pending KYC documents.";
                    return;
                }

                pendingKycCache = result.data || [];

                if (!pendingKycCache.length) {
                    kycMessage.innerText = "No pending KYC documents.";
                    return;
                }

                pendingKycCache.forEach(doc => {
                    const row = document.createElement("tr");
                    const status = String(doc.status || "").toLowerCase();

                    row.innerHTML = `
                        <td>
                            <div class="admin-user-cell">
                                <strong>${escapeHtml(doc.userUid || "-")}</strong>
                                <span>${escapeHtml(doc.userEmail || "-")}</span>
                                ${
                                    doc.userFullName
                                        ? `<small>${escapeHtml(doc.userFullName)}</small>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td>
                            <span class="admin-status neutral">
                                ${escapeHtml(doc.documentType || "-")}
                            </span>
                        </td>

                        <td>
                            <span class="admin-status ${escapeHtml(status)}">
                                ${escapeHtml(doc.status || "-")}
                            </span>
                        </td>

                        <td>${formatDate(doc.createdAt)}</td>

                        <td>
                            <button class="admin-action-btn approve"
                                    onclick="viewKycFile(${doc.documentId})">
                                View
                            </button>
                        </td>

                        <td class="text-end">
                            <button class="admin-action-btn approve"
                                    onclick="approveKyc(${doc.documentId})">
                                Approve
                            </button>

                            <button class="admin-action-btn reject"
                                    onclick="openRejectKycModal(${doc.documentId})">
                                Reject
                            </button>
                        </td>
                    `;

                    kycTableBody.appendChild(row);
                });

                kycMessage.style.display = "none";
                kycTableWrapper.style.display = "block";

            } catch (error) {
                kycMessage.innerText = error.message || "Could not load pending KYC documents.";
            }
        }

        async function approveKyc(documentId) {
            const doc = pendingKycCache.find(x => x.documentId === documentId);

            const confirmed = await showConfirm(
                `Approve ${doc?.documentType || "this document"} for UID ${doc?.userUid || "-"}?`,
                "Approve KYC Document"
            );

            if (!confirmed) {
                return;
            }

            try {
                const result = await api(`/api/admin/kyc/document/${documentId}/approve`, {
                    method: "POST"
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not approve document.", "error");
                    return;
                }

                showNotification(result.message || "Document approved successfully.", "success");

                await loadPendingKycs();

            } catch (error) {
                showNotification(error.message || "Could not approve document.", "error");
            }
        }

        function openRejectKycModal(documentId) {
            const doc = pendingKycCache.find(x => x.documentId === documentId);

            if (!doc) {
                showNotification("Document not found.", "error");
                return;
            }

            rejectKycDocumentId.value = doc.documentId;
            rejectKycReason.value = "";

            rejectKycUser.innerText =
                `${doc.userUid || "-"} / ${doc.userEmail || "-"}`;

            rejectKycDocumentType.innerText =
                doc.documentType || "-";

            rejectKycModal.style.display = "flex";

            setTimeout(() => {
                rejectKycReason.focus();
            }, 100);
        }

        function closeRejectKycModal() {
            rejectKycModal.style.display = "none";

            rejectKycDocumentId.value = "";
            rejectKycReason.value = "";
            rejectKycUser.innerText = "-";
            rejectKycDocumentType.innerText = "-";
        }

        async function confirmRejectKyc() {
            const documentId = Number(rejectKycDocumentId.value);
            const reason = rejectKycReason.value.trim();

            if (!documentId) {
                showNotification("Document was not selected.", "error");
                return;
            }

            if (!reason) {
                showNotification("Reject reason is required.", "warning");
                return;
            }

            if (reason.length > 1000) {
                showNotification("Reject reason cannot be more than 1000 characters.", "warning");
                return;
            }

            const confirmed = await showConfirm(
                "Reject this KYC document and notify the user?",
                "Reject KYC Document"
            );

            if (!confirmed) {
                return;
            }

            confirmRejectKycBtn.disabled = true;
            confirmRejectKycBtn.innerText = "Rejecting...";

            try {
                const result = await api(`/api/admin/kyc/document/${documentId}/reject`, {
                    method: "POST",
                    body: JSON.stringify({
                        reason
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not reject document.", "error");
                    return;
                }

                showNotification(result.message || "Document rejected successfully.", "success");

                closeRejectKycModal();

                await loadPendingKycs();

            } catch (error) {
                showNotification(error.message || "Could not reject document.", "error");
            } finally {
                confirmRejectKycBtn.disabled = false;
                confirmRejectKycBtn.innerText = "Reject KYC";
            }
        }

        async function viewKycFile(documentId) {
            const token = localStorage.getItem("token");

            if (!token) {
                window.location.href = "/auth/login";
                return;
            }

            try {
                const response = await fetch(`/api/admin/kyc/document/${documentId}/file`, {
                    method: "GET",
                    headers: {
                        "Authorization": `Bearer ${token}`
                    }
                });

                if (response.status === 401 || response.status === 403) {
                    localStorage.removeItem("token");
                    window.location.href = "/auth/login";
                    return;
                }

                if (!response.ok) {
                    showNotification("Could not load document.", "error");
                    return;
                }

                const blob = await response.blob();
                const url = window.URL.createObjectURL(blob);

                window.open(url, "_blank");

                setTimeout(() => {
                    window.URL.revokeObjectURL(url);
                }, 60000);

            } catch {
                showNotification("Could not load document.", "error");
            }
        }

        function formatDate(value) {
            if (!value) return "-";

            return new Date(value).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit"
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        rejectKycModal.addEventListener("click", function (e) {
            if (e.target === rejectKycModal) {
                closeRejectKycModal();
            }
        });

        loadPendingKycs();
    </script>
}