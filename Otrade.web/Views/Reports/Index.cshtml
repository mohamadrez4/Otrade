@{
    ViewData["Title"] = "Reports";
}

<div class="reports-page">

    <div class="reports-grid">
        <div class="panel-card report-summary-card">
            <span>Total Deposits</span>
            <strong id="totalDeposits">$0.00</strong>
        </div>

        <div class="panel-card report-summary-card">
            <span>Total Withdrawals</span>
            <strong id="totalWithdrawals">$0.00</strong>
        </div>

        <div class="panel-card report-summary-card">
            <span>Total Profits</span>
            <strong id="totalProfits">$0.00</strong>
        </div>

        <div class="panel-card report-summary-card">
            <span>Total Bonuses</span>
            <strong id="totalBonuses">$0.00</strong>
        </div>
    </div>

    <div class="panel-card">
        <div class="reports-header">
            <div>
                <h3>User Reports</h3>
                <p>Review your deposits, withdrawals, transfers, profits, and bonuses.</p>
            </div>
        </div>

        <div class="reports-tabs">
            <button class="report-tab active" data-target="deposits">Deposits</button>
            <button class="report-tab" data-target="withdrawals">Withdrawals</button>
            <button class="report-tab" data-target="transfers">Transfers</button>
            <button class="report-tab" data-target="investmentProfits">Investment Profits</button>
            <button class="report-tab" data-target="referralProfits">Referral Profits</button>
            <button class="report-tab" data-target="mainInvestBonuses">Main → Invest Bonuses</button>
        </div>

        <div id="reportsMessage" class="reports-message">
            Loading reports...
        </div>

        <div id="reportsTableWrapper" class="reports-table-wrapper" style="display:none;">
            <table class="reports-table">
                <thead id="reportsTableHead"></thead>
                <tbody id="reportsTableBody"></tbody>
            </table>
        </div>

        <div id="reportsPagination" class="reports-pagination" style="display:none;">
            <button id="reportsPrevBtn"
                    class="reports-pagination-btn"
                    type="button">
                Previous
            </button>

            <span id="reportsPageInfo"></span>

            <button id="reportsNextBtn"
                    class="reports-pagination-btn"
                    type="button">
                Next
            </button>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const totalDeposits = document.getElementById("totalDeposits");
        const totalWithdrawals = document.getElementById("totalWithdrawals");
        const totalProfits = document.getElementById("totalProfits");
        const totalBonuses = document.getElementById("totalBonuses");

        const reportsMessage = document.getElementById("reportsMessage");
        const reportsTableWrapper = document.getElementById("reportsTableWrapper");
        const reportsTableHead = document.getElementById("reportsTableHead");
        const reportsTableBody = document.getElementById("reportsTableBody");

        const reportsPagination = document.getElementById("reportsPagination");
        const reportsPrevBtn = document.getElementById("reportsPrevBtn");
        const reportsNextBtn = document.getElementById("reportsNextBtn");
        const reportsPageInfo = document.getElementById("reportsPageInfo");

        const tabs = document.querySelectorAll(".report-tab");

        let currentTab = "deposits";
        let currentPage = 1;
        const pageSize = 5;
        let totalPages = 1;

        async function loadReports() {
            await loadSummary();
            await loadReportPage();
        }

        async function loadSummary() {
            try {
                const result = await api("/api/reports/user/summary");

                if (!result.success || !result.data) {
                    reportsMessage.innerText =
                        result.message || "Could not load report summary.";
                    reportsMessage.style.display = "block";
                    return;
                }

                fillSummary(result.data);

            } catch (error) {
                reportsMessage.innerText =
                    error.message || "Could not load report summary.";
                reportsMessage.style.display = "block";
            }
        }

        async function loadReportPage() {
            try {
                reportsTableHead.innerHTML = "";
                reportsTableBody.innerHTML = "";
                reportsTableWrapper.style.display = "none";
                reportsPagination.style.display = "none";

                reportsMessage.innerText = "Loading reports...";
                reportsMessage.style.display = "block";

                const url =
                    `/api/reports/user/page?type=${encodeURIComponent(currentTab)}&page=${currentPage}&pageSize=${pageSize}`;

                const result = await api(url);

                if (!result.success || !result.data) {
                    reportsMessage.innerText =
                        result.message || "Could not load reports.";
                    return;
                }

                const pagedData = result.data;
                const items = pagedData.items || [];

                currentPage = pagedData.page || 1;
                totalPages = pagedData.totalPages || 1;

                renderTable(currentTab, items);
                renderPagination(pagedData);

            } catch (error) {
                reportsMessage.innerText =
                    error.message || "Could not load reports.";
                reportsMessage.style.display = "block";
                reportsTableWrapper.style.display = "none";
                reportsPagination.style.display = "none";
            }
        }

        function fillSummary(data) {
            totalDeposits.innerText = formatMoney(data.totalDeposits);
            totalWithdrawals.innerText = formatMoney(data.totalWithdrawals);
            totalProfits.innerText = formatMoney(data.totalProfits);
            totalBonuses.innerText = formatMoney(data.totalBonuses);
        }

        function renderPagination(data) {
            const totalCount = data.totalCount || 0;

            if (totalCount <= 0) {
                reportsPagination.style.display = "none";
                return;
            }

            currentPage = data.page || 1;
            totalPages = data.totalPages || 1;

            reportsPagination.style.display = "flex";
            reportsPageInfo.innerText =
                `Page ${currentPage} of ${totalPages} - Total: ${totalCount}`;

            reportsPrevBtn.disabled = currentPage <= 1;
            reportsNextBtn.disabled = currentPage >= totalPages;
        }

        function renderTable(type, items) {
            reportsTableHead.innerHTML = "";
            reportsTableBody.innerHTML = "";

            if (!items || !items.length) {
                reportsMessage.innerText = "No records found.";
                reportsMessage.style.display = "block";
                reportsTableWrapper.style.display = "none";
                return;
            }

            reportsMessage.style.display = "none";
            reportsTableWrapper.style.display = "block";

            if (type === "deposits") {
                reportsTableHead.innerHTML = `
                    <tr>
                        <th>Date</th>
                        <th>Tx Hash</th>
                        <th>Status</th>
                        <th>Note</th>
                        <th>Processed At</th>
                        <th class="text-end">Amount</th>
                    </tr>
                `;

                items.forEach(item => {
                    const status = String(item.status || "").toLowerCase();
                    const note = item.adminNote || "-";

                    appendRow(`
                        <td>${formatDate(item.createdAt)}</td>

                        <td>
                            <div class="report-copy-cell">
                                <span title="${escapeHtml(item.txId || "")}">
                                    ${escapeHtml(item.txId || "-")}
                                </span>

                                ${
                                    item.txId
                                        ? `<button type="button" onclick="copyReportText('${escapeForJs(item.txId)}')">Copy</button>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td>
                            <span class="report-status ${escapeHtml(status)}">
                                ${escapeHtml(item.status || "-")}
                            </span>
                        </td>

                        <td>
                            <span class="report-note ${note !== "-" ? "has-note" : ""}">
                                ${escapeHtml(note)}
                            </span>
                        </td>

                        <td>${formatDate(item.processedAt)}</td>

                        <td class="text-end">${formatMoney(item.amount)}</td>
                    `);
                });

                return;
            }

            if (type === "withdrawals") {
                reportsTableHead.innerHTML = `
                    <tr>
                        <th>Date</th>
                        <th>Network</th>
                        <th>Wallet Address</th>
                        <th>Status</th>
                        <th>Note</th>
                        <th>Processed At</th>
                        <th class="text-end">Amount</th>
                    </tr>
                `;

                items.forEach(item => {
                    const status = String(item.status || "").toLowerCase();
                    const note = item.adminNote || "-";

                    appendRow(`
                        <td>${formatDate(item.createdAt)}</td>

                        <td>
                            <span class="report-status neutral">
                                ${escapeHtml(item.network || "-")}
                            </span>
                        </td>

                        <td>
                            <div class="report-copy-cell">
                                <span title="${escapeHtml(item.walletAddress || "")}">
                                    ${escapeHtml(item.walletAddress || "-")}
                                </span>

                                ${
                                    item.walletAddress
                                        ? `<button type="button" onclick="copyReportText('${escapeForJs(item.walletAddress)}')">Copy</button>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td>
                            <span class="report-status ${escapeHtml(status)}">
                                ${escapeHtml(item.status || "-")}
                            </span>
                        </td>

                        <td>
                            <span class="report-note ${note !== "-" ? "has-note" : ""}">
                                ${escapeHtml(note)}
                            </span>
                        </td>

                        <td>${formatDate(item.processedAt)}</td>

                        <td class="text-end">${formatMoney(item.amount)}</td>
                    `);
                });

                return;
            }

            if (type === "transfers") {
                reportsTableHead.innerHTML = `
                    <tr>
                        <th>Date</th>
                        <th>Direction</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Wallet Path</th>
                        <th>Description</th>
                        <th class="text-end">Amount</th>
                    </tr>
                `;

                items.forEach(item => {
                    appendRow(`
                        <td>${formatDate(item.createdAt)}</td>

                        <td>
                            <span class="report-status neutral">
                                ${escapeHtml(item.direction || "-")}
                            </span>
                        </td>

                        <td>
                            <div class="report-user-cell">
                                <strong>${escapeHtml(item.fromUid || "-")}</strong>
                                <span>${escapeHtml(item.fromEmail || "-")}</span>
                            </div>
                        </td>

                        <td>
                            <div class="report-user-cell">
                                <strong>${escapeHtml(item.toUid || "-")}</strong>
                                <span>${escapeHtml(item.toEmail || "-")}</span>
                            </div>
                        </td>

                        <td>
                            ${escapeHtml(item.fromWalletType || "-")}
                            →
                            ${escapeHtml(item.toWalletType || "-")}
                        </td>

                        <td>${escapeHtml(item.description || "-")}</td>

                        <td class="text-end">${formatMoney(item.amount)}</td>
                    `);
                });

                return;
            }
        if (type === "investmentProfits") {
            reportsTableHead.innerHTML = `
                <tr>
                    <th>Date</th>
                    <th>Effective Rank</th>
                    <th>Real Capital</th>
                    <th>Bonus Capital</th>
                    <th>Profit Base</th>
                    <th class="text-end">Daily Profit</th>
                </tr>
            `;

            items.forEach(item => {
                appendRow(`
                    <td>${formatDate(item.createdAt)}</td>

                    <td>
                        <span class="report-status success">
                            ${escapeHtml(item.effectiveRankName || "-")}
                        </span>
                    </td>

                    <td>
                        ${formatMoney(item.realCapitalAmount)} USDT
                    </td>

                    <td>
                        <strong class="report-bonus-capital">
                            ${formatMoney(item.bonusCapitalAmount)} USDT
                        </strong>
                    </td>

                    <td>
                        <strong>
                            ${formatMoney(item.profitBaseAmount)} USDT
                        </strong>
                    </td>

                    <td class="text-end">
                        ${formatMoney(item.amount)}
                    </td>
                `);
            });

            return;
        }
            if (type === "referralProfits") {
                reportsTableHead.innerHTML = `
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Source User</th>
                        <th class="text-end">Amount</th>
                    </tr>
                `;

                items.forEach(item => {
                    appendRow(`
                        <td>${formatDate(item.createdAt)}</td>

                        <td>
                            <span class="report-status success">
                                Referral Profit
                            </span>
                        </td>

                        <td>
                            <div class="report-user-cell">
                                <strong>${escapeHtml(item.sourceUserUid || "-")}</strong>
                                <span>${escapeHtml(item.sourceUserEmail || "-")}</span>
                                ${
                                    item.sourceUserFullName
                                        ? `<small>${escapeHtml(item.sourceUserFullName)}</small>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td class="text-end">${formatMoney(item.amount)}</td>
                    `);
                });

                return;
            }

            reportsTableHead.innerHTML = `
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th class="text-end">Amount</th>
                </tr>
            `;

            items.forEach(item => {
                appendRow(`
                    <td>${formatDate(item.createdAt)}</td>
                    <td><span class="report-status success">${getReadableType(type)}</span></td>
                    <td class="text-end">${formatMoney(item.amount)}</td>
                `);
            });
        }

        function appendRow(html) {
            const row = document.createElement("tr");
            row.innerHTML = html;
            reportsTableBody.appendChild(row);
        }

        tabs.forEach(tab => {
            tab.addEventListener("click", async function () {
                tabs.forEach(x => x.classList.remove("active"));
                this.classList.add("active");

                currentTab = this.dataset.target;
                currentPage = 1;

                await loadReportPage();
            });
        });

        reportsPrevBtn.addEventListener("click", async function () {
            if (currentPage <= 1) {
                return;
            }

            currentPage--;
            await loadReportPage();
        });

        reportsNextBtn.addEventListener("click", async function () {
            if (currentPage >= totalPages) {
                return;
            }

            currentPage++;
            await loadReportPage();
        });

        function getReadableType(type) {
            if (type === "investmentProfits") return "Investment Profit";
            if (type === "referralProfits") return "Referral Profit";
            if (type === "mainInvestBonuses") return "Main → Invest Bonus";
            return type;
        }

        function formatMoney(value) {
            const number = Number(value || 0);

            return number.toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 8
            }) + " USDT";
        }

        function formatDate(value) {
            if (!value) return "-";

            return new Date(value).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit"
            });
        }

        async function copyReportText(value) {
            if (!value) {
                showNotification("Nothing to copy.", "warning");
                return;
            }

            try {
                await navigator.clipboard.writeText(value);
                showNotification("Copied to clipboard.", "success");
            } catch {
                const textarea = document.createElement("textarea");
                textarea.value = value;
                textarea.style.position = "fixed";
                textarea.style.opacity = "0";

                document.body.appendChild(textarea);
                textarea.focus();
                textarea.select();

                document.execCommand("copy");
                document.body.removeChild(textarea);

                showNotification("Copied to clipboard.", "success");
            }
        }

        function escapeForJs(value) {
            return String(value || "")
                .replaceAll("\\", "\\\\")
                .replaceAll("'", "\\'")
                .replaceAll('"', '\\"')
                .replaceAll("\n", "")
                .replaceAll("\r", "");
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        loadReports();
    </script>
}