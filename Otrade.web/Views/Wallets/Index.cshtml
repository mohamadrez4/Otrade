@{
    Layout = "~/Views/Shared/_PanelLayout.cshtml";
    ViewData["Title"] = "Wallets";
}

<div class="wallet-v2-page">

    <section class="panel-card wallet-v2-header">
        <div>
            <span class="wallet-v2-eyebrow">Asset Management</span>
            <h2>Wallets</h2>
            <p>
                Manage your Otrade wallets and transfer funds through the allowed wallet paths.
            </p>
        </div>

        <div class="wallet-v2-header-actions">
            <button type="button"
                    class="wallet-v2-outline-btn"
                    data-open-wallet-modal="walletGuideModal">
                Wallet Guide
            </button>

            <button type="button"
                    class="wallet-v2-outline-btn"
                    data-open-wallet-modal="transferRulesModal">
                Transfer Rules
            </button>
        </div>
    </section>

    <div class="wallet-v2-main-grid">

        <section class="panel-card wallet-v2-overview">
            <div class="wallet-v2-section-header">
                <div>
                    <span class="wallet-v2-eyebrow">Your Assets</span>
                    <h3>Wallet Overview</h3>
                </div>

                <button type="button"
                        class="wallet-v2-icon-btn wallet-v2-warning-icon"
                        data-open-wallet-modal="walletGuideModal"
                        aria-label="Open wallet guide"
                        title="Important wallet information">
                    !
                </button>
            </div>

            <div class="wallet-v2-total-assets">
                <span>Total Assets</span>
                <strong id="walletTotalAssets">0.00 USDT</strong>
            </div>

            <div class="wallet-v2-wallet-list">
                <article class="wallet-v2-wallet-row wallet-main">
                    <div class="wallet-v2-wallet-info">
                        <span class="wallet-v2-wallet-icon">M</span>
                        <div>
                            <strong>Main Wallet</strong>
                            <small>Deposits and withdrawals</small>
                        </div>
                    </div>
                    <span class="wallet-v2-wallet-balance" id="mainWallet">0.00 USDT</span>
                </article>

                <article class="wallet-v2-wallet-row wallet-invest">
                    <div class="wallet-v2-wallet-info">
                        <span class="wallet-v2-wallet-icon">I</span>
                        <div>
                            <strong>Investing Wallet</strong>
                            <small>Active investment capital</small>
                        </div>
                    </div>
                    <span class="wallet-v2-wallet-balance" id="investWallet">0.00 USDT</span>
                </article>

                <article class="wallet-v2-wallet-row wallet-profit">
                    <div class="wallet-v2-wallet-info">
                        <span class="wallet-v2-wallet-icon">P</span>
                        <div>
                            <strong>Profit Wallet</strong>
                            <small>Daily investment profits</small>
                        </div>
                    </div>
                    <span class="wallet-v2-wallet-balance" id="profitWallet">0.00 USDT</span>
                </article>

                <article class="wallet-v2-wallet-row wallet-referral">
                    <div class="wallet-v2-wallet-info">
                        <span class="wallet-v2-wallet-icon">R</span>
                        <div>
                            <strong>Referral Wallet</strong>
                            <small>Referral commissions</small>
                        </div>
                    </div>
                    <span class="wallet-v2-wallet-balance" id="referralWallet">0.00 USDT</span>
                </article>
            </div>
        </section>

        <section class="panel-card wallet-v2-transfer-panel">
            <div class="wallet-v2-section-header">
                <div>
                    <span class="wallet-v2-eyebrow">Wallet Transfer</span>
                    <h3>Transfer Between Wallets</h3>
                </div>

                <button type="button"
                        class="wallet-v2-rules-btn"
                        data-open-wallet-modal="transferRulesModal">
                    View Rules
                </button>
            </div>

            <form id="transferForm" class="wallet-v2-transfer-form">
                <div class="wallet-v2-transfer-grid">
                    <div class="wallet-v2-field">
                        <label for="fromWallet">From Wallet</label>
                        <select class="form-control panel-input" id="fromWallet">
                            <option value="Main">Main Wallet</option>
                            <option value="Invest">Investing Wallet</option>
                            <option value="Profit">Profit Wallet</option>
                            <option value="Referral">Referral Wallet</option>
                        </select>
                    </div>

                    <div class="wallet-v2-field">
                        <label for="toWallet">To Wallet</label>
                        <select class="form-control panel-input" id="toWallet"></select>
                    </div>
                </div>

                <div class="wallet-v2-route-box">
                    <div>
                        <span>Selected Route</span>
                        <strong id="transferRouteText">Main Wallet → Investing Wallet</strong>
                    </div>
                    <div>
                        <span>Available Balance</span>
                        <strong id="sourceWalletBalance">0.00 USDT</strong>
                    </div>
                </div>

                <div class="transfer-capacity-box wallet-v2-capacity-box"
                     id="transferCapacityBox"
                     style="display:none;">
                    <div class="transfer-capacity-header">
                        <div>
                            <span>Investment Capacity</span>
                            <strong id="capacityMonthText">Current Month</strong>
                        </div>

                        <button type="button" id="refreshInvestmentCapacityBtn">
                            Refresh
                        </button>
                    </div>

                    <div class="transfer-capacity-remaining-box">
                        <span>Capacity Remaining</span>
                        <strong id="capacityRemainingText">0.00 USDT</strong>
                    </div>

                    <p id="capacityWarningText" class="transfer-capacity-warning"></p>

                    <div id="investmentWaitListBox"
                         class="investment-waitlist-box"
                         style="display:none;">
                        <div class="investment-waitlist-info">
                            <strong id="investmentWaitListTitle">Join Investment Wait List</strong>
                            <p id="investmentWaitListText">
                                Investment capacity is full. You can join the wait list and we will notify you when capacity becomes available.
                            </p>
                        </div>

                        <div id="investmentWaitListStatus"
                             class="investment-waitlist-status"
                             style="display:none;">
                        </div>

                        <div class="investment-waitlist-actions">
                            <button type="button"
                                    id="joinInvestmentWaitListBtn"
                                    class="panel-primary-btn investment-waitlist-btn">
                                Join Wait List
                            </button>

                            <button type="button"
                                    id="cancelInvestmentWaitListBtn"
                                    class="internal-transfer-secondary-btn investment-waitlist-btn"
                                    style="display:none;">
                                Cancel Request
                            </button>
                        </div>
                    </div>
                </div>

                <div class="wallet-v2-field">
                    <label for="transferAmount">Amount</label>
                    <div class="transfer-amount-wrapper">
                        <input type="number"
                               class="form-control panel-input transfer-amount-input"
                               id="transferAmount"
                               min="0"
                               step="0.00000001"
                               placeholder="0.00" />

                        <button type="button" id="maxTransferBtn" class="transfer-max-btn">
                            MAX
                        </button>
                    </div>
                </div>

                <div class="wallet-v2-field">
                    <label for="transferDescription">Description</label>
                    <input type="text"
                           class="form-control panel-input"
                           id="transferDescription"
                           maxlength="500"
                           placeholder="Optional" />
                </div>

                <button type="submit"
                        class="wallet-v2-submit-btn"
                        id="confirmTransferBtn">
                    Review Transfer
                </button>
            </form>
        </section>
    </div>

    <section class="panel-card wallet-v2-internal-card internal-transfer-card">
        <div class="internal-transfer-header">
            <div>
                <h4>Internal Transfer</h4>
                <p>Transfer funds from your Main Wallet to another user's Main Wallet using UID or email.</p>
            </div>
        </div>

        <div class="internal-transfer-lookup">
            <div class="internal-transfer-field">
                <label for="internalReceiverQuery">Receiver UID or Email</label>

                <div class="internal-transfer-search-row">
                    <input id="internalReceiverQuery"
                           type="text"
                           class="panel-input"
                           autocomplete="off"
                           placeholder="Enter receiver UID or email" />

                    <button type="button"
                            id="checkInternalReceiverBtn"
                            class="panel-primary-btn">
                        Check
                    </button>
                </div>

                <small class="internal-transfer-help">
                    UID is the user's referral code.
                </small>
            </div>
        </div>

        <div id="internalReceiverMessage"
             class="internal-receiver-message"
             style="display:none;">
        </div>

        <div id="internalReceiverPreview"
             class="internal-receiver-preview"
             style="display:none;">
            <div class="internal-receiver-preview-icon">✓</div>

            <div class="internal-receiver-preview-content">
                <div class="internal-receiver-preview-title">Receiver Found</div>

                <div class="internal-receiver-grid">
                    <div>
                        <span>Full Name</span>
                        <strong id="internalReceiverFullName">-</strong>
                    </div>
                    <div>
                        <span>UID</span>
                        <strong id="internalReceiverUid">-</strong>
                    </div>
                    <div>
                        <span>Email</span>
                        <strong id="internalReceiverEmail">-</strong>
                    </div>
                </div>

                <p class="internal-receiver-warning">
                    Please make sure this is the correct receiver before continuing.
                </p>
            </div>
        </div>

        <div id="internalTransferDetails"
             class="internal-transfer-details"
             style="display:none;">
            <div class="internal-transfer-details-grid">
                <div class="internal-transfer-field">
                    <label for="internalTransferAmount">Amount</label>
                    <input id="internalTransferAmount"
                           type="number"
                           min="0"
                           step="0.00000001"
                           class="panel-input"
                           placeholder="Enter amount from Main Wallet" />
                </div>

                <div class="internal-transfer-field">
                    <label for="internalTransferDescription">Description</label>
                    <input id="internalTransferDescription"
                           type="text"
                           maxlength="500"
                           class="panel-input"
                           placeholder="Optional" />
                </div>
            </div>

            <div class="internal-transfer-balance-box">
                <span>Your Main Wallet Balance</span>
                <strong id="internalTransferMainBalance">0.00 USDT</strong>
            </div>

            <button type="button"
                    id="sendInternalTransferCodeBtn"
                    class="panel-primary-btn internal-transfer-send-code-btn">
                Send Verification Code
            </button>
        </div>

        <div id="internalTransferVerificationBox"
             class="internal-transfer-verification-box"
             style="display:none;">
            <div class="internal-transfer-verification-header">
                <div>
                    <h5>Email Verification</h5>
                    <p>
                        A 6-digit verification code has been sent to your email.
                        Enter the code to complete the internal transfer.
                    </p>
                </div>
            </div>

            <div class="internal-transfer-verification-summary">
                <div>
                    <span>Receiver</span>
                    <strong id="internalTransferVerifyReceiver">-</strong>
                </div>
                <div>
                    <span>Amount</span>
                    <strong id="internalTransferVerifyAmount">0.00 USDT</strong>
                </div>
            </div>

            <div class="internal-transfer-field">
                <label for="internalTransferCode">Verification Code</label>
                <input id="internalTransferCode"
                       type="text"
                       maxlength="6"
                       inputmode="numeric"
                       autocomplete="one-time-code"
                       class="panel-input internal-transfer-code-input"
                       placeholder="Enter 6-digit code" />
            </div>

            <div class="internal-transfer-actions">
                <button type="button"
                        id="resetInternalTransferBtn"
                        class="internal-transfer-secondary-btn">
                    Change Receiver / Amount
                </button>

                <button type="button"
                        id="confirmInternalTransferBtn"
                        class="panel-primary-btn">
                    Confirm Internal Transfer
                </button>
            </div>
        </div>
    </section>
</div>

<div class="wallet-v2-modal-backdrop"
     id="walletGuideModal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="walletGuideTitle"
     aria-hidden="true">
    <div class="wallet-v2-modal-shell">
        <div class="wallet-v2-modal-header">
            <div>
                <span class="wallet-v2-eyebrow">Asset Type Explanation</span>
                <h3 id="walletGuideTitle">Wallet Guide</h3>
            </div>

            <button type="button"
                    class="wallet-v2-modal-close"
                    data-close-wallet-modal
                    aria-label="Close wallet guide">
                ×
            </button>
        </div>

        <div class="wallet-v2-modal-body">
            <p class="wallet-v2-modal-intro">
                Your assets are managed through four separate wallets, each designed for a specific purpose.
                This structure ensures transparent fund management while giving you full control over your
                investments, profits, and referral earnings.
            </p>

            <article class="wallet-v2-guide-item">
                <h4>Main Wallet</h4>
                <p>The Main Wallet serves as the central hub for managing your funds.</p>
                <ul>
                    <li>All deposits are credited to your Main Wallet first.</li>
                    <li>All withdrawals can only be made from the Main Wallet.</li>
                    <li>You can transfer funds from your Main Wallet to your Investing Wallet to start earning daily profits.</li>
                    <li>You can also receive investment profits and referral commissions from their respective wallets into your Main Wallet and withdraw them at any time.</li>
                </ul>
            </article>

            <article class="wallet-v2-guide-item">
                <h4>Investing Wallet</h4>
                <p>The Investing Wallet holds the capital actively used for investment and daily profit generation.</p>
                <ul>
                    <li>Funds are transferred here from your Main Wallet.</li>
                    <li>Daily investment profits are calculated based on your current rank and credited to your Profit Wallet.</li>
                    <li>You may reinvest your earnings by transferring them back into the Investing Wallet, allowing your investment capital to grow through compounding.</li>
                </ul>
            </article>

            <article class="wallet-v2-guide-item">
                <h4>Profit Wallet</h4>
                <p>The Profit Wallet stores all daily profits generated from your investments.</p>
                <ul>
                    <li>Transfer your profits to your Main Wallet for withdrawal.</li>
                    <li>Transfer your profits to your Investing Wallet to increase your investment capital and benefit from compound growth.</li>
                </ul>
            </article>

            <article class="wallet-v2-guide-item">
                <h4>Referral Wallet</h4>
                <p>The Referral Wallet stores all commissions earned through the referral program.</p>
                <ul>
                    <li>Transfer your referral commissions to your Main Wallet and withdraw them at any time.</li>
                    <li>Transfer them to your Investing Wallet to increase your investment capital and maximize future returns.</li>
                </ul>
            </article>

            <article class="wallet-v2-guide-item flow">
                <h4>How Funds Flow Through the Platform</h4>
                <ol>
                    <li>Deposit funds into your Main Wallet.</li>
                    <li>Transfer the desired amount from your Main Wallet to your Investing Wallet.</li>
                    <li>Daily investment profits are credited to your Profit Wallet.</li>
                    <li>Referral commissions are credited to your Referral Wallet.</li>
                    <li>Funds in both the Profit Wallet and Referral Wallet can be transferred to the Main Wallet or the Investing Wallet.</li>
                </ol>
            </article>
        </div>

        <div class="wallet-v2-modal-footer">
            <button type="button" class="wallet-v2-modal-primary" data-close-wallet-modal>
                Got It
            </button>
        </div>
    </div>
</div>

<div class="wallet-v2-modal-backdrop"
     id="transferRulesModal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="transferRulesTitle"
     aria-hidden="true">
    <div class="wallet-v2-modal-shell rules">
        <div class="wallet-v2-modal-header">
            <div>
                <span class="wallet-v2-eyebrow">Allowed Wallet Paths</span>
                <h3 id="transferRulesTitle">Wallet Transfer Rules</h3>
            </div>

            <button type="button"
                    class="wallet-v2-modal-close"
                    data-close-wallet-modal
                    aria-label="Close transfer rules">
                ×
            </button>
        </div>

        <div class="wallet-v2-modal-body">
            <div class="wallet-v2-rule-list">
                <div class="wallet-v2-rule-item"><span>01</span><p>Funds can be transferred from the Main Wallet to the Investing Wallet to start an investment.</p></div>
                <div class="wallet-v2-rule-item"><span>02</span><p>The balances of the Profit Wallet and Referral Wallet are updated automatically by the system based on your investment profits and referral commissions. Users cannot deposit funds directly into these wallets. Funds can only be transferred out of these wallets to either the Main Wallet or the Investing Wallet.</p></div>
                <div class="wallet-v2-rule-item"><span>03</span><p>Funds in the Profit Wallet and Referral Wallet can be transferred to the Main Wallet for withdrawal or to the Investing Wallet to increase your investment capital.</p></div>
                <div class="wallet-v2-rule-item"><span>04</span><p>Direct transfers between the Profit Wallet and Referral Wallet are not permitted.</p></div>
                <div class="wallet-v2-rule-item"><span>05</span><p>Deposits are credited to the Main Wallet, and all withdrawals can only be made from the Main Wallet.</p></div>
                <div class="wallet-v2-rule-item"><span>06</span><p>After each transfer, wallet balances are updated automatically in real time.</p></div>
            </div>

            <div class="wallet-v2-route-table">
                <div><strong>Main Wallet</strong><span>Investing Wallet</span></div>
                <div><strong>Investing Wallet</strong><span>Main Wallet, after the investment term has ended</span></div>
                <div><strong>Profit Wallet</strong><span>Main Wallet / Investing Wallet</span></div>
                <div><strong>Referral Wallet</strong><span>Main Wallet / Investing Wallet</span></div>
            </div>
        </div>

        <div class="wallet-v2-modal-footer">
            <button type="button" class="wallet-v2-modal-primary" data-close-wallet-modal>
                Close
            </button>
        </div>
    </div>
</div>

<div class="transfer-confirm-backdrop" id="transferConfirmModal" style="display:none;">
    <div class="transfer-confirm-shell">
        <div class="transfer-confirm-header">
            <div>
                <h4>Confirm Transfer</h4>
                <p>Please review the details before final confirmation.</p>
            </div>

            <button type="button" class="transfer-modal-close" onclick="closeTransferConfirmModal()">
                ×
            </button>
        </div>

        <div class="transfer-confirm-body">
            <div class="transfer-confirm-row"><span>From Wallet</span><strong id="confirmFromWallet">-</strong></div>
            <div class="transfer-confirm-row"><span>To Wallet</span><strong id="confirmToWallet">-</strong></div>
            <div class="transfer-confirm-row highlight"><span>Amount</span><strong id="confirmAmount">0.00 USDT</strong></div>
            <div class="transfer-confirm-row"><span>Fee</span><strong id="confirmFee">0.00 USDT</strong></div>

            <div class="transfer-confirm-note" id="confirmDescriptionBox" style="display:none;">
                <span>Description</span>
                <p id="confirmDescription">-</p>
            </div>
        </div>

        <div class="transfer-confirm-footer">
            <button type="button" class="transfer-cancel-btn" onclick="closeTransferConfirmModal()">
                Back
            </button>

            <button type="button"
                    class="transfer-submit-btn"
                    id="finalConfirmTransferBtn"
                    onclick="confirmTransferFinal()">
                Confirm & Transfer
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentInvestmentWaitList = null;
        let walletsMap = {};
        let currentInvestmentCapacity = null;
        let isTransferSubmitting = false;
        let pendingTransferRequest = null;
        let selectedInternalReceiver = null;
        let internalReceiverLookupTimer = null;
        let selectedInternalTransferVerificationId = null;
        let internalTransferLocked = false;
        let internalTransferVerifiedAmount = 0;

        const allowedTransfers = {
            Main: ["Invest"],
            Invest: ["Main"],
            Profit: ["Main", "Invest"],
            Referral: ["Main", "Invest"]
        };

        const investmentWaitListBox = document.getElementById("investmentWaitListBox");
        const investmentWaitListTitle = document.getElementById("investmentWaitListTitle");
        const investmentWaitListText = document.getElementById("investmentWaitListText");
        const investmentWaitListStatus = document.getElementById("investmentWaitListStatus");
        const joinInvestmentWaitListBtn = document.getElementById("joinInvestmentWaitListBtn");
        const cancelInvestmentWaitListBtn = document.getElementById("cancelInvestmentWaitListBtn");

        document.addEventListener("DOMContentLoaded", async function () {
            checkAuth();

            const fromWalletSelect = document.getElementById("fromWallet");
            const toWalletSelect = document.getElementById("toWallet");
            const transferAmountInput = document.getElementById("transferAmount");
            const maxTransferBtn = document.getElementById("maxTransferBtn");
            const transferForm = document.getElementById("transferForm");
            const refreshCapacityBtn = document.getElementById("refreshInvestmentCapacityBtn");

            fromWalletSelect?.addEventListener("change", updateToWalletOptions);
            toWalletSelect?.addEventListener("change", updateTransferRouteSummary);
            transferAmountInput?.addEventListener("input", updateTransferCapacityBox);
            maxTransferBtn?.addEventListener("click", setMaxTransferAmount);
            transferForm?.addEventListener("submit", submitTransfer);
            refreshCapacityBtn?.addEventListener("click", loadCurrentInvestmentCapacity);

            document.querySelectorAll("[data-open-wallet-modal]").forEach(button => {
                button.addEventListener("click", function () {
                    openWalletInfoModal(button.dataset.openWalletModal);
                });
            });

            document.querySelectorAll("[data-close-wallet-modal]").forEach(button => {
                button.addEventListener("click", function () {
                    closeWalletInfoModal(button.closest(".wallet-v2-modal-backdrop"));
                });
            });

            document.querySelectorAll(".wallet-v2-modal-backdrop").forEach(modal => {
                modal.addEventListener("click", function (event) {
                    if (event.target === modal) {
                        closeWalletInfoModal(modal);
                    }
                });
            });

            document.getElementById("transferConfirmModal")?.addEventListener("click", function (event) {
                if (event.target.id === "transferConfirmModal") {
                    closeTransferConfirmModal();
                }
            });

            document.addEventListener("keydown", function (event) {
                if (event.key !== "Escape") {
                    return;
                }

                if (document.getElementById("transferConfirmModal")?.style.display === "flex") {
                    closeTransferConfirmModal();
                    return;
                }

                closeAllWalletInfoModals();
            });

            const internalReceiverInput = document.getElementById("internalReceiverQuery");
            const checkInternalReceiverBtn = document.getElementById("checkInternalReceiverBtn");
            const sendInternalTransferCodeBtn = document.getElementById("sendInternalTransferCodeBtn");
            const confirmInternalTransferBtn = document.getElementById("confirmInternalTransferBtn");
            const resetInternalTransferBtn = document.getElementById("resetInternalTransferBtn");
            const internalTransferCodeInput = document.getElementById("internalTransferCode");

            internalReceiverInput?.addEventListener("input", handleInternalReceiverInput);
            checkInternalReceiverBtn?.addEventListener("click", lookupInternalReceiver);
            sendInternalTransferCodeBtn?.addEventListener("click", sendInternalTransferVerificationCode);
            confirmInternalTransferBtn?.addEventListener("click", confirmInternalTransfer);
            resetInternalTransferBtn?.addEventListener("click", resetInternalTransferVerification);

            internalTransferCodeInput?.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    confirmInternalTransfer();
                }
            });

            joinInvestmentWaitListBtn?.addEventListener("click", joinInvestmentWaitList);
            cancelInvestmentWaitListBtn?.addEventListener("click", cancelInvestmentWaitList);

            updateToWalletOptions();

            await loadWallets();
            await loadCurrentInvestmentCapacity();
            await loadMyInvestmentWaitListStatus();
        });

        async function loadWallets() {
            try {
                const result = await api("/api/dashboard", { method: "GET" });

                if (!result || !result.success) {
                    showNotification(result?.message || "Unable to load wallets", "error");
                    return;
                }

                walletsMap = {};

                const data = result.data || {};
                const wallets = data.wallets || [];

                wallets.forEach(wallet => {
                    walletsMap[wallet.walletType] = {
                        walletId: wallet.walletId,
                        balance: Number(wallet.balance || 0)
                    };
                });

                setWalletValue("Main", "mainWallet");
                setWalletValue("Invest", "investWallet");
                setWalletValue("Profit", "profitWallet");
                setWalletValue("Referral", "referralWallet");

                const totalAssetsElement = document.getElementById("walletTotalAssets");
                if (totalAssetsElement) {
                    totalAssetsElement.innerText = formatMoney(data.totalAssets) + " USDT";
                }

                updateTransferRouteSummary();
            } catch (error) {
                showNotification(error.message || "Unable to load wallets", "error");
            }
        }

        async function loadCurrentInvestmentCapacity() {
            try {
                const result = await api("/api/wallet/investment-capacity/current", { method: "GET" });

                if (!result || !result.success) {
                    currentInvestmentCapacity = null;
                    updateTransferCapacityBox();
                    return;
                }

                currentInvestmentCapacity = result.data;
                updateTransferCapacityBox();
            } catch {
                currentInvestmentCapacity = null;
                updateTransferCapacityBox();
            }
        }

        function setWalletValue(type, elementId) {
            const wallet = walletsMap[type];
            const element = document.getElementById(elementId);

            if (!element) {
                return;
            }

            element.innerText = wallet
                ? formatMoney(wallet.balance) + " USDT"
                : "0.00 USDT";
        }

        function openWalletInfoModal(modalId) {
            const modal = document.getElementById(modalId);

            if (!modal) {
                return;
            }

            modal.classList.add("show");
            modal.setAttribute("aria-hidden", "false");
            document.body.classList.add("wallet-v2-modal-open");
        }

        function closeWalletInfoModal(modal) {
            if (!modal) {
                return;
            }

            modal.classList.remove("show");
            modal.setAttribute("aria-hidden", "true");

            if (!document.querySelector(".wallet-v2-modal-backdrop.show")) {
                document.body.classList.remove("wallet-v2-modal-open");
            }
        }

        function closeAllWalletInfoModals() {
            document.querySelectorAll(".wallet-v2-modal-backdrop.show").forEach(modal => {
                closeWalletInfoModal(modal);
            });
        }

        function closeTransferConfirmModal() {
            const modal = document.getElementById("transferConfirmModal");

            if (modal) {
                modal.style.display = "none";
            }
        }

        function resetWalletTransferForm() {
            document.getElementById("transferForm")?.reset();

            const fromSelect = document.getElementById("fromWallet");
            if (fromSelect) {
                fromSelect.value = "Main";
            }

            pendingTransferRequest = null;
            updateToWalletOptions();
        }

        function updateToWalletOptions() {
            const fromSelect = document.getElementById("fromWallet");
            const toSelect = document.getElementById("toWallet");

            if (!fromSelect || !toSelect) {
                return;
            }

            const fromType = fromSelect.value;
            const previousTarget = toSelect.value;
            const allowedTargets = allowedTransfers[fromType] || [];

            toSelect.innerHTML = "";

            allowedTargets.forEach(targetType => {
                const option = document.createElement("option");
                option.value = targetType;
                option.textContent = getWalletDisplayName(targetType);
                toSelect.appendChild(option);
            });

            if (allowedTargets.includes(previousTarget)) {
                toSelect.value = previousTarget;
            }

            const amountInput = document.getElementById("transferAmount");
            if (amountInput) {
                amountInput.value = "";
            }

            updateTransferRouteSummary();
        }

        function updateTransferRouteSummary() {
            const fromType = document.getElementById("fromWallet")?.value || "";
            const toType = document.getElementById("toWallet")?.value || "";
            const routeText = document.getElementById("transferRouteText");
            const sourceBalance = document.getElementById("sourceWalletBalance");

            if (routeText) {
                routeText.innerText = `${getWalletDisplayName(fromType)} → ${getWalletDisplayName(toType)}`;
            }

            if (sourceBalance) {
                sourceBalance.innerText = formatMoney(walletsMap[fromType]?.balance || 0) + " USDT";
            }

            updateTransferCapacityBox();
        }

        function isTransferToInvest() {
            return document.getElementById("toWallet")?.value === "Invest";
        }

        async function loadMyInvestmentWaitListStatus() {
            try {
                const result = await api("/api/wallet/investment-wait-list/my-status", { method: "GET" });

                if (!result || !result.success) {
                    currentInvestmentWaitList = null;
                    updateInvestmentWaitListBox();
                    return;
                }

                currentInvestmentWaitList = result.data || null;
                updateInvestmentWaitListBox();
            } catch {
                currentInvestmentWaitList = null;
                updateInvestmentWaitListBox();
            }
        }

        async function joinInvestmentWaitList() {
            const amount = Number(document.getElementById("transferAmount")?.value || 0);

            if (!isTransferToInvest()) {
                showNotification("Wait list is only available for transfers to the Investing Wallet.", "warning");
                return;
            }

            if (!amount || amount <= 0) {
                showNotification("Please enter the amount you want to invest first.", "warning");
                return;
            }

            const confirmed = await showConfirm(
                `Join investment wait list for ${formatMoney(amount)} USDT?`,
                "Join Wait List"
            );

            if (!confirmed) {
                return;
            }

            joinInvestmentWaitListBtn.disabled = true;
            joinInvestmentWaitListBtn.innerText = "Submitting...";

            try {
                const result = await api("/api/wallet/investment-wait-list/join", {
                    method: "POST",
                    body: JSON.stringify({ requestedAmount: amount })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not join wait list.", "error");
                    return;
                }

                currentInvestmentWaitList = result.data || null;
                showNotification(result.message || "You have been added to the investment wait list.", "success");
                updateInvestmentWaitListBox();
            } catch (error) {
                showNotification(error.message || "Could not join wait list.", "error");
            } finally {
                joinInvestmentWaitListBtn.disabled = false;
                joinInvestmentWaitListBtn.innerText = "Join Wait List";
            }
        }

        async function cancelInvestmentWaitList() {
            const confirmed = await showConfirm(
                "Are you sure you want to cancel your wait list request?",
                "Cancel Wait List"
            );

            if (!confirmed) {
                return;
            }

            cancelInvestmentWaitListBtn.disabled = true;
            cancelInvestmentWaitListBtn.innerText = "Cancelling...";

            try {
                const result = await api("/api/wallet/investment-wait-list/cancel", { method: "POST" });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not cancel wait list request.", "error");
                    return;
                }

                showNotification(result.message || "Wait list request cancelled.", "success");
                await loadMyInvestmentWaitListStatus();
            } catch (error) {
                showNotification(error.message || "Could not cancel wait list request.", "error");
            } finally {
                cancelInvestmentWaitListBtn.disabled = false;
                cancelInvestmentWaitListBtn.innerText = "Cancel Request";
            }
        }

        function updateInvestmentWaitListBox() {
            if (!investmentWaitListBox) {
                return;
            }

            if (!isTransferToInvest()) {
                investmentWaitListBox.style.display = "none";
                return;
            }

            const amount = Number(document.getElementById("transferAmount")?.value || 0);
            const remaining = Number(currentInvestmentCapacity?.remainingCapacity || 0);

            const capacityIsUnavailable =
                !currentInvestmentCapacity ||
                !currentInvestmentCapacity.isConfigured ||
                !currentInvestmentCapacity.isActive ||
                remaining <= 0 ||
                (amount > 0 && amount > remaining);

            const activeWaitList = currentInvestmentWaitList && [
                "Pending",
                "Notified",
                "CapacityAvailable"
            ].includes(currentInvestmentWaitList.status);

            if (!capacityIsUnavailable && !activeWaitList) {
                investmentWaitListBox.style.display = "none";
                return;
            }

            investmentWaitListBox.style.display = "block";

            if (activeWaitList) {
                investmentWaitListTitle.innerText = "Your Wait List Request";
                investmentWaitListText.innerText =
                    `Requested Amount: ${formatMoney(currentInvestmentWaitList.requestedAmount)} USDT`;

                investmentWaitListStatus.style.display = "block";
                investmentWaitListStatus.className =
                    `investment-waitlist-status ${String(currentInvestmentWaitList.status || "").toLowerCase()}`;
                investmentWaitListStatus.innerText = `Status: ${currentInvestmentWaitList.status}`;

                joinInvestmentWaitListBtn.style.display = "none";
                cancelInvestmentWaitListBtn.style.display = "inline-flex";

                if (currentInvestmentWaitList.status === "Notified") {
                    investmentWaitListText.innerText =
                        `Your wait list request has been reviewed. We will notify you when investment capacity becomes available. Requested amount: ${formatMoney(currentInvestmentWaitList.requestedAmount)} USDT.`;
                }

                if (currentInvestmentWaitList.status === "CapacityAvailable") {
                    investmentWaitListText.innerText =
                        `Investment capacity is now available for your request of ${formatMoney(currentInvestmentWaitList.requestedAmount)} USDT. You can try transferring funds to the Investing Wallet now.`;
                }

                return;
            }

            investmentWaitListTitle.innerText = "Join Investment Wait List";

            if (!currentInvestmentCapacity || !currentInvestmentCapacity.isConfigured) {
                investmentWaitListText.innerText =
                    "Investment capacity is not configured yet. You can join the wait list.";
            } else if (!currentInvestmentCapacity.isActive) {
                investmentWaitListText.innerText =
                    "Investment capacity is currently inactive. You can join the wait list.";
            } else if (remaining <= 0) {
                investmentWaitListText.innerText =
                    "Investment capacity is full. You can join the wait list.";
            } else if (amount > remaining) {
                investmentWaitListText.innerText =
                    `Your amount exceeds remaining capacity. Remaining capacity is ${formatMoney(remaining)} USDT.`;
            } else {
                investmentWaitListText.innerText =
                    "You can join the wait list for this investment amount.";
            }

            investmentWaitListStatus.style.display = "none";
            investmentWaitListStatus.innerText = "";
            joinInvestmentWaitListBtn.style.display = "inline-flex";
            cancelInvestmentWaitListBtn.style.display = "none";
        }

        function updateTransferCapacityBox() {
            const box = document.getElementById("transferCapacityBox");
            const warning = document.getElementById("capacityWarningText");

            if (!box || !warning) {
                return;
            }

            if (!isTransferToInvest()) {
                box.style.display = "none";
                updateInvestmentWaitListBox();
                return;
            }

            box.style.display = "block";
            warning.classList.remove("danger");
            warning.innerText = "";

            if (!currentInvestmentCapacity || !currentInvestmentCapacity.isConfigured) {
                document.getElementById("capacityMonthText").innerText = "Not configured";
                document.getElementById("capacityRemainingText").innerText = "0.00 USDT";
                warning.innerText = "Investment capacity for current month is not configured by admin.";
                warning.classList.add("danger");
                updateInvestmentWaitListBox();
                return;
            }

            const remaining = Number(currentInvestmentCapacity.remainingCapacity || 0);
            const amount = Number(document.getElementById("transferAmount")?.value || 0);

            document.getElementById("capacityMonthText").innerText =
                currentInvestmentCapacity.monthLabel || "Current Month";
            document.getElementById("capacityRemainingText").innerText =
                formatMoney(remaining) + " USDT";

            if (!currentInvestmentCapacity.isActive) {
                warning.innerText = "Investment capacity for current month is inactive.";
                warning.classList.add("danger");
                updateInvestmentWaitListBox();
                return;
            }

            if (remaining <= 0) {
                warning.innerText = "Investment capacity for current month is full.";
                warning.classList.add("danger");
                updateInvestmentWaitListBox();
                return;
            }

            if (amount > 0 && amount > remaining) {
                warning.innerText =
                    `Amount exceeds remaining investment capacity. Remaining: ${formatMoney(remaining)} USDT`;
                warning.classList.add("danger");
                updateInvestmentWaitListBox();
                return;
            }

            warning.innerText =
                `You can transfer up to ${formatMoney(remaining)} USDT to the Investing Wallet this month.`;
            updateInvestmentWaitListBox();
        }

        function setMaxTransferAmount() {
            const fromType = document.getElementById("fromWallet")?.value;
            const wallet = walletsMap[fromType];

            if (!wallet) {
                showNotification("Wallet balance not found", "error");
                return;
            }

            let maxAmount = Number(wallet.balance || 0);

            if (isTransferToInvest()) {
                if (!currentInvestmentCapacity || !currentInvestmentCapacity.isConfigured) {
                    showNotification("Investment capacity is not configured.", "error");
                    return;
                }

                if (!currentInvestmentCapacity.isActive) {
                    showNotification("Investment capacity is inactive.", "error");
                    return;
                }

                const remaining = Number(currentInvestmentCapacity.remainingCapacity || 0);

                if (remaining <= 0) {
                    showNotification("Investment capacity is full.", "error");
                    return;
                }

                maxAmount = Math.min(maxAmount, remaining);
            }

            const amountInput = document.getElementById("transferAmount");
            if (amountInput) {
                amountInput.value = maxAmount;
            }

            updateTransferCapacityBox();
            showNotification("Maximum transferable amount selected.", "success");
        }

        function buildTransferRequest() {
            const fromType = document.getElementById("fromWallet")?.value;
            const toType = document.getElementById("toWallet")?.value;
            const amount = Number(document.getElementById("transferAmount")?.value);
            const description = document.getElementById("transferDescription")?.value.trim() || "";

            if (!allowedTransfers[fromType] || !allowedTransfers[fromType].includes(toType)) {
                showNotification("This wallet transfer is not allowed", "error");
                return null;
            }

            if (!walletsMap[fromType] || !walletsMap[toType]) {
                showNotification("Wallet information not found", "error");
                return null;
            }

            if (!amount || amount <= 0) {
                showNotification("Invalid amount", "error");
                return null;
            }

            if (amount > Number(walletsMap[fromType].balance || 0)) {
                showNotification("Insufficient balance", "error");
                return null;
            }

            if (isTransferToInvest()) {
                if (!currentInvestmentCapacity || !currentInvestmentCapacity.isConfigured) {
                    showNotification("Investment capacity is not configured.", "error");
                    return null;
                }

                if (!currentInvestmentCapacity.isActive) {
                    showNotification("Investment capacity is inactive.", "error");
                    return null;
                }

                const remaining = Number(currentInvestmentCapacity.remainingCapacity || 0);

                if (remaining <= 0) {
                    showNotification("Investment capacity is full.", "error");
                    return null;
                }

                if (amount > remaining) {
                    showNotification(
                        `Amount exceeds remaining investment capacity. Remaining: ${formatMoney(remaining)} USDT`,
                        "error"
                    );
                    return null;
                }
            }

            return {
                fromType,
                toType,
                amount,
                description,
                fee: 0,
                payload: {
                    fromWalletId: walletsMap[fromType].walletId,
                    toWalletId: walletsMap[toType].walletId,
                    amount,
                    description
                }
            };
        }

        function submitTransfer(event) {
            event.preventDefault();

            if (isTransferSubmitting) {
                return;
            }

            const request = buildTransferRequest();

            if (!request) {
                return;
            }

            pendingTransferRequest = request;
            openTransferConfirmModal(request);
        }

        function openTransferConfirmModal(request) {
            document.getElementById("confirmFromWallet").innerText = getWalletDisplayName(request.fromType);
            document.getElementById("confirmToWallet").innerText = getWalletDisplayName(request.toType);
            document.getElementById("confirmAmount").innerText = formatMoney(request.amount) + " USDT";
            document.getElementById("confirmFee").innerText = formatMoney(request.fee || 0) + " USDT";

            const descriptionBox = document.getElementById("confirmDescriptionBox");
            const descriptionText = document.getElementById("confirmDescription");

            if (request.description) {
                descriptionText.innerText = request.description;
                descriptionBox.style.display = "block";
            } else {
                descriptionText.innerText = "-";
                descriptionBox.style.display = "none";
            }

            document.getElementById("transferConfirmModal").style.display = "flex";
        }

        async function confirmTransferFinal() {
            if (!pendingTransferRequest || isTransferSubmitting) {
                return;
            }

            const submitBtn = document.getElementById("finalConfirmTransferBtn");

            isTransferSubmitting = true;
            submitBtn.disabled = true;
            submitBtn.innerText = "Transferring...";

            try {
                const result = await api("/api/wallet/transfer", {
                    method: "POST",
                    body: JSON.stringify(pendingTransferRequest.payload)
                });

                if (!result || !result.success) {
                    const message = result?.message || "Transfer failed";

                    if (message.includes("No active contract")) {
                        window.location.href = "/contracts";
                        return;
                    }

                    showNotification(message, "error");
                    return;
                }

                showNotification(result.message || "Transfer completed", "success");
                closeTransferConfirmModal();
                resetWalletTransferForm();

                await loadWallets();
                await loadCurrentInvestmentCapacity();
                await loadMyInvestmentWaitListStatus();
            } catch (error) {
                showNotification(error.message || "Transfer failed", "error");
            } finally {
                isTransferSubmitting = false;
                pendingTransferRequest = null;
                submitBtn.disabled = false;
                submitBtn.innerText = "Confirm & Transfer";
            }
        }

        function getWalletDisplayName(walletType) {
            const names = {
                Main: "Main Wallet",
                Invest: "Investing Wallet",
                Profit: "Profit Wallet",
                Referral: "Referral Wallet"
            };

            return names[walletType] || walletType || "-";
        }
        function handleInternalReceiverInput() {
            if (internalTransferLocked) {
                return;
            }

            selectedInternalReceiver = null;
            selectedInternalTransferVerificationId = null;
            internalTransferVerifiedAmount = 0;

            hideInternalReceiverPreview();
            hideInternalTransferDetails();
            hideInternalTransferVerificationBox();

            const query = document.getElementById("internalReceiverQuery").value.trim();

            clearTimeout(internalReceiverLookupTimer);

            if (!query) {
                showInternalReceiverMessage("", "");
                return;
            }

            if (query.length < 3) {
                showInternalReceiverMessage("Enter at least 3 characters to search receiver.", "muted");
                return;
            }

            showInternalReceiverMessage("Checking receiver...", "muted");

            internalReceiverLookupTimer = setTimeout(() => {
                lookupInternalReceiver();
            }, 700);
        }
        async function lookupInternalReceiver() {
            const input = document.getElementById("internalReceiverQuery");
            const btn = document.getElementById("checkInternalReceiverBtn");

            const query = input.value.trim();
                    if (internalTransferLocked) {
            showNotification("Please reset current verification before changing receiver.", "warning");
            return;
        }
            selectedInternalReceiver = null;
            hideInternalReceiverPreview();

            if (!query) {
                showInternalReceiverMessage("Receiver UID or email is required.", "error");
                return;
            }

            btn.disabled = true;
            btn.innerText = "Checking...";

            showInternalReceiverMessage("Checking receiver...", "muted");

            try {
                const result = await api(
                    `/api/wallet/internal-transfer/recipient?query=${encodeURIComponent(query)}`
                );

                if (!result || !result.success) {
                    showInternalReceiverMessage(result?.message || "Receiver not found.", "error");
                    return;
                }

                selectedInternalReceiver = result.data;

                renderInternalReceiverPreview(selectedInternalReceiver);

                showInternalReceiverMessage("", "");

            } catch (error) {
                showInternalReceiverMessage(error.message || "Receiver not found.", "error");
            } finally {
                btn.disabled = false;
                btn.innerText = "Check";
            }
        }

        function renderInternalReceiverPreview(receiver) {
            if (!receiver) {
                hideInternalReceiverPreview();
                hideInternalTransferDetails();
                return;
            }

            document.getElementById("internalReceiverFullName").innerText =
                receiver.fullName || "-";

            document.getElementById("internalReceiverUid").innerText =
                receiver.uid || "-";

            document.getElementById("internalReceiverEmail").innerText =
                receiver.email || "-";

            document.getElementById("internalReceiverPreview").style.display = "flex";

            showInternalTransferDetails();
        }
        function hideInternalReceiverPreview() {
            const preview = document.getElementById("internalReceiverPreview");

            if (preview) {
                preview.style.display = "none";
            }

            const fullName = document.getElementById("internalReceiverFullName");
            const uid = document.getElementById("internalReceiverUid");
            const email = document.getElementById("internalReceiverEmail");

            if (fullName) fullName.innerText = "-";
            if (uid) uid.innerText = "-";
            if (email) email.innerText = "-";
        }

        function showInternalReceiverMessage(message, type) {
            const messageBox = document.getElementById("internalReceiverMessage");

            if (!messageBox) {
                return;
            }

            if (!message) {
                messageBox.innerText = "";
                messageBox.style.display = "none";
                messageBox.className = "internal-receiver-message";
                return;
            }

            messageBox.innerText = message;
            messageBox.style.display = "block";
            messageBox.className = `internal-receiver-message ${type || "muted"}`;
        }
                function showInternalTransferDetails() {
            const details = document.getElementById("internalTransferDetails");

            if (!details) return;

            const mainWallet = walletsMap["Main"];
            const balance = Number(mainWallet?.balance || 0);

            document.getElementById("internalTransferMainBalance").innerText =
                formatMoney(balance) + " USDT";

            details.style.display = "block";
        }

        function hideInternalTransferDetails() {
            const details = document.getElementById("internalTransferDetails");

            if (details) {
                details.style.display = "none";
            }

            const amountInput = document.getElementById("internalTransferAmount");
            const descriptionInput = document.getElementById("internalTransferDescription");

            if (amountInput) amountInput.value = "";
            if (descriptionInput) descriptionInput.value = "";
        }

        function hideInternalTransferVerificationBox() {
            const box = document.getElementById("internalTransferVerificationBox");

            if (box) {
                box.style.display = "none";
            }

            const codeInput = document.getElementById("internalTransferCode");

            if (codeInput) {
                codeInput.value = "";
            }
        }

        function setInternalTransferLocked(isLocked) {
            internalTransferLocked = isLocked;

            const receiverInput = document.getElementById("internalReceiverQuery");
            const checkBtn = document.getElementById("checkInternalReceiverBtn");
            const amountInput = document.getElementById("internalTransferAmount");
            const descriptionInput = document.getElementById("internalTransferDescription");
            const sendCodeBtn = document.getElementById("sendInternalTransferCodeBtn");

            if (receiverInput) receiverInput.disabled = isLocked;
            if (checkBtn) checkBtn.disabled = isLocked;
            if (amountInput) amountInput.disabled = isLocked;
            if (descriptionInput) descriptionInput.disabled = isLocked;
            if (sendCodeBtn) sendCodeBtn.style.display = isLocked ? "none" : "inline-flex";
        }

        function resetInternalTransferVerification() {
            selectedInternalTransferVerificationId = null;
            internalTransferVerifiedAmount = 0;

            setInternalTransferLocked(false);
            hideInternalTransferVerificationBox();

            showNotification("You can now change receiver or amount and request a new code.", "success");
        }

        async function sendInternalTransferVerificationCode() {
            if (!selectedInternalReceiver) {
                showNotification("Please select a valid receiver first.", "error");
                return;
            }

            const amountInput = document.getElementById("internalTransferAmount");
            const descriptionInput = document.getElementById("internalTransferDescription");
            const btn = document.getElementById("sendInternalTransferCodeBtn");

            const amount = Number(amountInput.value || 0);
            const description = descriptionInput.value.trim();

            const mainWallet = walletsMap["Main"];
            const mainBalance = Number(mainWallet?.balance || 0);

            if (!amount || amount <= 0) {
                showNotification("Please enter a valid amount.", "error");
                return;
            }

            if (amount > mainBalance) {
                showNotification("Amount is greater than your Main Wallet balance.", "error");
                return;
            }

            const confirmed = await showConfirm(
                `Send verification code for transferring ${formatMoney(amount)} USDT to UID ${selectedInternalReceiver.uid}?`,
                "Internal Transfer Verification"
            );

            if (!confirmed) {
                return;
            }

            btn.disabled = true;
            btn.innerText = "Sending...";

            try {
                const result = await api("/api/wallet/internal-transfer/send-code", {
                    method: "POST",
                    body: JSON.stringify({
                        receiver: selectedInternalReceiver.uid,
                        amount,
                        description
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not send verification code.", "error");
                    return;
                }

                selectedInternalTransferVerificationId = result.data.verificationId;
                internalTransferVerifiedAmount = Number(result.data.amount || amount);

                document.getElementById("internalTransferVerifyReceiver").innerText =
                    `${result.data.receiverFullName || "-"} / UID: ${result.data.receiverUid}`;

                document.getElementById("internalTransferVerifyAmount").innerText =
                    formatMoney(internalTransferVerifiedAmount) + " USDT";

                setInternalTransferLocked(true);

                document.getElementById("internalTransferVerificationBox").style.display = "block";

                showNotification(result.message || "Verification code sent to your email.", "success");

                setTimeout(() => {
                    document.getElementById("internalTransferCode").focus();
                }, 100);

            } catch (error) {
                showNotification(error.message || "Could not send verification code.", "error");
            } finally {
                btn.disabled = false;
                btn.innerText = "Send Verification Code";
            }
        }

        async function confirmInternalTransfer() {
            const codeInput = document.getElementById("internalTransferCode");
            const btn = document.getElementById("confirmInternalTransferBtn");

            const code = codeInput.value.trim();

            if (!selectedInternalTransferVerificationId) {
                showNotification("Verification request was not created.", "error");
                return;
            }

            if (!code) {
                showNotification("Verification code is required.", "error");
                return;
            }

            if (code.length !== 6) {
                showNotification("Verification code must be 6 digits.", "error");
                return;
            }

            btn.disabled = true;
            btn.innerText = "Confirming...";

            try {
                const result = await api("/api/wallet/internal-transfer/confirm", {
                    method: "POST",
                    body: JSON.stringify({
                        verificationId: selectedInternalTransferVerificationId,
                        code
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Internal transfer failed.", "error");
                    return;
                }

                showNotification(result.message || "Internal transfer completed.", "success");

                resetInternalTransferFormAfterSuccess();

                await loadWallets();

            } catch (error) {
                showNotification(error.message || "Internal transfer failed.", "error");
            } finally {
                btn.disabled = false;
                btn.innerText = "Confirm Internal Transfer";
            }
        }

        function resetInternalTransferFormAfterSuccess() {
            selectedInternalReceiver = null;
            selectedInternalTransferVerificationId = null;
            internalTransferVerifiedAmount = 0;

            setInternalTransferLocked(false);

            const receiverInput = document.getElementById("internalReceiverQuery");

            if (receiverInput) {
                receiverInput.value = "";
            }

            hideInternalReceiverPreview();
            hideInternalTransferDetails();
            hideInternalTransferVerificationBox();
            showInternalReceiverMessage("", "");
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }
    </script>
}
