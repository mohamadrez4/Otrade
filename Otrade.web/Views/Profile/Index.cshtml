
<div class="profile-page">

    <div id="forcedPasswordBanner"
         class="profile-2fa-recovery-warning"
         hidden>

        <span>!</span>

        <p>
            For security, you must change your password before using
            the rest of your account. After changing it successfully,
            normal access will be restored.
        </p>

    </div>

    <!-- Profile Info -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>Profile Information</h3>
                <p>View your account information and verification status.</p>
            </div>
        </div>

        <div id="profileMessage" class="profile-message">
            Loading profile...
        </div>

        <div id="profileContent" class="profile-grid" style="display:none;">
            <div class="profile-info-item">
                <span>First Name</span>
                <strong id="firstName">-</strong>
            </div>

            <div class="profile-info-item">
                <span>Last Name</span>
                <strong id="lastName">-</strong>
            </div>

            <div class="profile-info-item">
                <span>Email</span>
                <strong id="email">-</strong>
            </div>

            <div class="profile-info-item">
                <span>Referral Code</span>
                <strong id="referralCode">-</strong>
            </div>

            <div class="profile-info-item">
                <span>KYC Status</span>
                <strong id="kycStatus" class="profile-status">-</strong>
            </div>
        </div>
    </div>


    <!-- Google Authenticator -->
    <div class="panel-card profile-2fa-card">

        <div class="profile-header profile-2fa-header">

            <div>
                <h3>Google Authenticator</h3>

                <p>
                    Protect login and withdrawal operations with a
                    time-based 6-digit security code.
                </p>
            </div>

            <span id="twoFactorHeaderStatus"
                  class="profile-2fa-badge loading">
                Checking...
            </span>

        </div>

        <div id="twoFactorLoading"
             class="profile-2fa-loading">
            Checking Google Authenticator status...
        </div>

        <!-- Disabled State -->
        <section id="twoFactorDisabledState"
                 class="profile-2fa-state"
                 hidden>

            <div class="profile-2fa-disabled-hero">

                <div class="profile-2fa-shield">
                    2FA
                </div>

                <div class="profile-2fa-disabled-copy">

                    <span>Account Protection</span>

                    <h4>Google Authenticator is disabled</h4>

                    <p id="twoFactorDisabledDescription">
                        Add an extra security layer to your account.
                        After activation, a code from your phone will be
                        required for login and withdrawal.
                    </p>

                </div>

            </div>

            <div class="profile-2fa-benefits">

                <div>
                    <strong>Login Protection</strong>

                    <span>
                        A password alone will not be enough to access
                        your account.
                    </span>
                </div>

                <div>
                    <strong>Withdrawal Protection</strong>

                    <span>
                        Sensitive withdrawal requests require a code
                        from your authenticator app.
                    </span>
                </div>

                <div>
                    <strong>Offline Codes</strong>

                    <span>
                        Google Authenticator generates codes even when
                        your phone has no internet connection.
                    </span>
                </div>

            </div>

            <button id="startTwoFactorSetupBtn"
                    type="button"
                    class="panel-primary-btn profile-2fa-main-btn">
                Enable Google Authenticator
            </button>

        </section>

        <!-- Setup State -->
        <section id="twoFactorSetupState"
                 class="profile-2fa-state"
                 hidden>

            <div class="profile-2fa-setup-notice">

                <span>!</span>

                <p>
                    Do not share the QR code or manual setup key.
                    Anyone with this information can generate your
                    authentication codes.
                </p>

            </div>

            <div class="profile-2fa-setup-grid">

                <div class="profile-2fa-qr-column">

                    <span class="profile-2fa-step-label">
                        Step 1
                    </span>

                    <h4 id="twoFactorSetupScanTitle">Scan the QR code</h4>

                    <div class="profile-2fa-qr-box">

                        <img id="twoFactorQrImage"
                             alt="Google Authenticator setup QR code" />

                    </div>

                    <p id="twoFactorSetupScanHelp">
                        Open Google Authenticator, select
                        <strong>Add a code</strong>, and scan this QR code.
                    </p>

                </div>

                <div class="profile-2fa-verify-column">

                    <span class="profile-2fa-step-label">
                        Step 2
                    </span>

                    <h4 id="twoFactorSetupConfirmTitle">Confirm the setup</h4>

                    <div class="profile-2fa-account-info">

                        <div>
                            <span>Issuer</span>

                            <strong id="twoFactorIssuer">
                                Otrade
                            </strong>
                        </div>

                        <div>
                            <span>Account</span>

                            <strong id="twoFactorAccountName">
                                -
                            </strong>
                        </div>

                    </div>

                    <div class="profile-2fa-manual-key">

                        <div>
                            <span>Manual setup key</span>

                            <code id="twoFactorManualKey">
                                -
                            </code>
                        </div>

                        <button id="copyTwoFactorKeyBtn"
                                type="button">
                            Copy
                        </button>

                    </div>

                    <div class="profile-2fa-expiry">

                        <span>Setup expires in</span>

                        <strong id="twoFactorSetupCountdown">
                            15:00
                        </strong>

                    </div>

                    <div class="profile-form-group">

                        <label for="twoFactorSetupCode">
                            6-digit authentication code
                        </label>

                        <input id="twoFactorSetupCode"
                               class="panel-input profile-2fa-code-input"
                               type="text"
                               maxlength="6"
                               inputmode="numeric"
                               autocomplete="one-time-code"
                               placeholder="000000" />

                        <small id="twoFactorSetupCodeHelp">
                            Enter the current code shown in Google
                            Authenticator.
                        </small>

                    </div>

                    <div class="profile-2fa-setup-actions">

                        <button id="confirmTwoFactorBtn"
                                type="button"
                                class="panel-primary-btn">
                            Verify and Enable
                        </button>

                        <button id="restartTwoFactorSetupBtn"
                                type="button"
                                class="profile-2fa-secondary-btn">
                            Generate New QR
                        </button>

                        <button id="cancelTwoFactorSetupBtn"
                                type="button"
                                class="profile-2fa-link-btn">
                            Cancel
                        </button>

                    </div>

                </div>

            </div>

        </section>

        <!-- Enabled State -->
        <section id="twoFactorEnabledState"
                 class="profile-2fa-state"
                 hidden>

            <div class="profile-2fa-enabled-hero">

                <div class="profile-2fa-shield enabled">
                    ✓
                </div>

                <div>

                    <span>Account Protection</span>

                    <h4>Google Authenticator is enabled</h4>

                    <p>
                        Your account now requires a time-based security
                        code for protected operations.
                    </p>

                </div>

            </div>

            <div class="profile-2fa-enabled-metrics">

                <div>
                    <span>Enabled At</span>

                    <strong id="twoFactorEnabledAt">
                        -
                    </strong>
                </div>

                <div>
                    <span>Recovery Codes Remaining</span>

                    <strong id="twoFactorRecoveryCount">
                        0
                    </strong>
                </div>

                <div>
                    <span>Code Refresh</span>

                    <strong>
                        Every 30 Seconds
                    </strong>
                </div>

            </div>

            <div id="twoFactorRecoveryWarning"
                 class="profile-2fa-recovery-warning"
                 hidden>

                <span>!</span>

                <p>
                    You have very few recovery codes remaining.
                    Generate a new set and store it securely.
                </p>

            </div>

            <div class="profile-2fa-enabled-actions">

                <button id="regenerateRecoveryCodesBtn"
                        type="button"
                        class="profile-2fa-secondary-btn">
                    Generate New Recovery Codes
                </button>

                <button id="replaceTwoFactorBtn"
                        type="button"
                        class="profile-2fa-secondary-btn">
                    Replace Google Authenticator
                </button>

                <button id="disableTwoFactorBtn"
                        type="button"
                        class="profile-2fa-danger-btn">
                    Disable Google Authenticator
                </button>

            </div>

        </section>

    </div>

    <!-- USDT BEP20 Withdrawal Address -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>USDT Withdrawal Address</h3>
                <p>
                    This address will be used for USDT withdrawals through
                    the BNB Smart Chain (BEP20) network.
                </p>
            </div>
        </div>

        <form id="walletAddressForm"
              class="profile-form"
              autocomplete="off">

            <div class="profile-form-group">
                <label>
                    Withdrawal Asset &amp; Network
                </label>

                <div class="profile-usdt-network-box">

                    <div class="profile-usdt-network-icon">
                        USDT
                    </div>

                    <div class="profile-usdt-network-info">
                        <strong>USDT — Tether USD</strong>

                        <span>
                            BNB Smart Chain (BEP20)
                        </span>
                    </div>

                    <span class="profile-usdt-network-status">
                        Supported
                    </span>

                </div>

                <input id="network"
                       type="hidden"
                       value="BEP20" />

                <small class="profile-usdt-network-note">
                    Enter only a USDT deposit address that supports the
                    <strong>BNB Smart Chain (BEP20)</strong> network.
                </small>
            </div>

            <div class="profile-form-group">
                <label for="walletAddress">
                    USDT Withdrawal Address (BEP20)
                </label>

                <div class="profile-wallet-address-wrap">

                    <input id="walletAddress"
                           class="panel-input"
                           type="text"
                           maxlength="42"
                           autocomplete="new-password"
                           spellcheck="false"
                           inputmode="text"
                           placeholder="0x..."
                           required />

                    <button type="button"
                            id="clearWalletAddressBtn"
                            class="profile-wallet-clear-btn">
                        Clear
                    </button>

                </div>

                <div class="profile-wallet-address-help">

                    <span id="walletAddressValidationText">
                        Enter a 42-character USDT BEP20 address.
                    </span>

                    <span id="walletAddressCounter">
                        0 / 42
                    </span>

                </div>

                <div class="profile-usdt-warning">

                    <span>!</span>

                    <p>
                        Make sure the selected deposit asset is
                        <strong>USDT</strong> and the selected network is
                        <strong>BNB Smart Chain (BEP20)</strong>.
                        Using another asset or network may result in permanent
                        loss of funds.
                    </p>

                </div>
            </div>

            <button id="saveWalletBtn"
                    type="submit"
                    class="panel-primary-btn">
                Save USDT BEP20 Address
            </button>
        </form>
    </div>

    <!-- KYC -->
    <div class="panel-card">
        <div class="profile-header">
            <div>
                <h3>KYC Verification</h3>
                <p>Upload only the documents that are missing or rejected.</p>
            </div>
        </div>

        <div id="kycMessage" class="profile-alert" style="display:none;"></div>

        <form id="kycForm" class="profile-form" autocomplete="off">

            <!-- National ID -->
            <div id="nationalIdGroup" class="profile-form-group">
                <label for="nationalIdImage">National ID Image</label>

                <div class="kyc-file-picker">
                    <input id="nationalIdImage"
                           class="kyc-file-input"
                           type="file"
                           accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" />

                    <label for="nationalIdImage" class="kyc-file-btn">
                        Choose File
                    </label>

                    <span id="nationalIdFileName" class="kyc-file-name">
                        No file chosen
                    </span>
                </div>

                <span id="nationalIdStatus" class="profile-status"></span>

                <div id="nationalIdRejectReasonBox"
                     class="kyc-reject-reason-box"
                     style="display:none;">
                    <strong>National ID Reject Reason</strong>
                    <p id="nationalIdRejectReasonText"></p>
                </div>
            </div>

            <!-- Selfie -->
            <div id="selfieGroup" class="profile-form-group">
                <label for="selfieImage">Selfie Image</label>

                <div class="kyc-file-picker">
                    <input id="selfieImage"
                           class="kyc-file-input"
                           type="file"
                           accept=".jpg,.jpeg,.png,.pdf,image/jpeg,image/png,application/pdf" />

                    <label for="selfieImage" class="kyc-file-btn">
                        Choose File
                    </label>

                    <span id="selfieFileName" class="kyc-file-name">
                        No file chosen
                    </span>
                </div>

                <span id="selfieStatus" class="profile-status"></span>

                <div id="selfieRejectReasonBox"
                     class="kyc-reject-reason-box"
                     style="display:none;">
                    <strong>Selfie Reject Reason</strong>
                    <p id="selfieRejectReasonText"></p>
                </div>
            </div>

            <button id="submitKycBtn"
                    type="submit"
                    class="panel-primary-btn kyc-submit-hidden"
                    hidden>
                Submit KYC
            </button>
        </form>
    </div>

    <!-- Change Password -->
    <div id="changePasswordCard"
         class="panel-card">
        <div class="profile-header">
            <div>
                <h3>Change Password</h3>
                <p>Update your account password.</p>
            </div>
        </div>

        <div id="passwordMessage" class="profile-alert" style="display:none;"></div>

        <form id="passwordForm" class="profile-form" autocomplete="off">
            <div class="profile-form-group">
                <label for="currentPassword">Current Password</label>
                <div class="pre-password-wrap">
                    <input type="password"
                           class="form-control auth-input"
                           id="currentPassword"
                           placeholder="Current password" />

                    <button type="button"
                            class="pre-eye-btn"
                            onclick="togglePassword('currentPassword', this)"
                            aria-label="Show password">
                        <span class="eye-open">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 5C7 5 2.7 8.1 1 12c1.7 3.9 6 7 11 7s9.3-3.1 11-7c-1.7-3.9-6-7-11-7Zm0 11.5A4.5 4.5 0 1 1 12 7.5a4.5 4.5 0 0 1 0 9Zm0-2A2.5 2.5 0 1 0 12 9.5a2.5 2.5 0 0 0 0 5Z" />
                            </svg>
                        </span>

                        <span class="eye-closed">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3.3 2 2 3.3l3 3C3.2 7.6 1.8 9.6 1 12c1.7 3.9 6 7 11 7 2 0 3.9-.5 5.5-1.3l3.2 3.2 1.3-1.3L3.3 2Zm8.7 15c-3.8 0-7.1-2.1-8.8-5 .7-1.3 1.8-2.5 3.1-3.4l2.2 2.2A4.4 4.4 0 0 0 7.5 12 4.5 4.5 0 0 0 12 16.5c.4 0 .8-.1 1.2-.2l2 2A10.2 10.2 0 0 1 12 17Zm2.4-3.8c.1-.4.1-.8.1-1.2A4.5 4.5 0 0 0 10 7.5c-.4 0-.8.1-1.2.2L7.2 6.1C8.7 5.4 10.3 5 12 5c5 0 9.3 3.1 11 7a12.5 12.5 0 0 1-3.2 4.1l-2.1-2.1c.5-.6.8-1.3.8-2.1a2.5 2.5 0 0 0-2.5-2.5c-.8 0-1.5.3-2.1.8l-1.9-1.9c.1 0 .2-.1.3-.1A2.5 2.5 0 0 1 14.5 12c0 .1 0 .2-.1.3Z" />
                            </svg>
                        </span>
                    </button>
                </div>

            </div>

            <div class="profile-form-group">
                <label for="newPassword">New Password</label>

                <div class="pre-password-wrap">
                    <input type="password"
                           class="form-control auth-input"
                           id="newPassword"
                           placeholder="New password" />

                    <button type="button"
                            class="pre-eye-btn"
                            onclick="togglePassword('newPassword', this)"
                            aria-label="Show password">
                        <span class="eye-open">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 5C7 5 2.7 8.1 1 12c1.7 3.9 6 7 11 7s9.3-3.1 11-7c-1.7-3.9-6-7-11-7Zm0 11.5A4.5 4.5 0 1 1 12 7.5a4.5 4.5 0 0 1 0 9Zm0-2A2.5 2.5 0 1 0 12 9.5a2.5 2.5 0 0 0 0 5Z" />
                            </svg>
                        </span>

                        <span class="eye-closed">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3.3 2 2 3.3l3 3C3.2 7.6 1.8 9.6 1 12c1.7 3.9 6 7 11 7 2 0 3.9-.5 5.5-1.3l3.2 3.2 1.3-1.3L3.3 2Zm8.7 15c-3.8 0-7.1-2.1-8.8-5 .7-1.3 1.8-2.5 3.1-3.4l2.2 2.2A4.4 4.4 0 0 0 7.5 12 4.5 4.5 0 0 0 12 16.5c.4 0 .8-.1 1.2-.2l2 2A10.2 10.2 0 0 1 12 17Zm2.4-3.8c.1-.4.1-.8.1-1.2A4.5 4.5 0 0 0 10 7.5c-.4 0-.8.1-1.2.2L7.2 6.1C8.7 5.4 10.3 5 12 5c5 0 9.3 3.1 11 7a12.5 12.5 0 0 1-3.2 4.1l-2.1-2.1c.5-.6.8-1.3.8-2.1a2.5 2.5 0 0 0-2.5-2.5c-.8 0-1.5.3-2.1.8l-1.9-1.9c.1 0 .2-.1.3-.1A2.5 2.5 0 0 1 14.5 12c0 .1 0 .2-.1.3Z" />
                            </svg>
                        </span>
                    </button>
                </div>
            </div>

            <button id="changePasswordBtn" type="submit" class="panel-primary-btn">
                Change Password
            </button>
        </form>
    </div>


    <!-- Two-Factor Security Action Modal -->
    <div id="twoFactorActionModal"
         class="profile-2fa-modal"
         hidden>

        <div class="profile-2fa-modal-backdrop"
             data-close-two-factor-action>
        </div>

        <div class="profile-2fa-modal-dialog"
             role="dialog"
             aria-modal="true"
             aria-labelledby="twoFactorActionTitle">

            <div class="profile-2fa-modal-header">

                <div>
                    <span class="profile-2fa-step-label">
                        Security Verification
                    </span>

                    <h4 id="twoFactorActionTitle">
                        Confirm Action
                    </h4>
                </div>

                <button type="button"
                        class="profile-2fa-modal-close"
                        data-close-two-factor-action
                        aria-label="Close">
                    ×
                </button>

            </div>

            <p id="twoFactorActionDescription"
               class="profile-2fa-modal-description">
            </p>

            <form id="twoFactorActionForm"
                  class="profile-2fa-action-form"
                  autocomplete="off">

                <div id="twoFactorActionPasswordGroup"
                     class="profile-form-group"
                     hidden>

                    <label for="twoFactorActionPassword">
                        Current Password
                    </label>

                    <div class="pre-password-wrap">

                        <input id="twoFactorActionPassword"
                               type="password"
                               class="form-control auth-input"
                               autocomplete="current-password"
                               placeholder="Enter your current password" />

                        <button type="button"
                                class="pre-eye-btn"
                                onclick="togglePassword('twoFactorActionPassword', this)"
                                aria-label="Show password">

                            <span class="eye-open">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 5C7 5 2.7 8.1 1 12c1.7 3.9 6 7 11 7s9.3-3.1 11-7c-1.7-3.9-6-7-11-7Zm0 11.5A4.5 4.5 0 1 1 12 7.5a4.5 4.5 0 0 1 0 9Zm0-2A2.5 2.5 0 1 0 12 9.5a2.5 2.5 0 0 0 0 5Z" />
                                </svg>
                            </span>

                            <span class="eye-closed">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3.3 2 2 3.3l3 3C3.2 7.6 1.8 9.6 1 12c1.7 3.9 6 7 11 7 2 0 3.9-.5 5.5-1.3l3.2 3.2 1.3-1.3L3.3 2Zm8.7 15c-3.8 0-7.1-2.1-8.8-5 .7-1.3 1.8-2.5 3.1-3.4l2.2 2.2A4.4 4.4 0 0 0 7.5 12 4.5 4.5 0 0 0 12 16.5c.4 0 .8-.1 1.2-.2l2 2A10.2 10.2 0 0 1 12 17Zm2.4-3.8c.1-.4.1-.8.1-1.2A4.5 4.5 0 0 0 10 7.5c-.4 0-.8.1-1.2.2L7.2 6.1C8.7 5.4 10.3 5 12 5c5 0 9.3 3.1 11 7a12.5 12.5 0 0 1-3.2 4.1l-2.1-2.1c.5-.6.8-1.3.8-2.1a2.5 2.5 0 0 0-2.5-2.5c-.8 0-1.5.3-2.1.8l-1.9-1.9c.1 0 .2-.1.3-.1A2.5 2.5 0 0 1 14.5 12c0 .1 0 .2-.1.3Z" />
                                </svg>
                            </span>

                        </button>

                    </div>

                </div>

                <div class="profile-form-group">

                    <label id="twoFactorActionCodeLabel"
                           for="twoFactorActionCode">
                        Authentication Code
                    </label>

                    <input id="twoFactorActionCode"
                           class="panel-input profile-2fa-code-input"
                           type="text"
                           maxlength="14"
                           inputmode="text"
                           autocomplete="one-time-code"
                           placeholder="Enter your code" />

                    <small id="twoFactorActionCodeHelp">
                    </small>

                </div>

                <div class="profile-2fa-modal-actions">

                    <button type="button"
                            class="profile-2fa-secondary-btn"
                            data-close-two-factor-action>
                        Cancel
                    </button>

                    <button id="twoFactorActionSubmitBtn"
                            type="submit"
                            class="panel-primary-btn">
                        Confirm
                    </button>

                </div>

            </form>

        </div>

    </div>

    <!-- Recovery Codes Modal -->
    <div id="recoveryCodesModal"
         class="profile-2fa-modal"
         hidden>

        <div class="profile-2fa-modal-backdrop">
        </div>

        <div class="profile-2fa-modal-dialog recovery"
             role="dialog"
             aria-modal="true"
             aria-labelledby="recoveryCodesTitle">

            <div class="profile-2fa-modal-header">

                <div>
                    <span class="profile-2fa-step-label">
                        One-Time Display
                    </span>

                    <h4 id="recoveryCodesTitle">
                        Save Your Recovery Codes
                    </h4>
                </div>

            </div>

            <div class="profile-2fa-recovery-alert">

                <span>!</span>

                <p>
                    Each recovery code can be used only once.
                    Store these codes somewhere safe. They will not be
                    shown again after you close this window.
                </p>

            </div>

            <div id="recoveryCodesList"
                 class="profile-2fa-recovery-grid">
            </div>

            <div class="profile-2fa-recovery-tools">

                <button id="copyRecoveryCodesBtn"
                        type="button"
                        class="profile-2fa-secondary-btn">
                    Copy All
                </button>

                <button id="downloadRecoveryCodesBtn"
                        type="button"
                        class="profile-2fa-secondary-btn">
                    Download TXT
                </button>

            </div>

            <label class="profile-2fa-saved-check">

                <input id="recoveryCodesSavedCheck"
                       type="checkbox" />

                <span>
                    I have saved these recovery codes in a secure place.
                </span>

            </label>

            <button id="closeRecoveryCodesBtn"
                    type="button"
                    class="panel-primary-btn profile-2fa-full-btn"
                    disabled>
                Finish
            </button>

        </div>

    </div>


</div>

@section Scripts {
    <script>
        // ---------------------
        // Elements
        // ---------------------
        const profileMessage = document.getElementById("profileMessage");
        const profileContent = document.getElementById("profileContent");

        const forcedPasswordBanner =
            document.getElementById("forcedPasswordBanner");

        const changePasswordCard =
            document.getElementById("changePasswordCard");

        const firstName = document.getElementById("firstName");
        const lastName = document.getElementById("lastName");
        const email = document.getElementById("email");
        const referralCode = document.getElementById("referralCode");
        const kycStatus = document.getElementById("kycStatus");

        const walletAddressForm = document.getElementById("walletAddressForm");
        const networkInput = document.getElementById("network");
