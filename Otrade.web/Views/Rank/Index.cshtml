@{
    ViewData["Title"] = "Rank";
}

<div class="rank-v2-page">

    <section class="panel-card rank-v2-header">

        <div>
            <span class="rank-v2-eyebrow">
                Membership Program
            </span>

            <h2>Rank Overview</h2>

            <p>
                Your rank is determined by the total Investing Wallet
                volume generated by you and your referral network.
            </p>
        </div>

        <a href="/referral"
           class="rank-v2-header-link">
            View Referral Network
        </a>

    </section>

    <section id="rankMessage"
             class="panel-card rank-v2-message">
        Loading rank information...
    </section>

    <div id="rankContent"
         class="rank-v2-content"
         style="display:none;">

        <div class="rank-v2-overview-grid">

            <!-- Current Rank -->

            <section class="panel-card rank-v2-current-card">

                <div class="rank-v2-card-header">

                    <div>
                        <span class="rank-v2-eyebrow">
                            Current Membership
                        </span>

                        <h3>Your Current Rank</h3>
                    </div>

                    <span id="currentRankBadge"
                          class="rank-v2-status-badge current">
                        Current
                    </span>

                </div>

                <div class="rank-v2-current-main">

                    <span class="rank-media-shell rank-media-current-shell">

                        <img id="currentRankImage"
                             class="rank-media-img"
                             src="/images/ranks/basic-rank.gif"
                             alt="Basic Rank" />

                    </span>

                    <div class="rank-v2-current-info">

                        <span>Current Rank</span>

                        <strong id="currentRankName">
                            -
                        </strong>

                        <p>
                            Your active profit rates and referral rewards
                            are based on this membership level.
                        </p>

                    </div>

                </div>

                <div class="rank-v2-volume-box">

                    <div>
                        <span>Total Network Volume</span>

                        <strong id="networkVolume">
                            $0.00
                        </strong>
                    </div>

                    <span class="rank-v2-volume-label">
                        Investing Wallet Volume
                    </span>

                </div>

            </section>

            <!-- Next Rank Progress -->

            <section class="panel-card rank-v2-progress-card">

                <div class="rank-v2-card-header">

                    <div>
                        <span class="rank-v2-eyebrow">
                            Rank Progress
                        </span>

                        <h3>Next Membership Level</h3>
                    </div>

                    <span id="progressPercent"
                          class="rank-v2-progress-percent">
                        0%
                    </span>

                </div>

                <div class="rank-v2-next-rank">

                    <div class="rank-v2-next-rank-copy">

                        <span>Next Rank</span>

                        <strong id="nextRankName">
                            -
                        </strong>

                    </div>

                    <span id="nextRankImageShell"
                          class="rank-media-shell rank-media-next-shell">

                        <img id="nextRankImage"
                             class="rank-media-img"
                             src="/images/ranks/bronze-rank.gif"
                             alt="Next Rank" />

                    </span>

                </div>
                <div class="rank-v2-progress-track">

                    <div id="rankProgressBar"
                         class="rank-v2-progress-bar"
                         style="width:0%;">
                    </div>

                </div>

                <div class="rank-v2-progress-footer">

                    <div>
                        <span>Remaining Volume</span>

                        <strong id="remainingVolume">
                            $0.00
                        </strong>
                    </div>

                    <div class="rank-v2-progress-target">
                        <span>Target Volume</span>

                        <strong id="nextRankRequiredVolume">
                            $0.00
                        </strong>
                    </div>

                </div>

                <p id="rankProgressDescription"
                   class="rank-v2-progress-description">
                    Increase your network investment volume to unlock
                    the next membership level.
                </p>

            </section>

        </div>

        <!-- Current Benefits -->

        <section class="panel-card rank-v2-benefits-section">

            <div class="rank-v2-section-header">

                <div>
                    <span class="rank-v2-eyebrow">
                        Current Benefits
                    </span>

                    <h3>Your Profit &amp; Reward Rates</h3>
                </div>

                <span id="benefitRankName"
                      class="rank-v2-section-badge">
                    -
                </span>

            </div>

            <div class="rank-v2-benefits-grid">

                <article class="rank-v2-benefit-card">

                    <span class="rank-v2-benefit-number">
                        01
                    </span>

                    <div>
                        <span>Daily Profit</span>

                        <strong id="dailyProfitPercent">
                            0%
                        </strong>
                    </div>

                </article>

                <article class="rank-v2-benefit-card">

                    <span class="rank-v2-benefit-number">
                        02
                    </span>

                    <div>
                        <span>Monthly Profit</span>

                        <strong id="monthlyProfitPercent">
                            0%
                        </strong>
                    </div>

                </article>

                <article class="rank-v2-benefit-card">

                    <span class="rank-v2-benefit-number">
                        03
                    </span>

                    <div>
                        <span>Referral Profit</span>

                        <strong id="referralProfitPercent">
                            0%
                        </strong>
                    </div>

                </article>

                <article class="rank-v2-benefit-card">

                    <span class="rank-v2-benefit-number">
                        04
                    </span>

                    <div>
                        <span>Referral Commission</span>

                        <strong id="referralCommissionPercent">
                            0%
                        </strong>
                    </div>

                </article>

            </div>

        </section>

        <!-- Rank Levels -->

        <section class="panel-card rank-v2-levels-section">

            <div class="rank-v2-section-header">

                <div>
                    <span class="rank-v2-eyebrow">
                        Membership Levels
                    </span>

                    <h3>Explore Rank Plans</h3>

                    <p>
                        Select a membership card to review its requirements,
                        profit rates, and referral rewards.
                    </p>
                </div>

            </div>

            <div id="rankCardsGrid"
                 class="rank-v2-cards-grid">
            </div>

            <div class="rank-v2-selected-detail">

                <div class="rank-v2-selected-header">

                    <div class="rank-v2-selected-title">

                        <span class="rank-media-shell rank-media-selected-shell">

                            <img id="selectedRankImage"
                                 class="rank-media-img"
                                 src="/images/ranks/basic-rank.gif"
                                 alt="Basic Rank" />

                        </span>
                        <div>
                            <span>Selected Membership</span>

                            <h3 id="selectedRankName">
                                Basic
                            </h3>
                        </div>

                    </div>

                    <span id="selectedRankStatus"
                          class="rank-v2-selected-status">
                        Available
                    </span>

                </div>

                <p id="selectedRankDescription"
                   class="rank-v2-selected-description">
                </p>

                <div class="rank-v2-selected-metrics">

                    <div>
                        <span>Required Volume</span>

                        <strong id="selectedRequiredVolume">
                            $0.00
                        </strong>
                    </div>

                    <div>
                        <span>Daily Profit</span>

                        <strong id="selectedDailyProfit">
                            0%
                        </strong>
                    </div>

                    <div>
                        <span>Monthly Profit</span>

                        <strong id="selectedMonthlyProfit">
                            0%
                        </strong>
                    </div>

                    <div>
                        <span>Referral Profit</span>

                        <strong id="selectedReferralProfit">
                            0%
                        </strong>
                    </div>

                    <div>
                        <span>Referral Commission</span>

                        <strong id="selectedReferralCommission">
                            0%
                        </strong>
                    </div>

                </div>

                <div class="rank-v2-selected-progress">

                    <div class="rank-v2-selected-progress-header">

                        <span>
                            Your progress toward this rank
                        </span>

                        <strong id="selectedProgressPercent">
                            0%
                        </strong>

                    </div>

                    <div class="rank-v2-progress-track">

                        <div id="selectedProgressBar"
                             class="rank-v2-progress-bar"
                             style="width:0%;">
                        </div>

                    </div>

                    <p id="selectedProgressText">
                        -
                    </p>

                </div>

            </div>

        </section>

    </div>

</div>

@section Scripts {

    <script>
        const rankDescriptions = {
            basic:
                "Basic is the starting membership level for every investor. " +
                "It provides access to daily investment profits and referral " +
                "rewards with no minimum network volume requirement.",

            bronze:
                "Bronze is the first upgraded membership level. It offers " +
                "higher daily returns and increased referral rewards for " +
                "investors who begin expanding their investment network.",

            silver:
                "Silver provides a balanced combination of stronger investment " +
                "returns and referral rewards. It is designed for members with " +
                "a growing personal and referral investment volume.",

            gold:
                "Gold is designed for committed investors seeking premium " +
                "returns and stronger referral benefits. This level provides " +
                "a significant increase in profit and commission rates.",

            diamond:
                "Diamond is the highest membership level and provides the " +
                "maximum available investment profit rates and referral rewards."
        };

        let rankOverviewData = null;
        let selectedRankId = null;

        document.addEventListener(
            "DOMContentLoaded",
            function () {
                checkAuth();
                loadRank();
            }
        );

        async function loadRank() {
            const message =
                document.getElementById("rankMessage");

            const content =
                document.getElementById("rankContent");

            message.style.display = "block";
            message.innerText =
                "Loading rank information...";

            content.style.display = "none";

            try {
                const result = await api(
                    "/api/rank/overview",
                    {
                        method: "GET"
                    }
                );

                if (!result || !result.success) {
                    throw new Error(
                        result?.message ||
                        "Could not load rank information."
                    );
                }

                rankOverviewData =
                    result.data || {};

                renderRankOverview(
                    rankOverviewData
                );

                message.style.display = "none";
                content.style.display = "block";

            } catch (error) {
                message.innerText =
                    error.message ||
                    "Could not load rank information.";

                message.style.display = "block";

                showNotification(
                    error.message ||
                    "Could not load rank information.",
                    "error"
                );
            }
        }

        function renderRankOverview(data) {
            const current = data.currentRank || null;
            const next = data.nextRank || null;
            const volume = Number(
                data.networkVolume || 0
            );

            const progress = Math.min(
                100,
                Math.max(
                    0,
                    Number(data.progressPercent || 0)
                )
            );

            document.getElementById(
                "currentRankName"
            ).innerText =
                current?.name || "-";
            setOtradeRankImage(
                 "currentRankImage",
                 current?.name || "Basic",
                 {
                     eager: true
                 }
                );
            document.getElementById(
                "benefitRankName"
            ).innerText =
                current?.name || "-";

            document.getElementById(
                "networkVolume"
            ).innerText =
                formatMoney(volume);

            document.getElementById(
                "nextRankName"
            ).innerText =
                next?.name || "Highest Rank";
        const nextRankImageShell =
            document.getElementById(
                "nextRankImageShell"
            );

        if (next) {
            nextRankImageShell.style.display =
                "inline-flex";

            setOtradeRankImage(
                "nextRankImage",
                next.name,
                {
                    eager: true
                }
            );
        } else {
            nextRankImageShell.style.display =
                "none";
        }
            document.getElementById(
                "progressPercent"
            ).innerText =
                formatPercent(progress);

            document.getElementById(
                "rankProgressBar"
            ).style.width =
                progress + "%";

            document.getElementById(
                "remainingVolume"
            ).innerText =
                next
                    ? formatMoney(
                        data.remainingVolume
                    )
                    : "$0.00";

            document.getElementById(
                "nextRankRequiredVolume"
            ).innerText =
                next
                    ? formatMoney(
                        next.requiredVolume
                    )
                    : "Completed";

            document.getElementById(
                "rankProgressDescription"
            ).innerText =
                next
                    ? `Reach ${formatMoney(next.requiredVolume)} ` +
                      `in total network volume to unlock ${next.name}.`
                    : "You have reached the highest membership level.";

            document.getElementById(
                "dailyProfitPercent"
            ).innerText =
                formatPercent(
                    current?.dailyProfitPercent
                );

            document.getElementById(
                "monthlyProfitPercent"
            ).innerText =
                formatPercent(
                    current?.monthlyProfitPercent
                );

            document.getElementById(
                "referralProfitPercent"
            ).innerText =
                formatPercent(
                    current?.referralProfitPercent
                );

            /*
             * نام فیلد Backend برای حفظ سازگاری
             * mainToInvestPercent باقی می‌ماند.
             * عنوان نمایشی Referral Commission است.
             */
            document.getElementById(
                "referralCommissionPercent"
            ).innerText =
                formatPercent(
                    current?.mainToInvestPercent
                );



            renderRankCards(
                data.ranks || [],
                current,
                next,
                volume
            );

            const defaultRank =
                current ||
                data.ranks?.[0] ||
                null;

            if (defaultRank) {
                selectRank(
                    defaultRank.rankId
                );
            }
        }

        function renderRankCards(
            ranks,
            currentRank,
            nextRank,
            networkVolume
        ) {
            const container =
                document.getElementById(
                    "rankCardsGrid"
                );

            container.innerHTML = "";

            ranks.forEach(rank => {
                const rankId =
                    Number(rank.rankId);

                const isCurrent =
                    Number(currentRank?.rankId) ===
                    rankId;

                const isNext =
                    Number(nextRank?.rankId) ===
                    rankId;

                const isUnlocked =
                    networkVolume >=
                    Number(rank.requiredVolume || 0);

                const button =
                    document.createElement("button");

                button.type = "button";

                button.className =
                    "rank-v2-level-card";

                button.dataset.rankId =
                    String(rankId);

                button.dataset.rankName =
                    normalizeRankName(
                        rank.name
                    );

                if (isCurrent) {
                    button.classList.add(
                        "current"
                    );
                } else if (isUnlocked) {
                    button.classList.add(
                        "unlocked"
                    );
                } else {
                    button.classList.add(
                        "locked"
                    );
                }

                const badgeText =
                    isCurrent
                        ? "Current"
                        : isNext
                            ? "Next"
                            : isUnlocked
                                ? "Unlocked"
                                : "Locked";

                button.innerHTML = `
                    <div class="rank-v2-level-top">

                        <span class="rank-media-shell rank-media-card-shell">

                            <img class="rank-media-img rank-v2-level-gif"
                                 src=""
                                 alt="" />

                        </span>

                        <span class="rank-v2-level-badge">
                            ${badgeText}
                        </span>

                    </div>

                    <div class="rank-v2-level-name">
                        <span>Membership</span>

                        <strong>
                            ${escapeHtml(rank.name)}
                        </strong>
                    </div>

                    <div class="rank-v2-level-volume">
                        <span>Required Volume</span>

                        <strong>
                            ${formatMoney(
                                rank.requiredVolume
                            )}
                        </strong>
                    </div>

                    <div class="rank-v2-level-preview">

                        <div>
                            <span>Daily</span>

                            <strong>
                                ${formatPercent(
                                    rank.dailyProfitPercent
                                )}
                            </strong>
                        </div>

                        <div>
                            <span>Commission</span>

                            <strong>
                                ${formatPercent(
                                    rank.mainToInvestPercent
                                )}
                            </strong>
                        </div>

                    </div>
                `;
                setOtradeRankImage(
                button.querySelector(
                        ".rank-v2-level-gif"
                    ),
                    rank.name
                );
                button.addEventListener(
                    "click",
                    function () {
                        selectRank(rankId);
                    }
                );

                container.appendChild(
                    button
                );
            });
        }

        function selectRank(rankId) {
            if (!rankOverviewData) {
                return;
            }

            const ranks =
                rankOverviewData.ranks || [];

            const selected =
                ranks.find(
                    rank =>
                        Number(rank.rankId) ===
                        Number(rankId)
                );

            if (!selected) {
                return;
            }

            selectedRankId =
                Number(selected.rankId);

            document
                .querySelectorAll(
                    ".rank-v2-level-card"
                )
                .forEach(card => {
                    card.classList.toggle(
                        "selected",
                        Number(
                            card.dataset.rankId
                        ) === selectedRankId
                    );
                });

            renderSelectedRank(
                selected
            );
        }

        function renderSelectedRank(rank) {
            const volume = Number(
                rankOverviewData?.networkVolume || 0
            );

            const requiredVolume = Number(
                rank.requiredVolume || 0
            );

            const currentRankId = Number(
                rankOverviewData
                    ?.currentRank
                    ?.rankId || 0
            );

            const isCurrent =
                Number(rank.rankId) ===
                currentRankId;

            const isUnlocked =
                volume >= requiredVolume;

            const progress =
                requiredVolume <= 0
                    ? 100
                    : Math.min(
                        100,
                        Math.max(
                            0,
                            (
                                volume /
                                requiredVolume
                            ) * 100
                        )
                    );

            const remaining =
                Math.max(
                    0,
                    requiredVolume - volume
                );

            document.getElementById(
                "selectedRankName"
            ).innerText =
                rank.name;

            document.getElementById(
                "selectedRankDescription"
            ).innerText =
                getRankDescription(
                    rank.name
                );

            document.getElementById(
                "selectedRequiredVolume"
            ).innerText =
                formatMoney(
                    requiredVolume
                );

            document.getElementById(
                "selectedDailyProfit"
            ).innerText =
                formatPercent(
                    rank.dailyProfitPercent
                );

            document.getElementById(
                "selectedMonthlyProfit"
            ).innerText =
                formatPercent(
                    rank.monthlyProfitPercent
                );

            document.getElementById(
                "selectedReferralProfit"
            ).innerText =
                formatPercent(
                    rank.referralProfitPercent
                );

            document.getElementById(
                "selectedReferralCommission"
            ).innerText =
                formatPercent(
                    rank.mainToInvestPercent
                );

            document.getElementById(
                "selectedProgressPercent"
            ).innerText =
                formatPercent(progress);

            document.getElementById(
                "selectedProgressBar"
            ).style.width =
                progress + "%";

            const statusElement =
                document.getElementById(
                    "selectedRankStatus"
                );

            statusElement.className =
                "rank-v2-selected-status";

            if (isCurrent) {
                statusElement.innerText =
                    "Current Rank";

                statusElement.classList.add(
                    "current"
                );

            } else if (isUnlocked) {
                statusElement.innerText =
                    "Unlocked";

                statusElement.classList.add(
                    "unlocked"
                );

            } else {
                statusElement.innerText =
                    "Locked";

                statusElement.classList.add(
                    "locked"
                );
            }

            document.getElementById(
                "selectedProgressText"
            ).innerText =
                isCurrent
                    ? "This is your current active membership level."
                    : isUnlocked
                        ? "You have reached the required network volume for this membership."
                        : `${formatMoney(remaining)} additional network volume is required.`;

        setOtradeRankImage(
            "selectedRankImage",
            rank.name,
            {
                eager: true
            }
        );
        }


        function getRankDescription(rankName) {
            const key =
                normalizeRankName(rankName);

            return (
                rankDescriptions[key] ||
                "Review the requirements and benefits of this membership level."
            );
        }

        function normalizeRankName(value) {
            return String(value || "")
                .trim()
                .toLowerCase()
                .replace(/\s+/g, "-");
        }

        function formatMoney(value) {
            const number =
                Number(value || 0);

            return "$" +
                number.toLocaleString(
                    "en-US",
                    {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }
                );
        }

        function formatPercent(value) {
            const number =
                Number(value || 0);

            return (
                number.toLocaleString(
                    "en-US",
                    {
                        minimumFractionDigits: 0,
                        maximumFractionDigits: 2
                    }
                ) + "%"
            );
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }
    </script>
}