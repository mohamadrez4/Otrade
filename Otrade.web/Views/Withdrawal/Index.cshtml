@{
    ViewData["Title"] = "Withdrawal";
}

<div class="panel-card">
    <div class="withdrawal-header">
        <div>
            <h3>Withdrawal Request</h3>
            <p>
                Submit a withdrawal request from your Main Wallet. Your KYC must be approved and your wallet address must be registered.
            </p>
        </div>
    </div>

    <div class="withdraw-balance-box">
        <span>Available Main Wallet Balance</span>
        <div class="withdraw-balance-right">
            <strong id="mainWalletBalance">0.00 USDT</strong>
        </div>
    </div>

    <form id="withdrawalForm" class="withdrawal-form">
        <div class="withdrawal-form-group">
            <label for="amount">Amount</label>

            <input id="amount"
                   name="amount"
                   type="number"
                   min="1"
                   step="0.01"
                   class="panel-input"
                   placeholder="Enter withdrawal amount"
                   required />
        </div>

        <button id="submitWithdrawalBtn" type="submit" class="panel-primary-btn">
            Send Verification Code
        </button>
    </form>

    <div id="withdrawalVerificationBox"
         class="withdrawal-verification-box"
         style="display:none;">

        <div class="withdrawal-verification-header">
            <h4>Email Verification</h4>
            <p>
                A 6-digit verification code has been sent to your email.
                Enter the code below to submit your withdrawal request.
            </p>
        </div>

        <div class="withdrawal-verification-summary">
            <div>
                <span>Amount</span>
                <strong id="withdrawVerifyAmount">0.00 USDT</strong>
            </div>

            <div>
                <span>Network</span>
                <strong id="withdrawVerifyNetwork">-</strong>
            </div>

            <div>
                <span>Wallet Address</span>
                <strong id="withdrawVerifyAddress">-</strong>
            </div>
        </div>

        <div class="withdrawal-code-field">
            <label for="withdrawalVerificationCode">Verification Code</label>

            <input id="withdrawalVerificationCode"
                   type="text"
                   maxlength="6"
                   inputmode="numeric"
                   autocomplete="one-time-code"
                   class="panel-input withdrawal-code-input"
                   placeholder="Enter 6-digit code" />
        </div>

        <div class="withdrawal-verification-actions">
            <button type="button"
                    id="resetWithdrawalVerificationBtn"
                    class="withdrawal-secondary-btn">
                Change Amount
            </button>

            <button type="button"
                    id="confirmWithdrawalBtn"
                    class="panel-primary-btn">
                Confirm Withdrawal
            </button>
        </div>
    </div>
</div>

<div class="panel-card mt-4">
    <div class="withdrawal-header">
        <div>
            <h3>Withdrawal History</h3>
            <p>You can cancel pending withdrawal requests before admin approval.</p>
        </div>
    </div>

    <div id="withdrawalsMessage" class="withdrawal-message">
        Loading withdrawals...
    </div>

    <div id="withdrawalsWrapper" class="withdrawal-table-wrapper" style="display:none;">
        <table class="withdrawal-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Network</th>
                    <th>Wallet Address</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Note</th>
                    <th>Processed At</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>

            <tbody id="withdrawalsBody"></tbody>
        </table>
    </div>

    <div id="withdrawalsPagination" class="withdrawal-history-pagination" style="display:none;">
        <button id="withdrawalsPrevBtn"
                class="withdrawal-history-page-btn"
                type="button">
            Previous
        </button>

        <span id="withdrawalsPageInfo"></span>

        <button id="withdrawalsNextBtn"
                class="withdrawal-history-page-btn"
                type="button">
            Next
        </button>
    </div>
</div>

@section Scripts {
    <script>
        let mainWalletBalance = 0;

        let withdrawalVerificationId = null;
        let withdrawalVerificationLocked = false;
        let withdrawalVerifiedAmount = 0;

        let withdrawalsCurrentPage = 1;
        const withdrawalsPageSize = 5;
        let withdrawalsTotalPages = 1;

        const withdrawalForm = document.getElementById("withdrawalForm");
        const amountInput = document.getElementById("amount");
        const submitWithdrawalBtn = document.getElementById("submitWithdrawalBtn");

        const withdrawalVerificationBox = document.getElementById("withdrawalVerificationBox");
        const withdrawalVerificationCode = document.getElementById("withdrawalVerificationCode");
        const resetWithdrawalVerificationBtn = document.getElementById("resetWithdrawalVerificationBtn");
        const confirmWithdrawalBtn = document.getElementById("confirmWithdrawalBtn");

        const withdrawVerifyAmount = document.getElementById("withdrawVerifyAmount");
        const withdrawVerifyNetwork = document.getElementById("withdrawVerifyNetwork");
        const withdrawVerifyAddress = document.getElementById("withdrawVerifyAddress");

        const withdrawalsMessage = document.getElementById("withdrawalsMessage");
        const withdrawalsWrapper = document.getElementById("withdrawalsWrapper");
        const withdrawalsBody = document.getElementById("withdrawalsBody");

        const withdrawalsPagination = document.getElementById("withdrawalsPagination");
        const withdrawalsPrevBtn = document.getElementById("withdrawalsPrevBtn");
        const withdrawalsNextBtn = document.getElementById("withdrawalsNextBtn");
        const withdrawalsPageInfo = document.getElementById("withdrawalsPageInfo");

        withdrawalForm.addEventListener("submit", submitWithdrawalRequest);

        resetWithdrawalVerificationBtn.addEventListener("click", resetWithdrawalVerification);

        confirmWithdrawalBtn.addEventListener("click", confirmWithdrawalRequest);

        withdrawalsPrevBtn.addEventListener("click", async function () {
            if (withdrawalsCurrentPage <= 1) {
                return;
            }

            withdrawalsCurrentPage--;
            await loadWithdrawals();
        });

        withdrawalsNextBtn.addEventListener("click", async function () {
            if (withdrawalsCurrentPage >= withdrawalsTotalPages) {
                return;
            }

            withdrawalsCurrentPage++;
            await loadWithdrawals();
        });

        withdrawalVerificationCode.addEventListener("input", function () {
            this.value = this.value.replace(/\D/g, "").slice(0, 6);
        });

        withdrawalVerificationCode.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                confirmWithdrawalRequest();
            }
        });

        async function submitWithdrawalRequest(e) {
            e.preventDefault();

            if (withdrawalVerificationLocked) {
                showNotification("Please confirm current verification or reset it first.", "warning");
                return;
            }

            const amount = Number(amountInput.value || 0);

            if (!amount || amount <= 0) {
                showNotification("Please enter a valid amount.", "warning");
                return;
            }

            if (amount > mainWalletBalance) {
                showNotification("Amount is greater than your Main Wallet balance.", "error");
                return;
            }

            const confirmed = await showConfirm(
                `Send verification code for withdrawal of ${formatMoney(amount)} USDT?`,
                "Withdrawal Verification"
            );

            if (!confirmed) {
                return;
            }

            submitWithdrawalBtn.disabled = true;
            submitWithdrawalBtn.innerText = "Sending Code...";

            try {
                const result = await api("/api/wallet/withdrawal/request", {
                    method: "POST",
                    body: JSON.stringify({ amount })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not send verification code.", "error");
                    return;
                }

                withdrawalVerificationId = result.data.verificationId;
                withdrawalVerifiedAmount = Number(result.data.amount || amount);

                withdrawVerifyAmount.innerText =
                    formatMoney(withdrawalVerifiedAmount) + " USDT";

                withdrawVerifyNetwork.innerText =
                    result.data.network || "-";

                withdrawVerifyAddress.innerText =
                    result.data.walletAddress || "-";

                setWithdrawalVerificationLocked(true);

                withdrawalVerificationBox.style.display = "block";

                showNotification(result.message || "Verification code sent to your email.", "success");

                setTimeout(() => {
                    withdrawalVerificationCode.focus();
                }, 100);

            } catch (error) {
                showNotification(error.message || "Could not send verification code.", "error");
            } finally {
                submitWithdrawalBtn.disabled = false;
                submitWithdrawalBtn.innerText = "Send Verification Code";
            }
        }

        async function confirmWithdrawalRequest() {
            const code = withdrawalVerificationCode.value.trim();

            if (!withdrawalVerificationId) {
                showNotification("Verification request was not created.", "error");
                return;
            }

            if (!code) {
                showNotification("Verification code is required.", "error");
                return;
            }

            if (code.length !== 6) {
                showNotification("Verification code must be 6 digits.", "error");
                return;
            }

            const confirmed = await showConfirm(
                `Confirm withdrawal request of ${formatMoney(withdrawalVerifiedAmount)} USDT?`,
                "Confirm Withdrawal"
            );

            if (!confirmed) {
                return;
            }

            confirmWithdrawalBtn.disabled = true;
            confirmWithdrawalBtn.innerText = "Confirming...";

            try {
                const result = await api("/api/wallet/withdrawal/confirm", {
                    method: "POST",
                    body: JSON.stringify({
                        verificationId: withdrawalVerificationId,
                        code
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Withdrawal confirmation failed.", "error");
                    return;
                }

                showNotification(result.message || "Withdrawal request submitted.", "success");

                resetWithdrawalFormAfterSuccess();

                withdrawalsCurrentPage = 1;

                await loadWalletBalance();
                await loadWithdrawals();

            } catch (error) {
                showNotification(error.message || "Withdrawal confirmation failed.", "error");
            } finally {
                confirmWithdrawalBtn.disabled = false;
                confirmWithdrawalBtn.innerText = "Confirm Withdrawal";
            }
        }

        function setWithdrawalVerificationLocked(isLocked) {
            withdrawalVerificationLocked = isLocked;

            amountInput.disabled = isLocked;
            submitWithdrawalBtn.style.display = isLocked ? "none" : "inline-flex";
        }

        function resetWithdrawalVerification() {
            withdrawalVerificationId = null;
            withdrawalVerifiedAmount = 0;

            setWithdrawalVerificationLocked(false);
            hideWithdrawalVerificationBox();

            showNotification("You can now change amount and request a new code.", "success");
        }

        function resetWithdrawalFormAfterSuccess() {
            withdrawalVerificationId = null;
            withdrawalVerifiedAmount = 0;

            setWithdrawalVerificationLocked(false);

            amountInput.value = "";

            hideWithdrawalVerificationBox();
        }

        function hideWithdrawalVerificationBox() {
            withdrawalVerificationBox.style.display = "none";

            withdrawalVerificationCode.value = "";

            withdrawVerifyAmount.innerText = "0.00 USDT";
            withdrawVerifyNetwork.innerText = "-";
            withdrawVerifyAddress.innerText = "-";
        }

        async function loadWalletBalance() {
            try {
                const result = await api("/api/dashboard");

                if (!result.success) return;

                const wallet = result.data.wallets.find(x => x.walletType === "Main");

                if (!wallet) return;

                mainWalletBalance = Number(wallet.balance || 0);

                document.getElementById("mainWalletBalance").innerText =
                    formatMoney(mainWalletBalance) + " USDT";

            } catch {
                showNotification("Could not load wallet balance.", "error");
            }
        }

        async function loadWithdrawals() {
            withdrawalsMessage.style.display = "block";
            withdrawalsMessage.innerText = "Loading withdrawals...";
            withdrawalsWrapper.style.display = "none";
            withdrawalsPagination.style.display = "none";
            withdrawalsBody.innerHTML = "";

            try {
                const url =
                    `/api/wallet/withdrawals/my-history?page=${withdrawalsCurrentPage}&pageSize=${withdrawalsPageSize}`;

                const result = await api(url);

                if (!result || !result.success) {
                    withdrawalsMessage.innerText =
                        result?.message || "Could not load withdrawals.";
                    return;
                }

                const data = result.data || {};
                const items = data.items || [];

                withdrawalsCurrentPage = data.page || 1;
                withdrawalsTotalPages = data.totalPages || 1;

                if (!items.length) {
                    withdrawalsMessage.innerText = "No withdrawals found.";
                    withdrawalsPagination.style.display = "none";
                    return;
                }

                items.forEach(item => {
                    const row = document.createElement("tr");
                    const status = String(item.status || "").toLowerCase();
                    const note = item.adminNote || "-";

                    row.innerHTML = `
                        <td>${formatDate(item.createdAt)}</td>

                        <td>
                            <span class="withdraw-network">
                                ${escapeHtml(item.network || "-")}
                            </span>
                        </td>

                        <td class="withdraw-wallet-address">
                            ${escapeHtml(item.walletAddress || "-")}
                        </td>

                        <td class="withdraw-amount">
                            ${formatMoney(item.amount)} USDT
                        </td>

                        <td>
                            <span class="withdraw-status ${escapeHtml(status)}">
                                ${escapeHtml(item.status || "-")}
                            </span>
                        </td>

                        <td>
                            <span class="withdraw-note ${note !== "-" ? "has-note" : ""}">
                                ${escapeHtml(note)}
                            </span>
                        </td>

                        <td>${formatDate(item.processedAt)}</td>

                        <td class="text-end">
                            ${
                                item.canCancel
                                    ? `<button class="withdraw-cancel-btn" onclick="cancelWithdrawal(${item.withdrawalId})">Cancel</button>`
                                    : "-"
                            }
                        </td>
                    `;

                    withdrawalsBody.appendChild(row);
                });

                withdrawalsMessage.style.display = "none";
                withdrawalsWrapper.style.display = "block";

                renderWithdrawalsPagination(data);

            } catch {
                withdrawalsMessage.innerText = "Could not load withdrawals.";
                withdrawalsPagination.style.display = "none";
            }
        }

        function renderWithdrawalsPagination(data) {
            const totalCount = data.totalCount || 0;

            if (totalCount <= 0) {
                withdrawalsPagination.style.display = "none";
                return;
            }

            withdrawalsCurrentPage = data.page || 1;
            withdrawalsTotalPages = data.totalPages || 1;

            withdrawalsPagination.style.display = "flex";

            withdrawalsPageInfo.innerText =
                `Page ${withdrawalsCurrentPage} of ${withdrawalsTotalPages} - Total: ${totalCount}`;

            withdrawalsPrevBtn.disabled = withdrawalsCurrentPage <= 1;
            withdrawalsNextBtn.disabled = withdrawalsCurrentPage >= withdrawalsTotalPages;
        }

        async function cancelWithdrawal(withdrawalId) {
            const confirmed = await showConfirm(
                "Are you sure you want to cancel this withdrawal request?",
                "Cancel Withdrawal"
            );

            if (!confirmed) return;

            try {
                const result = await api(`/api/wallet/withdrawals/cancel/${withdrawalId}`, {
                    method: "POST"
                });

                if (!result.success) {
                    showNotification(result.message || "Could not cancel withdrawal.", "error");
                    return;
                }

                showNotification(result.message || "Withdrawal canceled successfully.", "success");

                await loadWalletBalance();
                await loadWithdrawals();

            } catch {
                showNotification("Could not cancel withdrawal.", "error");
            }
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 8
            });
        }

        function formatDate(value) {
            if (!value) return "-";

            return new Date(value).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit"
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        hideWithdrawalVerificationBox();
        setWithdrawalVerificationLocked(false);

        loadWalletBalance();
        loadWithdrawals();
    </script>
}