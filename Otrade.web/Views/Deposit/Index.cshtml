@{
    ViewData["Title"] = "Deposit";
}

<div class="panel-card">
    <div class="deposit-header">
        <div>
            <h3>Deposit Request</h3>
            <p>
                Submit your deposit amount and transaction hash. Your request will be reviewed by the admin.
                The approved amount will be credited to your Main Wallet.
            </p>
        </div>
    </div>

    <div id="depositWalletBox" class="deposit-wallet-box" style="display:none;">
        <p class="deposit-wallet-title">
            Please use the wallet address below to complete your deposit.
        </p>

        <div class="deposit-wallet-content">
            <div>
                <span>Network</span>
                <strong id="depositNetwork">-</strong>
            </div>

            <div>
                <span>Wallet Address</span>
                <strong id="depositWalletAddress">-</strong>
            </div>

            <button id="copyDepositAddressBtn" type="button" class="deposit-copy-btn">
                Copy
            </button>
        </div>
    </div>

    <form id="depositForm" class="deposit-form">

        <div class="deposit-form-group">
            <label for="amount">Amount</label>

            <input id="amount"
                   name="amount"
                   type="number"
                   min="1"
                   step="0.00000001"
                   class="panel-input"
                   placeholder="Enter deposit amount"
                   required />
        </div>

        <div class="deposit-form-group">
            <label for="txId">Transaction Hash</label>

            <input id="txId"
                   name="txId"
                   type="text"
                   class="panel-input"
                   placeholder="Enter full transaction hash"
                   required />
        </div>

        <button id="submitDepositBtn" type="submit" class="panel-primary-btn">
            Submit Deposit Request
        </button>

    </form>
</div>

<div class="panel-card mt-4">
    <div class="deposit-header">
        <div>
            <h3>Deposit History</h3>
            <p>
                Track your deposit requests, status, admin note, and transaction hash.
            </p>
        </div>
    </div>

    <div id="depositsMessage" class="deposit-history-message">
        Loading deposits...
    </div>

    <div id="depositsWrapper" class="deposit-history-wrapper" style="display:none;">
        <table class="deposit-history-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Tx Hash</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Note</th>
                    <th>Processed At</th>
                </tr>
            </thead>

            <tbody id="depositsBody"></tbody>
        </table>
    </div>

    <div id="depositsPagination" class="deposit-history-pagination" style="display:none;">
        <button id="depositsPrevBtn"
                class="deposit-history-page-btn"
                type="button">
            Previous
        </button>

        <span id="depositsPageInfo"></span>

        <button id="depositsNextBtn"
                class="deposit-history-page-btn"
                type="button">
            Next
        </button>
    </div>
</div>

@section Scripts {
    <script>
        const depositForm = document.getElementById("depositForm");
        const amountInput = document.getElementById("amount");
        const txIdInput = document.getElementById("txId");
        const submitDepositBtn = document.getElementById("submitDepositBtn");

        const depositWalletBox = document.getElementById("depositWalletBox");
        const depositNetwork = document.getElementById("depositNetwork");
        const depositWalletAddress = document.getElementById("depositWalletAddress");
        const copyDepositAddressBtn = document.getElementById("copyDepositAddressBtn");

        const depositsMessage = document.getElementById("depositsMessage");
        const depositsWrapper = document.getElementById("depositsWrapper");
        const depositsBody = document.getElementById("depositsBody");

        const depositsPagination = document.getElementById("depositsPagination");
        const depositsPrevBtn = document.getElementById("depositsPrevBtn");
        const depositsNextBtn = document.getElementById("depositsNextBtn");
        const depositsPageInfo = document.getElementById("depositsPageInfo");

        let siteWalletAddress = "";

        let depositsCurrentPage = 1;
        const depositsPageSize = 5;
        let depositsTotalPages = 1;

        depositForm.addEventListener("submit", submitDepositRequest);

        copyDepositAddressBtn.addEventListener("click", function () {
            copyText(siteWalletAddress);
        });

        depositsPrevBtn.addEventListener("click", async function () {
            if (depositsCurrentPage <= 1) {
                return;
            }

            depositsCurrentPage--;
            await loadDeposits();
        });

        depositsNextBtn.addEventListener("click", async function () {
            if (depositsCurrentPage >= depositsTotalPages) {
                return;
            }

            depositsCurrentPage++;
            await loadDeposits();
        });

        async function submitDepositRequest(e) {
            e.preventDefault();

            const amount = Number(amountInput.value || 0);
            const txId = txIdInput.value.trim();

            if (!amount || amount <= 0) {
                showNotification("Please enter a valid amount.", "warning");
                return;
            }

            if (!txId) {
                showNotification("Please enter the transaction hash.", "warning");
                return;
            }

            const confirmed = await showConfirm(
                `Submit deposit request for ${formatMoney(amount)} USDT?`,
                "Submit Deposit"
            );

            if (!confirmed) {
                return;
            }

            submitDepositBtn.disabled = true;
            submitDepositBtn.innerText = "Submitting...";

            try {
                const result = await api("/api/wallet/deposit/request", {
                    method: "POST",
                    body: JSON.stringify({
                        amount: amount,
                        txId: txId
                    })
                });

                if (!result || !result.success) {
                    showNotification(result?.message || "Could not submit deposit request.", "error");
                    return;
                }

                showNotification(result.message || "Deposit request submitted successfully.", "success");

                amountInput.value = "";
                txIdInput.value = "";

                depositsCurrentPage = 1;
                await loadDeposits();

            } catch (error) {
                showNotification(error.message || "Could not submit deposit request.", "error");
            } finally {
                submitDepositBtn.disabled = false;
                submitDepositBtn.innerText = "Submit Deposit Request";
            }
        }

        async function loadDepositInfo() {
            try {
                const result = await api("/api/wallet/deposit/info");

                if (!result || !result.success) {
                    depositWalletBox.style.display = "none";
                    return;
                }

                const data = result.data || {};

                siteWalletAddress = data.siteWalletAddress || data.SiteWalletAddress || "";
                const network = data.network || data.Network || "";

                depositNetwork.innerText = network || "-";
                depositWalletAddress.innerText = siteWalletAddress || "-";

                depositWalletBox.style.display = "block";

            } catch {
                depositWalletBox.style.display = "none";
            }
        }

        async function loadDeposits() {
            depositsMessage.style.display = "block";
            depositsMessage.innerText = "Loading deposits...";
            depositsWrapper.style.display = "none";
            depositsPagination.style.display = "none";
            depositsBody.innerHTML = "";

            try {
                const url =
                    `/api/wallet/deposits/my-history?page=${depositsCurrentPage}&pageSize=${depositsPageSize}`;

                const result = await api(url);

                if (!result || !result.success) {
                    depositsMessage.innerText = result?.message || "Could not load deposits.";
                    return;
                }

                const data = result.data || {};
                const items = data.items || [];

                depositsCurrentPage = data.page || 1;
                depositsTotalPages = data.totalPages || 1;

                if (!items.length) {
                    depositsMessage.innerText = "No deposits found.";
                    depositsPagination.style.display = "none";
                    return;
                }

                items.forEach(item => {
                    const row = document.createElement("tr");
                    const status = String(item.status || "").toLowerCase();
                    const note = item.adminNote || "-";

                    row.innerHTML = `
                        <td>${formatDate(item.createdAt)}</td>

                        <td>
                            <div class="deposit-tx-cell">
                                <span title="${escapeHtml(item.txId || "")}">
                                    ${escapeHtml(item.txId || "-")}
                                </span>

                                ${
                                    item.txId
                                        ? `<button type="button" onclick="copyText('${escapeForJs(item.txId)}')">Copy</button>`
                                        : ""
                                }
                            </div>
                        </td>

                        <td>
                            <span class="deposit-amount">
                                ${formatMoney(item.amount)} USDT
                            </span>
                        </td>

                        <td>
                            <span class="deposit-status ${escapeHtml(status)}">
                                ${escapeHtml(item.status || "-")}
                            </span>
                        </td>

                        <td>
                            <span class="deposit-note ${note !== "-" ? "has-note" : ""}">
                                ${escapeHtml(note)}
                            </span>
                        </td>

                        <td>${formatDate(item.processedAt)}</td>
                    `;

                    depositsBody.appendChild(row);
                });

                depositsMessage.style.display = "none";
                depositsWrapper.style.display = "block";

                renderDepositsPagination(data);

            } catch {
                depositsMessage.innerText = "Could not load deposits.";
                depositsPagination.style.display = "none";
            }
        }

        function renderDepositsPagination(data) {
            const totalCount = data.totalCount || 0;

            if (totalCount <= 0) {
                depositsPagination.style.display = "none";
                return;
            }

            depositsCurrentPage = data.page || 1;
            depositsTotalPages = data.totalPages || 1;

            depositsPagination.style.display = "flex";

            depositsPageInfo.innerText =
                `Page ${depositsCurrentPage} of ${depositsTotalPages} - Total: ${totalCount}`;

            depositsPrevBtn.disabled = depositsCurrentPage <= 1;
            depositsNextBtn.disabled = depositsCurrentPage >= depositsTotalPages;
        }

        async function copyText(value) {
            if (!value) {
                showNotification("Nothing to copy.", "warning");
                return;
            }

            try {
                await navigator.clipboard.writeText(value);
                showNotification("Copied to clipboard.", "success");
            } catch {
                const textarea = document.createElement("textarea");
                textarea.value = value;
                textarea.style.position = "fixed";
                textarea.style.opacity = "0";

                document.body.appendChild(textarea);
                textarea.focus();
                textarea.select();

                document.execCommand("copy");
                document.body.removeChild(textarea);

                showNotification("Copied to clipboard.", "success");
            }
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 8
            });
        }

        function formatDate(value) {
            if (!value) return "-";

            return new Date(value).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "2-digit"
            });
        }

        function escapeHtml(value) {
            return String(value || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function escapeForJs(value) {
            return String(value || "")
                .replaceAll("\\", "\\\\")
                .replaceAll("'", "\\'")
                .replaceAll('"', '\\"')
                .replaceAll("\n", "")
                .replaceAll("\r", "");
        }

        loadDepositInfo();
        loadDeposits();
    </script>
}