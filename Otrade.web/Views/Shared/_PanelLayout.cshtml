<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />

    <title>
        @ViewData["Title"] | Otrade
    </title>

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <link href="~/css/panel.css"
          rel="stylesheet"
          asp-append-version="true" />

    <link href="~/css/common.css"
          rel="stylesheet"
          asp-append-version="true" />

    <link rel="icon"
          type="image/x-icon"
          href="~/favicon.ico?v=1" />

    <link rel="icon"
          type="image/png"
          sizes="32x32"
          href="~/favicon-32x32.png?v=1" />

    <link rel="apple-touch-icon"
          href="~/apple-touch-icon.png?v=1" />


</head>

<body class="panel-body">

    <div class="panel-layout">

        <div id="notificationContainer"
             class="notification-container">
        </div>

        <aside class="sidebar"
               id="panelSidebar"
               aria-label="User panel navigation">

            <div class="sidebar-logo">

                <img src="~/images/logo.png"
                     alt="Otrade Logo" />

            </div>

            <div class="sidebar-uid-chip"
                 id="sidebarUidCard"
                 style="display:none;">

                <span>UID</span>

                <strong id="sidebarUserUid">
                    -
                </strong>

            </div>

            <nav class="sidebar-nav">

                <a href="/dashboard"
                   class="nav-item">
                    <span>Dashboard</span>
                </a>

                <a href="/wallets"
                   class="nav-item">
                    <span>Wallets</span>
                </a>

                <a href="/bonus-codes"
                   class="nav-item">
                    <span>Bonus Codes</span>
                </a>

                <a href="/contracts"
                   class="nav-item">
                    <span>Contracts</span>
                </a>

                <a href="/deposit"
                   class="nav-item">
                    <span>Deposit</span>
                </a>

                <a href="/withdrawal"
                   class="nav-item">
                    <span>Withdrawal</span>
                </a>

                <a href="/profits"
                   class="nav-item">
                    <span>Profits</span>
                </a>

                <a href="/referral"
                   class="nav-item">
                    <span>Referral</span>
                </a>

                <a href="/rank"
                   class="nav-item">
                    <span>Rank</span>
                </a>

                <a href="/reports"
                   class="nav-item">
                    <span>Reports</span>
                </a>

                <a href="/tickets"
                   class="nav-item">
                    <span>Tickets</span>
                </a>

                <a href="/profile"
                   class="nav-item">
                    <span>Profile</span>
                </a>

            </nav>

            <button type="button"
                    class="logout-btn"
                    onclick="logout()">
                Logout
            </button>

        </aside>

        <div id="sidebarMobileOverlay"
             class="sidebar-mobile-overlay"
             aria-hidden="true">
        </div>

        <main class="panel-main">

            <header class="topbar">

                <button type="button"
                        class="mobile-menu-btn"
                        id="mobileMenuBtn"
                        aria-label="Open menu"
                        aria-controls="panelSidebar"
                        aria-expanded="false">
                    ☰
                </button>

                <div>
                    <h4>
                        @ViewData["Title"]
                    </h4>
                </div>

            </header>

            <section class="content">
                @RenderBody()
            </section>

        </main>

    </div>

    <script src="~/js/common.js"
            asp-append-version="true">
    </script>

    <script src="~/js/auth.js"
            asp-append-version="true">
    </script>

    <script>
        checkAuth();
    </script>

    <script src="~/js/api.js"
            asp-append-version="true">
    </script>

    <script src="~/js/rank-assets.js"
            asp-append-version="true">
    </script>

    <script>
        (function () {
            const currentPath =
                window.location.pathname
                    .toLowerCase();

            document
                .querySelectorAll(
                    ".sidebar-nav a"
                )
                .forEach(
                    function (link) {
                        const href =
                            String(
                                link.getAttribute(
                                    "href"
                                ) || ""
                            )
                            .toLowerCase();

                        if (
                            currentPath === href ||
                            currentPath.startsWith(
                                href + "/"
                            )
                        ) {
                            link.classList.add(
                                "active"
                            );
                        }
                    }
                );
        })();

        async function loadPanelUserUid() {
            try {
                const result =
                    await api(
                        "/api/profile"
                    );

                if (
                    !result ||
                    !result.success ||
                    !result.data?.referralCode
                ) {
                    return;
                }

                const uidElement =
                    document.getElementById(
                        "sidebarUserUid"
                    );

                const uidCard =
                    document.getElementById(
                        "sidebarUidCard"
                    );

                if (
                    uidElement &&
                    uidCard
                ) {
                    uidElement.innerText =
                        result.data
                            .referralCode;

                    uidCard.style.display =
                        "inline-flex";
                }

            } catch {
                /*
                 * UID loading failure should not
                 * prevent the panel from loading.
                 */
            }
        }

        loadPanelUserUid();
    </script>

  <script>
    (function () {
        if (window.__otradeAdminSidebarInitialized) {
            return;
        }

        window.__otradeAdminSidebarInitialized =
            true;

        const body =
            document.body;

        const sidebar =
            document.querySelector(
                ".sidebar"
            );

        const menuButton =
            document.getElementById(
                "mobileMenuBtn"
            );

        const overlay =
            document.getElementById(
                "sidebarMobileOverlay"
            );

        const mobileMedia =
            window.matchMedia(
                "(max-width: 992px)"
            );

        function isMobileOrTablet() {
            return mobileMedia.matches;
        }

        function updateMenuState(isOpen) {
            if (menuButton) {
                menuButton.setAttribute(
                    "aria-expanded",
                    String(isOpen)
                );

                menuButton.setAttribute(
                    "aria-label",
                    isOpen
                        ? "Close menu"
                        : "Open menu"
                );
            }

            if (overlay) {
                overlay.setAttribute(
                    "aria-hidden",
                    String(!isOpen)
                );
            }

            if (sidebar) {
                sidebar.setAttribute(
                    "aria-hidden",
                    String(
                        isMobileOrTablet() &&
                        !isOpen
                    )
                );
            }
        }

        function openSidebar() {
            if (!isMobileOrTablet()) {
                return;
            }

            body.classList.add(
                "sidebar-open"
            );

            updateMenuState(true);
        }

        function closeSidebar() {
            body.classList.remove(
                "sidebar-open"
            );

            updateMenuState(false);
        }

        function toggleSidebar() {
            if (!isMobileOrTablet()) {
                return;
            }

            const isOpen =
                body.classList.contains(
                    "sidebar-open"
                );

            if (isOpen) {
                closeSidebar();
            } else {
                openSidebar();
            }
        }

        function synchronizeSidebar() {
            /*
             * کلاس قدیمی دیگر نباید در Desktop
             * منو را مخفی کند.
             */
            body.classList.remove(
                "sidebar-collapsed"
            );

            if (isMobileOrTablet()) {
                closeSidebar();
                return;
            }

            /*
             * در Desktop منو همیشه ثابت و باز است.
             */
            body.classList.remove(
                "sidebar-open"
            );

            updateMenuState(true);
        }

        if (menuButton) {
            menuButton.addEventListener(
                "click",
                function (event) {
                    event.preventDefault();
                    event.stopPropagation();

                    toggleSidebar();
                }
            );
        }

        if (overlay) {
            overlay.addEventListener(
                "click",
                function (event) {
                    event.preventDefault();

                    closeSidebar();
                }
            );
        }

        if (sidebar) {
            sidebar
                .querySelectorAll("a")
                .forEach(
                    function (link) {
                        link.addEventListener(
                            "click",
                            function () {
                                if (
                                    isMobileOrTablet()
                                ) {
                                    closeSidebar();
                                }
                            }
                        );
                    }
                );
        }

        document.addEventListener(
            "keydown",
            function (event) {
                if (
                    event.key === "Escape" &&
                    isMobileOrTablet()
                ) {
                    closeSidebar();
                }
            }
        );

        if (
            typeof mobileMedia.addEventListener ===
            "function"
        ) {
            mobileMedia.addEventListener(
                "change",
                synchronizeSidebar
            );
        } else {
            mobileMedia.addListener(
                synchronizeSidebar
            );
        }

        synchronizeSidebar();
    })();
</script>

    @RenderSection(
    "Scripts",
        required: false
        )

</body>

</html>