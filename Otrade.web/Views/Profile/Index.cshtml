            } else {
                twoFactorSetupScanTitle.innerText =
                    "Scan the QR code";

                twoFactorSetupScanHelp.innerHTML =
                    "Open Google Authenticator, select <strong>Add a code</strong>, and scan this QR code.";

                twoFactorSetupConfirmTitle.innerText =
                    "Confirm the setup";

                twoFactorSetupCodeHelp.innerText =
                    "Enter the current code shown in Google Authenticator.";

                confirmTwoFactorBtn.innerText =
                    twoFactorSetupMode === "replace"
                        ? "Verify and Replace"
                        : "Verify and Enable";

                restartTwoFactorSetupBtn.hidden =
                    false;
            }

            startTwoFactorSetupCountdown(
                data.expiresAt
            );

            twoFactorSetupCode.focus();
        }

        function clearTwoFactorSetupTimer() {
            if (twoFactorSetupTimer) {
                window.clearInterval(
                    twoFactorSetupTimer
                );

                twoFactorSetupTimer = null;
            }
        }

        function updateTwoFactorSetupCountdown() {
            if (!twoFactorSetupExpiresAt) {
                twoFactorSetupCountdown.innerText =
                    "--:--";

                return;
            }

            const remainingMilliseconds =
                twoFactorSetupExpiresAt.getTime() -
                Date.now();

            if (remainingMilliseconds <= 0) {
                clearTwoFactorSetupTimer();

                twoFactorSetupCountdown.innerText =
                    "Expired";

                confirmTwoFactorBtn.disabled =
                    true;

                twoFactorSetupCode.disabled =
                    true;

                return;
            }

            const totalSeconds =
                Math.floor(
                    remainingMilliseconds / 1000
                );

            const minutes =
                Math.floor(totalSeconds / 60);

            const seconds =
                totalSeconds % 60;

            twoFactorSetupCountdown.innerText =
                `${String(minutes).padStart(2, "0")}:` +
                `${String(seconds).padStart(2, "0")}`;
        }

        function startTwoFactorSetupCountdown(expiresAt) {
            clearTwoFactorSetupTimer();

            const parsedDate =
                new Date(expiresAt);

            if (Number.isNaN(parsedDate.getTime())) {
                twoFactorSetupExpiresAt =
                    null;

                twoFactorSetupCountdown.innerText =
                    "--:--";

                return;
            }

            twoFactorSetupExpiresAt =
                parsedDate;

            confirmTwoFactorBtn.disabled =
                false;

            twoFactorSetupCode.disabled =
                false;

            updateTwoFactorSetupCountdown();

            twoFactorSetupTimer =
                window.setInterval(
                    updateTwoFactorSetupCountdown,
                    1000
                );
        }

        async function copyTextToClipboard(
            value,
            successMessage
        ) {
            const text =
                String(value || "").trim();

            if (!text) {
                showNotification(
                    "There is nothing to copy.",
                    "warning"
                );

                return;
            }

            try {
                if (
                    navigator.clipboard &&
                    window.isSecureContext
                ) {
                    await navigator.clipboard
                        .writeText(text);
                } else {
                    const temporaryInput =
                        document.createElement(
                            "textarea"
                        );

                    temporaryInput.value =
                        text;

                    temporaryInput.style.position =
                        "fixed";

                    temporaryInput.style.opacity =
                        "0";

                    document.body.appendChild(
                        temporaryInput
                    );

                    temporaryInput.focus();
                    temporaryInput.select();

                    const copied =
                        document.execCommand(
                            "copy"
                        );

                    temporaryInput.remove();

                    if (!copied) {
                        throw new Error(
                            "Clipboard copy failed."
                        );
                    }
                }

                showNotification(
                    successMessage ||
                    "Copied successfully.",
                    "success"
                );

            } catch {
                showNotification(
                    "Could not copy automatically. Please copy it manually.",
                    "error"
                );
            }
        }

